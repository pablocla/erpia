{
  "nodes": [
    {
      "parameters": {
        "path": "cobranza-whatsapp-trigger",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        360
      ],
      "id": "trigger-id",
      "name": "Webhook Trigger"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.NOP_BASE_URL}}/api/automation/actions/create-task",
