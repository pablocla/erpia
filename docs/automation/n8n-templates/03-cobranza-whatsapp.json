        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        480,
        360
      ],
      "id": "wa-task-id",
      "name": "WA Template Dispatcher",
      "credentials": {
        "httpHeaderAuth": {
          "id": "nop-api-credentials",
          "name": "NOP API Key Header"
        }
      }
    }
  ],
  "connections": {
    "Webhook Trigger": {
      "main": [
        [
          {
            "node": "WA Template Dispatcher",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
