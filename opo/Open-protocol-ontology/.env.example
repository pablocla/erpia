# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# n8n Feedback Webhook Integration (Optional)
# If blank, forms fallback to direct GitHub Issues templates
NEXT_PUBLIC_N8N_WEBHOOK_URL="https://your-n8n-instance.com/webhook/opo-feedback"

# REDIS_URL: Redis connection URL (e.g. redis://localhost:6379 or redis://:password@host:6379)
# If unset or OPO_USE_MEMORY_BLACKBOARD=true is set, falls back to MemoryBlackboardAdapter.
# Required in production for Swarm worker and distributed agent memory.
# Docker Redis uses a password — include it in the URL when running npm run dev on the host:
REDIS_URL="redis://:secretredispassword@localhost:6379"
REDIS_PASSWORD="secretredispassword"

# OPO_USE_MEMORY_BLACKBOARD: Force using in-memory blackboard instead of Redis (development only)
OPO_USE_MEMORY_BLACKBOARD="false"

# OPO_DB_PATH: Path to the SQLite database.
# In Docker production, this should point to a persistent volume (e.g., /app/data/opo.db)
OPO_DB_PATH="./data/opo.db"

# OPO_VAULT_SECRET: Encryption key for storing credentials in the SQLite vault.
# REQUIRED in production. Generate a strong random key.
OPO_VAULT_SECRET="MY_RANDOM_VAULT_SECRET_KEY"
