{
  "opo_version": "0.1.0",
  "system_identity": {
    "erp_name": "Multi-System Adapter (SAP & Odoo)",
    "version": "1.0.0",
    "jurisdictions": ["US", "BR", "AR"]
  },
  "discovery": {
    "context_url": "https://openontology.vercel.app/ontology/opo-context.jsonld",
    "registry_url": "https://openontology.vercel.app/ontology/opo-registry.json"
  },
  "endpoints": {
    "opo:Customer": {
      "path": "/customers",
      "methods": ["GET"],
      "schema": "https://openontology.vercel.app/ontology/schemas/Customer.json"
    },
    "opo:Supplier": {
      "path": "/suppliers",
      "methods": ["GET"],
      "schema": "https://openontology.vercel.app/ontology/schemas/Supplier.json"
    },
    "opo:Invoice": {
      "path": "/invoices",
      "methods": ["GET", "POST"],
      "schema": "https://openontology.vercel.app/ontology/schemas/Invoice.json"
    },
    "opo:Product": {
      "path": "/products",
      "methods": ["GET"],
      "schema": "https://openontology.vercel.app/ontology/schemas/Product.json"
    },
    "opo:PriceList": {
      "path": "/pricelists",
      "methods": ["GET"],
      "schema": "https://openontology.vercel.app/ontology/schemas/PriceList.json"
    }
  }
}

