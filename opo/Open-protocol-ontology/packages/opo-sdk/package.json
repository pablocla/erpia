{
  "name": "opo-sdk",
  "version": "0.3.1",
  "description": "The official SDK for the Open Protocol Ontology (OPO)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "opo": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --watch"
  },
  "keywords": [
    "opo",
    "ontology",
    "erp",
    "ai",
    "agents",
    "mcp",
    "semantic",
    "layer"
  ],
  "author": "Pablo Clavero",
  "license": "MIT",
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "opo-sdk": "^0.1.0",
    "prompts": "^2.4.2"
  }
}