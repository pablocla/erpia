// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id               Int       @id @default(autoincrement())
  nombre           String
  razonSocial      String
  cuit             String    @unique
  direccion        String?
  telefono         String?
  email            String?
  certificadoCRT   String?   // Base64 encoded
  certificadoKEY   String?   // Base64 encoded
  puntoVenta       Int       @default(1)
  entorno          String    @default("homologacion") // "homologacion" o "produccion"
  /// Rubro de la empresa: define plan de cuentas base y módulos sugeridos
  /// "comercio" | "industria" | "servicios" | "gastronomia" | "salud" | "hoteleria" | "agro" | "construccion" | "transporte" | "educacion" | "otro"
  rubro            String    @default("comercio")
  /// "AR" | "CL" | "MX" — país fiscal principal
  paisFiscal       String    @default("AR")
  /// Condición IVA de la empresa: "Responsable Inscripto" | "Monotributista" | "Exento"
  condicionIva     String    @default("Responsable Inscripto")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  
  facturas          Factura[]
  usuarios          Usuario[]
  cajas             Caja[]
  puntosVentaConfig PuntoVentaConfig[]
  cuentasBancarias  CuentaBancaria[]
  activosFijos      ActivoFijo[]
  profesionales     Profesional[]
  planesMembresia   PlanMembresia[]
  salones           Salon[]
  modulosConfig     ConfiguracionModulo[]
  cuentasContables  CuentaContable[]
  configAsientos    ConfigAsientoCuenta[]
  numeradores       Numerador[]
  parametrosFiscales ParametroFiscal[]
  periodosFiscales   PeriodoFiscal[]
  // Multi-tenant relations (Sprint 15)
  clientes          Cliente[]
  proveedores       Proveedor[]
  productos         Producto[]
  categorias        Categoria[]
  compras           Compra[]
  asientosContables AsientoContable[]
  notasCredito      NotaCredito[]
  remitos           Remito[]
  tickets           Ticket[]
  depositos         Deposito[]
  transportistas    Transportista[]
  vehiculos         Vehiculo[]
  choferes          Chofer[]
  hojasRuta         HojaRuta[]
  dispositivosIoT   DispositivoIoT[]
  listasMateriales  ListaMateriales[]
  ordenesProduccion OrdenProduccion[]
  listasPicking     ListaPicking[]
  ordenesCompra     OrdenCompra[]
  pedidosVenta      PedidoVenta[]
  presupuestos      Presupuesto[]
  envios            Envio[]
  tiposEnvase       TipoEnvase[]
  movimientosEnvase MovimientoEnvase[]
  // IA module (Sprint AI)
  alertasIA         AlertaIA[]
  reportesIA        ReporteIA[]
  mensajesWhatsApp  MensajePendienteWhatsApp[]
  chatIAHistorial   ChatIAHistorial[]

  @@map("empresas")
}

model Cliente {
  id           Int       @id @default(autoincrement())
  /// Razón social o nombre completo
  nombre       String
  /// Nombre fantasía (opcional, para búsquedas y comprobantes)
  nombreFantasia String?
  /// "persona_fisica" | "persona_juridica"
  tipoPersona  String    @default("persona_juridica")
  cuit         String?
  dni          String?
  /// Número de Ingresos Brutos (puede ser CUIT o convenio multilateral)
  nroIIBB      String?
  /// "local" | "convenio_multilateral" | "exento" | "no_inscripto"
  situacionIIBB String?
  direccion    String?
  /// Piso / depto / oficina
  direccionComplemento String?
  codigoPostal String?
  telefono     String?
  telefonoAlternativo String?
  email        String?
  emailFacturacion    String?
  /// Sitio web
  web          String?
  /// Código interno del cliente (autoasignado o manual)
  codigo       String?
  condicionIva String    @default("Consumidor Final") // "Responsable Inscripto", "Monotributista", "Exento", etc.
  /// Fecha de alta como cliente
  fechaAlta    DateTime  @default(now())
  /// Fecha de nacimiento / constitución
  fechaNacimiento DateTime?
  /// Observaciones libres
  observaciones String?  @db.Text
  /// Si es agente de retención de IVA (RG 2854)
  esAgenteRetencionIVA Boolean @default(false)
  /// Si es agente de retención de Ganancias (RG 830)
  esAgenteRetencionGanancias Boolean @default(false)
  /// Si es agente de percepción de IVA (RG 2408)
  esAgentePercepcionIVA Boolean @default(false)
  /// Si es agente de percepción de IIBB
  esAgentePercepcionIIBB Boolean @default(false)
  /// Número de certificado de exclusión de retención (si aplica)
  nroCertificadoExclusion String?
  /// Vigencia del certificado de exclusión
  vigenciaCertificadoExclusion DateTime?
  /// Límite de crédito en pesos (0 = sin límite)
  limiteCredito Decimal  @default(0) @db.Decimal(15,2)
  /// Saldo de cuenta corriente (se actualiza vía triggers/service)
  saldoCuentaCorriente Decimal @default(0) @db.Decimal(15,2)
  /// Descuento general que se aplica automáticamente
  descuentoPct  Decimal  @default(0) @db.Decimal(5,2)
  /// Código de cuenta contable asignada (ej: "1.3.1.001" Deudores por Ventas - Cliente X)
  cuentaContableCodigo String?
  /// Días de gracia extra sobre condición de pago para este cliente
  diasGraciaExtra Int  @default(0)
  /// "pesos" | "dolares" | "euros"
  monedaHabitual  String @default("pesos")
  /// Si el cliente está activo para operar
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  createdBy    Int?
  updatedBy    Int?
  empresaId    Int
  empresa      Empresa   @relation(fields: [empresaId], references: [id])
  
  condicionPagoId  Int?
  condicionPago    CondicionPago?   @relation(fields: [condicionPagoId], references: [id])
  vendedorId       Int?
  vendedor         Vendedor?        @relation(fields: [vendedorId], references: [id])
  listaPrecioId    Int?
  listaPrecio      ListaPrecio?     @relation(fields: [listaPrecioId], references: [id])
  /// Forma de pago habitual del cliente
  formaPagoId      Int?
  formaPago        FormaPago?       @relation(fields: [formaPagoId], references: [id])
  provinciaId      Int?
  provincia        Provincia?       @relation(fields: [provinciaId], references: [id])
  paisId           Int?
  pais             Pais?            @relation(fields: [paisId], references: [id])
  localidadId      Int?
  localidad        Localidad?       @relation(fields: [localidadId], references: [id])
  zonaGeograficaId Int?
  zonaGeografica   ZonaGeografica?  @relation(fields: [zonaGeograficaId], references: [id])
  idiomaId         Int?
  idioma           Idioma?          @relation(fields: [idiomaId], references: [id])
  tipoClienteId    Int?
  tipoCliente      TipoCliente?     @relation(fields: [tipoClienteId], references: [id])
  estadoClienteId  Int?
  estadoCliente    EstadoCliente?   @relation(fields: [estadoClienteId], references: [id])
  rubroId          Int?
  rubro            Rubro?           @relation(fields: [rubroId], references: [id])
  canalVentaId     Int?
  canalVenta       CanalVenta?      @relation(fields: [canalVentaId], references: [id])
  segmentoClienteId Int?
  segmentoCliente  SegmentoCliente? @relation(fields: [segmentoClienteId], references: [id])
  tipoEmpresaId    Int?
  tipoEmpresa      TipoEmpresa?     @relation(fields: [tipoEmpresaId], references: [id])
  estadoCivilId    Int?
  estadoCivil      EstadoCivil?     @relation(fields: [estadoCivilId], references: [id])
  profesionId      Int?
  profesion        Profesion?       @relation(fields: [profesionId], references: [id])

  facturas         Factura[]
  notasCredito     NotaCredito[]
  remitos          Remito[]
  cuentasBancarias CuentaBancaria[]
  cheques          Cheque[]
  presupuestos     Presupuesto[]
  cuentasCobrar    CuentaCobrar[]
  recibos          Recibo[]
  padronRegimenes  PadronRegimenCliente[]
  turnos           Turno[]
  pacientes        Paciente[]
  membresias       Membresia[]
  pedidosVenta     PedidoVenta[]
  paradasRuta      ParadaRuta[]
  movimientosEnvase MovimientoEnvase[]

  @@index([cuit])
  @@index([empresaId, activo])
  @@index([empresaId, nombre])
  @@map("clientes")
}

model Proveedor {
  id           Int       @id @default(autoincrement())
  nombre       String
  cuit         String
  direccion    String?
  telefono     String?
  email        String?
  condicionIva String    @default("Responsable Inscripto")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  createdBy    Int?
  updatedBy    Int?
  empresaId    Int
  empresa      Empresa   @relation(fields: [empresaId], references: [id])
  
  condicionPagoId  Int?
  condicionPago    CondicionPago?   @relation(fields: [condicionPagoId], references: [id])
  provinciaId      Int?
  provincia        Provincia?       @relation(fields: [provinciaId], references: [id])
  paisId           Int?
  pais             Pais?            @relation(fields: [paisId], references: [id])
  localidadId      Int?
  localidad        Localidad?       @relation(fields: [localidadId], references: [id])
  rubroId          Int?
  rubro            Rubro?           @relation(fields: [rubroId], references: [id])

  compras          Compra[]
  retenciones      RetencionSICORE[]
  cuentasBancarias CuentaBancaria[]
  cheques          Cheque[]
  ordenesCompra    OrdenCompra[]
  cuentasPagar     CuentaPagar[]
  ordenesPago      OrdenPago[]
  @@map("proveedores")
}

model Factura {
  id              Int       @id @default(autoincrement())
  tipo            String    // "A", "B", "C"
  tipoCbte        Int       // Código AFIP: 1=Factura A, 6=Factura B, 11=Factura C
  numero          Int
  puntoVenta      Int
  cae             String?
  fechaCAE        DateTime?
  vencimientoCAE  DateTime?
  qrBase64        String?   @db.Text
  subtotal        Float
  iva             Float
  total           Float
  observaciones   String?   @db.Text
estado             String    @default("pendiente") // "pendiente", "emitida", "anulada"
  totalPercepciones  Float     @default(0)
  totalRetenciones   Float     @default(0)
  /// RG 5616/2024: moneda de origen ("PES" = ARS, "DOL" = USD, "060" = EUR)
  monedaOrigen       String    @default("PES")
  /// RG 5616/2024: tipo de cambio vendedor BNA al momento de emisión
  tipoCambio         Float     @default(1)
  /// RG 5824/2026: CUIT/CUIL del consumidor final si total > umbral $10M
  cuitReceptor       String?
  /// "CAE" | "CAEA" — modalidad de autorización
  modalidadAuth      String    @default("CAE")
  /// CAEA code (if modalidadAuth = "CAEA")
  caea               String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  createdBy          Int?
  updatedBy          Int?
  
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])
  clienteId       Int
  cliente         Cliente   @relation(fields: [clienteId], references: [id])
  
  lineas          LineaFactura[]
  asientos        AsientoContable[]
  notasCredito    NotaCredito[]
  remitos         Remito[]
  cuentasCobrar   CuentaCobrar[]
  condicionPagoId Int?
  condicionPago   CondicionPago?   @relation(fields: [condicionPagoId], references: [id])
  vendedorId      Int?
  vendedor        Vendedor?        @relation(fields: [vendedorId], references: [id])
  serieId         Int?
  serie           Serie?           @relation(fields: [serieId], references: [id])

  @@map("facturas")
}

model LineaFactura {
  id              Int       @id @default(autoincrement())
  descripcion     String
  cantidad        Float
  precioUnitario  Float
  porcentajeIva   Float     // 21, 10.5, 27, 0
  subtotal        Float
  iva             Float
  total           Float
  descuento       Float     @default(0)

  facturaId       Int
  factura         Factura   @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  productoId      Int?
  producto        Producto? @relation(fields: [productoId], references: [id])
  loteId          Int?
  lote            Lote?     @relation(fields: [loteId], references: [id])
  @@map("lineas_factura")
}

model Compra {
  id              Int       @id @default(autoincrement())
  tipo            String    // "A", "B", "C"
  numero          String
  puntoVenta      String
  fecha           DateTime
  subtotal        Float
  iva             Float
  total           Float
  observaciones      String?   @db.Text
  totalPercepciones  Float     @default(0)
  totalRetenciones   Float     @default(0)
  /// RG 5616/2024: moneda de origen
  monedaOrigen       String    @default("PES")
  /// RG 5616/2024: tipo de cambio vendedor BNA
  tipoCambio         Float     @default(1)
  /// CAE del proveedor (validado vía WSCDC)
  caeProveedor       String?
  /// Fecha vto. CAE del proveedor
  caeProveedorVto    DateTime?
  /// "valido" | "invalido" | "no_verificado"
  estadoVerificacionCAE String? @default("no_verificado")
  /// OrdenCompra de referencia para 3-way matching
  ordenCompraId      Int?
  ordenCompra        OrdenCompra? @relation(fields: [ordenCompraId], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  createdBy          Int?
  updatedBy          Int?
  empresaId          Int
  empresa            Empresa   @relation(fields: [empresaId], references: [id])

  proveedorId     Int
  proveedor       Proveedor      @relation(fields: [proveedorId], references: [id])
  condicionPagoId Int?
  condicionPago   CondicionPago? @relation(fields: [condicionPagoId], references: [id])

  lineas          LineaCompra[]
  asientos        AsientoContable[]
  retenciones     RetencionSICORE[]
  cuentasPagar    CuentaPagar[]

  @@map("compras")
}

model LineaCompra {
  id              Int       @id @default(autoincrement())
  descripcion     String
  cantidad        Float
  precioUnitario  Float
  porcentajeIva   Float
  subtotal        Float
  iva             Float
  total           Float
  descuento       Float     @default(0)

  compraId        Int
  compra          Compra    @relation(fields: [compraId], references: [id], onDelete: Cascade)
  productoId      Int?
  producto        Producto? @relation(fields: [productoId], references: [id])
  loteId          Int?
  lote            Lote?     @relation(fields: [loteId], references: [id])
  @@map("lineas_compra")
}

model AsientoContable {
  id          Int       @id @default(autoincrement())
  fecha       DateTime  @default(now())
  numero      Int
  descripcion String
  tipo        String    // "venta", "compra", "manual"
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  createdBy   Int?
  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])
  
  facturaId   Int?
  factura     Factura?  @relation(fields: [facturaId], references: [id])
  compraId    Int?
  compra      Compra?   @relation(fields: [compraId], references: [id])
  
  movimientos MovimientoContable[]
  
  @@map("asientos_contables")
}

model MovimientoContable {
  id          Int       @id @default(autoincrement())
  cuenta      String    // "1.1 Caja", "4.1 Ventas", etc.
  debe        Float     @default(0)
  haber       Float     @default(0)
  
  asientoId     Int
  asiento       AsientoContable @relation(fields: [asientoId], references: [id], onDelete: Cascade)
  centroCostoId Int?
  centroCosto   CentroCosto?    @relation(fields: [centroCostoId], references: [id])

  @@map("movimientos_contables")
}

model Usuario {
  id        Int       @id @default(autoincrement())
  nombre    String
  email     String    @unique
  password  String    // Hashed with bcrypt
  rol       String    @default("vendedor") // "administrador", "contador", "vendedor"
  activo    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  
  empresaId Int
  empresa   Empresa   @relation(fields: [empresaId], references: [id])
  vendedor  Vendedor?
  logs      LogActividad[]

  @@map("usuarios")
}

model ConfiguracionImpresora {
  id          Int       @id @default(autoincrement())
  nombre      String
  tipo        String    // "fiscal", "ticket", "a4"
  marca       String    // "hasar", "epson"
  modelo      String
  conexion    String    // "usb", "red"
  ip          String?
  puerto      Int?
  activa      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("configuracion_impresoras")
}

model Categoria {
  id          Int        @id @default(autoincrement())
  nombre      String
  descripcion String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  empresaId   Int
  empresa     Empresa    @relation(fields: [empresaId], references: [id])

  productos   Producto[]

  @@map("categorias")
}

model Producto {
  id              Int       @id @default(autoincrement())
  codigo          String    @unique
  nombre          String
  descripcion     String?
  precioVenta     Float
  precioCompra    Float     @default(0)
  porcentajeIva   Float     @default(21)  // 0, 10.5, 21, 27
  stock           Float     @default(0)
  stockMinimo     Float     @default(0)
  unidad          String    @default("unidad") // "unidad", "kg", "litro", etc.
  /// Marca platos/recetas para hospitalidad
  esPlato         Boolean   @default(false)
  /// Marca insumos para recetas/produccion
  esInsumo        Boolean   @default(false)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  createdBy       Int?
  updatedBy       Int?
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  categoriaId     Int?
  categoria       Categoria? @relation(fields: [categoriaId], references: [id])

  movimientosStock  MovimientoStock[]
  lineasFactura     LineaFactura[]
  lineasCompra      LineaCompra[]
  lineasPicking     LineaPicking[]
  componentesBOM    ComponenteBOM[]
  bomProducidos     ListaMateriales[]
  ordenesProduccion OrdenProduccion[]
  stocksDeposito      StockDeposito[]
  lineasTransferencia LineaTransferencia[]
  itemsListaPrecio    ItemListaPrecio[]
  lotes               Lote[]
  lineasPresupuesto   LineaPresupuesto[]
  lineasOrdenCompra   LineaOrdenCompra[]
  lineasComanda       LineaComanda[]
  lineasPedidoVenta   LineaPedidoVenta[]
  lineasRemito        LineaRemito[]
  unidadMedidaId      Int?
  unidadMedida        UnidadMedida?    @relation(fields: [unidadMedidaId], references: [id])

  @@map("productos")
}

model MovimientoStock {
  id          Int       @id @default(autoincrement())
  tipo        String    // "entrada", "salida", "ajuste", "transferencia_salida", "transferencia_entrada"
  cantidad    Float
  motivo      String?   // "venta", "compra", "ajuste manual", etc.
  createdAt   DateTime  @default(now())

  productoId  Int
  producto    Producto  @relation(fields: [productoId], references: [id])
  depositoId  Int?
  deposito    Deposito? @relation(fields: [depositoId], references: [id])

  @@map("movimientos_stock")
}

model Caja {
  id            Int       @id @default(autoincrement())
  fecha         DateTime  @default(now())
  estado        String    @default("abierta") // "abierta", "cerrada"
  saldoInicial  Float     @default(0)
  saldoFinal    Float?
  observaciones String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Arqueo (reconciliation)
  arqueoEfectivo      Float?    // Cash declared by cashier
  arqueoTarjeta       Float?    // Card vouchers total
  arqueoTransferencia Float?    // Transfer receipts total
  arqueoCheque        Float?    // Cheques total
  arqueoQR            Float?    // QR receipts total
  diferencia          Float?    // Declared total - system total
  diferenciaJustif    String?   @db.Text // Explanation for variance

  // Tracking
  abiertoPor    Int?
  cerradoPor    Int?
  turno         String?   // "mañana", "tarde", "noche"

  empresaId     Int
  empresa       Empresa        @relation(fields: [empresaId], references: [id])
  movimientos   MovimientoCaja[]

  @@map("cajas")
}

model MovimientoCaja {
  id          Int       @id @default(autoincrement())
  tipo        String    // "ingreso", "egreso"
  concepto    String
  monto       Float
  medioPago   String    @default("efectivo") // "efectivo", "tarjeta_debito", "tarjeta_credito", "transferencia", "cheque"
  referencia  String?   // número de factura, etc.
  createdAt   DateTime  @default(now())

  cajaId      Int
  caja        Caja      @relation(fields: [cajaId], references: [id])

  @@map("movimientos_caja")
}

model NotaCredito {
  id              Int       @id @default(autoincrement())
  tipo            String    // "A", "B", "C"
  tipoCbte        Int       // AFIP: 3=NC-A, 8=NC-B, 13=NC-C
  numero          Int
  puntoVenta      Int
  cae             String?
  fechaCAE        DateTime?
  vencimientoCAE  DateTime?
  motivo          String
  subtotal        Float
  iva             Float
  total           Float
  estado          String    @default("pendiente")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  createdBy       Int?
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  facturaId       Int
  factura         Factura   @relation(fields: [facturaId], references: [id])
  clienteId       Int
  cliente         Cliente   @relation(fields: [clienteId], references: [id])

  @@map("notas_credito")
}

model Remito {
  id          Int       @id @default(autoincrement())
  numero      Int
  fecha       DateTime  @default(now())
  estado      String    @default("pendiente") // "pendiente", "entregado", "anulado"
  observaciones String? @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdBy   Int?
  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])

  clienteId   Int
  cliente     Cliente   @relation(fields: [clienteId], references: [id])
  facturaId   Int?
  factura     Factura?  @relation(fields: [facturaId], references: [id])
  pedidoVentaId Int?
  pedidoVenta   PedidoVenta? @relation(fields: [pedidoVentaId], references: [id])

  incotermId  Int?
  incoterm    Incoterm?    @relation(fields: [incotermId], references: [id])

  lineas      LineaRemito[]
  envios      Envio[]
  pickings    ListaPicking[]
  cot         COT?

  @@map("remitos")
}

model LineaRemito {
  id              Int     @id @default(autoincrement())
  descripcion     String
  cantidad        Float
  unidad          String  @default("unidad")

  productoId      Int?
  producto        Producto? @relation(fields: [productoId], references: [id])

  remitoId        Int
  remito          Remito  @relation(fields: [remitoId], references: [id], onDelete: Cascade)

  @@map("lineas_remito")
}

// ─── SICORE — Retenciones impositivas ───────────────────────────────────────

model RetencionSICORE {
  id             Int        @id @default(autoincrement())
  /// "IVA" | "ganancias"
  tipo           String
  /// "217" | "219" | "305" | "767" | "779"
  codigoSicore   String
  base           Float
  alicuota       Float
  monto          Float
  fechaRetencion DateTime   @default(now())
  fechaPago      DateTime?
  /// "pendiente" | "acreditada" | "compensada"
  estado         String     @default("pendiente")
  /// Número de constancia emitida
  constanciaNum  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  compraId       Int?
  compra         Compra?     @relation(fields: [compraId], references: [id])
  proveedorId    Int?
  proveedor      Proveedor?  @relation(fields: [proveedorId], references: [id])
  ordenPagoId    Int?
  ordenPago      OrdenPago?  @relation(fields: [ordenPagoId], references: [id])

  @@map("retenciones_sicore")
}

// ─── IIBB — Liquidación mensual por jurisdicción ─────────────────────────────

model PeriodoIIBB {
  id             Int      @id @default(autoincrement())
  mes            Int      // 1–12
  anio           Int
  /// "PBA" | "CABA" | "SF" | "CBA" | "MZA"
  jurisdiccion   String
  /// "ARBA" | "ARCIBA" | "DGR_SF" | "DGR_CBA"
  organismo      String
  baseImponible  Float    @default(0)
  alicuota       Float
  montoDevengado Float    @default(0)
  /// Percepciones recibidas en el período (descuento sobre el saldo a pagar)
  montoPercibido Float    @default(0)
  saldo          Float    @default(0)
  /// "abierto" | "cerrado" | "presentado"
  estado         String   @default("abierto")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([mes, anio, jurisdiccion])
  @@map("periodos_iibb")
}

// ─── TAX ENGINE — DB-backed rate store ───────────────────────────────────────
// Mirrors the hardcoded AR_RATE_CATALOG in lib/tes/adapters/ar-adapter.ts.
// When a row exists here it overrides the hardcoded value, allowing accountants
// to update tax rates without a code redeployment.

model TaxConcepto {
  id           Int       @id @default(autoincrement())
  /// ISO 3166-1 alpha-2: "AR", "UY", "BR", "ES", "MX"
  pais         String
  /// Key matching AR_RATE_CATALOG: "IVA_21", "IIBB_PBA_COMERCIO", "PERC_IVA_RI"
  codigo       String
  nombre       String
  /// TaxTipo: "iva" | "iibb" | "retencion_iva" | "retencion_ganancias" | "percepcion_iva" | "percepcion_iibb"
  tipo         String
  /// TaxOrganismo: "AFIP" | "ARBA" | "ARCIBA" | "DGR_SF" | "DGR_CBA"
  organismo    String
  /// "federal" | "PBA" | "CABA" | "SF" | "CBA"
  jurisdiccion String?
  esRetencion  Boolean   @default(false)
  esPercepcion Boolean   @default(false)
  activo       Boolean   @default(true)
  /// Código numérico AFIP: 3=IVA 0%, 4=IVA 10.5%, 5=IVA 21%, 6=IVA 27%
  /// Para tributos en WSFE: 1=Nacional, 2=Provincial, 3=Municipal, 4=Interno, 99=Otro
  codigoAfip   String?
  /// Código SICORE para retenciones: "217", "219", "305", "767", "779"
  codigoSicore String?
  /// Código IIBB organismo provincial (ARBA=902, ARCIBA=901, etc.)
  codigoOrganismo String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tasas        TaxTasa[]

  @@unique([pais, codigo])
  @@map("tax_conceptos")
}

/// Rate history with validity periods. The active rate is the row where
/// vigenciaDesde <= TODAY and (vigenciaHasta IS NULL OR vigenciaHasta >= TODAY).
model TaxTasa {
  id            Int          @id @default(autoincrement())
  /// Percentage: 21 for 21%, 10.5 for 10.5%
  alicuota      Float
  /// Minimum transaction amount — tax does not apply below this (SICORE thresholds)
  montoMinimo   Float?
  vigenciaDesde DateTime
  /// null = rate is currently in force
  vigenciaHasta DateTime?
  createdAt     DateTime     @default(now())

  conceptoId    Int
  concepto      TaxConcepto  @relation(fields: [conceptoId], references: [id], onDelete: Cascade)

  @@map("tax_tasas")
}

// ─── LOGÍSTICA ───────────────────────────────────────────────────────────────

model Transportista {
  id        Int      @id @default(autoincrement())
  nombre    String
  cuit      String?
  telefono  String?
  email     String?
  activo    Boolean  @default(true)
