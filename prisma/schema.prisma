// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id               Int       @id @default(autoincrement())
  nombre           String
  razonSocial      String
  cuit             String    @unique
  direccion        String?
  telefono         String?
  email            String?
  certificadoCRT   String?   // Base64 encoded
  certificadoKEY   String?   // Base64 encoded
  puntoVenta       Int       @default(1)
  entorno          String    @default("homologacion") // "homologacion" o "produccion"
  /// Alias para compatibilidad con código que usa entornoAfip
  entornoAfip      String    @default("homologacion")
  // ── CAEA (RG 5782/2025 — contingencia offline) ──────────────────────────
  /// CAEA vigente para emitir comprobantes offline
  caeaVigente      String?
  /// Período del CAEA (YYYYMM)
  caeaPeriodo      String?
  /// Quincena: 1 = días 1-15, 2 = días 16 al último
  caeaQuincena     Int?
  /// Fecha inicio de vigencia del CAEA
  caeaVigDesde     DateTime?
  /// Fecha fin de vigencia del CAEA
  caeaVigHasta     DateTime?
  /// Tope para informar comprobantes emitidos con CAEA
  caeaTopeInformar DateTime?
  /// Rubro de la empresa: define plan de cuentas base y módulos sugeridos
  /// "comercio" | "industria" | "servicios" | "gastronomia" | "salud" | "hoteleria" | "agro" | "construccion" | "transporte" | "educacion" | "otro"
  rubro            String    @default("comercio")
  /// FK al maestro Rubro (coexiste con rubro string para migración gradual)
  rubroId          Int?
  rubroRef         Rubro?    @relation("EmpresaRubro", fields: [rubroId], references: [id])
  /// "AR" | "CL" | "MX" — país fiscal principal
  paisFiscal       String    @default("AR")
  /// Condición IVA de la empresa: "Responsable Inscripto" | "Monotributista" | "Exento"
  condicionIva     String    @default("Responsable Inscripto")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  
  facturas          Factura[]
  usuarios          Usuario[]
  cajas             Caja[]
  puntosVentaConfig PuntoVentaConfig[]
  cuentasBancarias  CuentaBancaria[]
  activosFijos      ActivoFijo[]
  profesionales     Profesional[]
  planesMembresia   PlanMembresia[]
  salones           Salon[]
  modulosConfig     ConfiguracionModulo[]
  cuentasContables  CuentaContable[]
  configAsientos    ConfigAsientoCuenta[]
  numeradores       Numerador[]
  parametrosFiscales ParametroFiscal[]
  periodosFiscales   PeriodoFiscal[]
  // Multi-tenant relations (Sprint 15)
  clientes          Cliente[]
  proveedores       Proveedor[]
  productos         Producto[]
  categorias        Categoria[]
  compras           Compra[]
  asientosContables AsientoContable[]
  notasCredito      NotaCredito[]
  remitos           Remito[]
  tickets           Ticket[]
  depositos         Deposito[]
  transportistas    Transportista[]
  vehiculos         Vehiculo[]
  choferes          Chofer[]
  hojasRuta         HojaRuta[]
  dispositivosIoT   DispositivoIoT[]
  listasMateriales  ListaMateriales[]
  ordenesProduccion OrdenProduccion[]
  listasPicking     ListaPicking[]
  ordenesCompra     OrdenCompra[]
  pedidosVenta      PedidoVenta[]
  presupuestos      Presupuesto[]
  envios            Envio[]
  tiposEnvase       TipoEnvase[]
  movimientosEnvase MovimientoEnvase[]
  // IA module (Sprint AI)
  alertasIA         AlertaIA[]
  reportesIA        ReporteIA[]
  mensajesWhatsApp  MensajePendienteWhatsApp[]
  chatIAHistorial   ChatIAHistorial[]
  agenteLogs        AgenteLog[]
  // Maestros contables y financieros (Sprint Maestros)
  rubrosContables   RubroContable[]
  tiposAsiento      TipoAsiento[]
  plantillasAsiento PlantillaAsiento[]
  tiposComprobante  TipoComprobanteMaestro[]
  tiposRetencion    TipoRetencion[]
  regimenesRetencion RegimenRetencion[]
  tiposMovBancario  TipoMovimientoBancario[]
  conceptosCobroPago ConceptoCobroPago[]
  planesCuotas      PlanCuotas[]
  entidadesFinancieras EntidadFinanciera[]
  sucursales        Sucursal[]
  cobradores        Cobrador[]
  tiposOpComercial  TipoOperacionComercial[]
  cajasTipo         CajaTipo[]
  camposPersonalizados CampoPersonalizado[]
  tablasAuxiliares  TablaAuxiliar[]
  configuracionesCampo ConfiguracionCampo[]
  // Sprint Impuestos — tax engineering models
  periodosIIBB      PeriodoIIBB[]
  retencionesSICORE RetencionSICORE[]
  configFiscal      ConfigFiscalEmpresa?
  tributosFactura   TributoFactura[]
  tributosCompra    TributoCompra[]
  padronRegimenesProveedor PadronRegimenProveedor[]
  regimenesPercepcion      RegimenPercepcion[]
  retencionesRecibo        RetencionRecibo[]
  declaracionesJuradas     DeclaracionJurada[]
  // Sprint mejoras — schema enrichment
  marcas            Marca[]
  notasDebito       NotaDebito[]
  listasPrecio      ListaPrecio[]
  // Sprint Rubro Config — dynamic feature activation
  featuresEmpresa      FeatureEmpresa[]
  instanciasWorkflow   WorkflowInstancia[]
  // Sprint Competitivo — SAP/Tango/Colppy gap closers
  documentosAdjuntos   DocumentoAdjunto[]
  facturasRecurrentes  FacturaRecurrente[]
  mercadoPagoConfig    MercadoPagoConfig?
  transaccionesMp      MercadoPagoTransaccion[]
  reglasAlerta         ReglaAlerta[]
  empleados            Empleado[]
  generacionesCITI     GeneracionCITI[]
  planesMantenimiento  PlanMantenimiento[]
  ordenesTrabajo       OrdenTrabajo[]
  tareasPendientes     TareaPendiente[]
  centrosCosto         CentroCosto[]
  configuracionesImpresora ConfiguracionImpresora[]
  afipLogs             AfipWebserviceLog[]
  transferenciasDeposito TransferenciaDeposito[]
  jornadasFiscales       JornadaFiscal[]         @relation("JornadaFiscalEmpresa")

  @@map("empresas")
}

model Cliente {
  id           Int       @id @default(autoincrement())
  /// Razón social o nombre completo
  nombre       String
  /// Nombre fantasía (opcional, para búsquedas y comprobantes)
  nombreFantasia String?
  /// "persona_fisica" | "persona_juridica"
  tipoPersona  String    @default("persona_juridica")
  cuit         String?
  dni          String?
  /// Número de Ingresos Brutos (puede ser CUIT o convenio multilateral)
  nroIIBB      String?
  /// "local" | "convenio_multilateral" | "exento" | "no_inscripto"
  situacionIIBB String?
  direccion    String?
  /// Piso / depto / oficina
  direccionComplemento String?
  codigoPostal String?
  telefono     String?
  telefonoAlternativo String?
  email        String?
  emailFacturacion    String?
  /// Sitio web
  web          String?
  /// Código interno del cliente (autoasignado o manual)
  codigo       String?
  condicionIva String    @default("Consumidor Final") // "Responsable Inscripto", "Monotributista", "Exento", etc.
  /// Fecha de alta como cliente
  fechaAlta    DateTime  @default(now())
  /// Fecha de nacimiento / constitución
  fechaNacimiento DateTime?
  /// Observaciones libres
  observaciones String?  @db.Text
  /// Si es agente de retención de IVA (RG 2854)
  esAgenteRetencionIVA Boolean @default(false)
  /// Si es agente de retención de Ganancias (RG 830)
  esAgenteRetencionGanancias Boolean @default(false)
  /// Si es agente de percepción de IVA (RG 2408)
  esAgentePercepcionIVA Boolean @default(false)
  /// Si es agente de percepción de IIBB
  esAgentePercepcionIIBB Boolean @default(false)
  /// Número de certificado de exclusión de retención (si aplica)
  nroCertificadoExclusion String?
  /// Vigencia del certificado de exclusión
  vigenciaCertificadoExclusion DateTime?
  /// Límite de crédito en pesos (0 = sin límite)
  limiteCredito Decimal  @default(0) @db.Decimal(15,2)
  /// Saldo de cuenta corriente (se actualiza vía triggers/service)
  saldoCuentaCorriente Decimal @default(0) @db.Decimal(15,2)
  /// Descuento general que se aplica automáticamente
  descuentoPct  Decimal  @default(0) @db.Decimal(5,2)
  /// Código de cuenta contable asignada (ej: "1.3.1.001" Deudores por Ventas - Cliente X)
  cuentaContableCodigo String?
  /// Días de gracia extra sobre condición de pago para este cliente
  diasGraciaExtra Int  @default(0)
  /// "pesos" | "dolares" | "euros"
  monedaHabitual  String @default("pesos")
  /// Si el cliente está activo para operar
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  createdBy    Int?
  updatedBy    Int?
  empresaId    Int
  empresa      Empresa   @relation(fields: [empresaId], references: [id])
  
  condicionPagoId  Int?
  condicionPago    CondicionPago?   @relation(fields: [condicionPagoId], references: [id])
  vendedorId       Int?
  vendedor         Vendedor?        @relation(fields: [vendedorId], references: [id])
  listaPrecioId    Int?
  listaPrecio      ListaPrecio?     @relation(fields: [listaPrecioId], references: [id])
  /// Forma de pago habitual del cliente
  formaPagoId      Int?
  formaPago        FormaPago?       @relation(fields: [formaPagoId], references: [id])
  provinciaId      Int?
  provincia        Provincia?       @relation(fields: [provinciaId], references: [id])
  paisId           Int?
  pais             Pais?            @relation(fields: [paisId], references: [id])
  localidadId      Int?
  localidad        Localidad?       @relation(fields: [localidadId], references: [id])
  zonaGeograficaId Int?
  zonaGeografica   ZonaGeografica?  @relation(fields: [zonaGeograficaId], references: [id])
  idiomaId         Int?
  idioma           Idioma?          @relation(fields: [idiomaId], references: [id])
  tipoClienteId    Int?
  tipoCliente      TipoCliente?     @relation(fields: [tipoClienteId], references: [id])
  estadoClienteId  Int?
  estadoCliente    EstadoCliente?   @relation(fields: [estadoClienteId], references: [id])
  rubroId          Int?
  rubro            Rubro?           @relation(fields: [rubroId], references: [id])
  canalVentaId     Int?
  canalVenta       CanalVenta?      @relation(fields: [canalVentaId], references: [id])
  segmentoClienteId Int?
  segmentoCliente  SegmentoCliente? @relation(fields: [segmentoClienteId], references: [id])
  tipoEmpresaId    Int?
  tipoEmpresa      TipoEmpresa?     @relation(fields: [tipoEmpresaId], references: [id])
  estadoCivilId    Int?
  estadoCivil      EstadoCivil?     @relation(fields: [estadoCivilId], references: [id])
  profesionId      Int?
  profesion        Profesion?       @relation(fields: [profesionId], references: [id])

  facturas         Factura[]
  notasCredito     NotaCredito[]
  notasDebito      NotaDebito[]
  remitos          Remito[]
  cuentasBancarias CuentaBancaria[]
  cheques          Cheque[]
  presupuestos     Presupuesto[]
  cuentasCobrar    CuentaCobrar[]
  recibos          Recibo[]
  padronRegimenes  PadronRegimenCliente[]
  turnos           Turno[]
  pacientes        Paciente[]
  membresias       Membresia[]
  pedidosVenta     PedidoVenta[]
  paradasRuta      ParadaRuta[]
  movimientosEnvase MovimientoEnvase[]

  @@index([cuit])
  @@index([empresaId, activo])
  @@index([empresaId, nombre])
  @@map("clientes")
}

model Proveedor {
  id           Int       @id @default(autoincrement())
  nombre       String
  cuit         String
  direccion    String?
  telefono     String?
  email        String?
  condicionIva String    @default("Responsable Inscripto")
  /// Código interno del proveedor
  codigo          String?
  nombreFantasia  String?
  /// "persona_fisica" | "persona_juridica"
  tipoPersona     String    @default("persona_juridica")
  telefonoAlternativo String?
  emailFacturacion    String?
  web                 String?
  activo              Boolean   @default(true)
  /// Límite de crédito otorgado al proveedor
  limiteCredito       Decimal   @default(0)  @db.Decimal(18, 2)
  /// Saldo deudor en cuenta corriente
  saldoCuentaCorriente Decimal  @default(0)  @db.Decimal(18, 2)
  /// Código de cuenta contable vinculada
  cuentaContableCodigo String?

  // ─── Campos fiscales / impositivos ────────────────────────────────
  /// Número de inscripción en Ingresos Brutos
  nroIIBB              String?
  /// "local" | "convenio_multilateral" | "exento" | "no_inscripto"
  situacionIIBB        String    @default("local")
  /// El proveedor es agente de retención IVA (nos retiene a nosotros)
  esAgenteRetencionIVA       Boolean @default(false)
  /// El proveedor es agente de retención de Ganancias
  esAgenteRetencionGanancias Boolean @default(false)
  /// El proveedor es agente de percepción de IVA (nos percibe en facturas de compra)
  esAgentePercepcionIVA      Boolean @default(false)
  /// El proveedor es agente de percepción de IIBB
  esAgentePercepcionIIBB     Boolean @default(false)
  /// Número de certificado de exclusión de retención/percepción
  nroCertificadoExclusion        String?
  /// Vigencia del certificado de exclusión
  vigenciaCertificadoExclusion   DateTime?
  /// Alícuota especial de retención IIBB para este proveedor (si difiere del régimen)
  alicuotaEspecialIIBB           Decimal?  @db.Decimal(5, 2)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  createdBy    Int?
  updatedBy    Int?
  empresaId    Int
  empresa      Empresa   @relation(fields: [empresaId], references: [id])
  
  condicionPagoId  Int?
  condicionPago    CondicionPago?   @relation(fields: [condicionPagoId], references: [id])
  provinciaId      Int?
  provincia        Provincia?       @relation(fields: [provinciaId], references: [id])
  paisId           Int?
  pais             Pais?            @relation(fields: [paisId], references: [id])
  localidadId      Int?
  localidad        Localidad?       @relation(fields: [localidadId], references: [id])
  rubroId          Int?
  rubro            Rubro?           @relation(fields: [rubroId], references: [id])
  /// Actividad económica principal (determina alícuota IIBB)
  actividadEconomicaId Int?
  actividadEconomica   ActividadEconomica? @relation(fields: [actividadEconomicaId], references: [id])

  compras          Compra[]
  retenciones      RetencionSICORE[]
  cuentasBancarias CuentaBancaria[]
  cheques          Cheque[]
  ordenesCompra    OrdenCompra[]
  cuentasPagar     CuentaPagar[]
  ordenesPago      OrdenPago[]
  padronRegimenes  PadronRegimenProveedor[]
  notasDebito      NotaDebito[]
  @@map("proveedores")
}

model Factura {
  id              Int       @id @default(autoincrement())
  tipo            String    // "A", "B", "C"
  tipoCbte        Int       // Código AFIP: 1=Factura A, 6=Factura B, 11=Factura C
  numero          Int
  puntoVenta      Int
  cae             String?
  fechaCAE        DateTime?
  vencimientoCAE  DateTime?
  qrBase64        String?   @db.Text
  subtotal        Decimal   @db.Decimal(15,2)
  iva             Decimal   @db.Decimal(15,2)
  total           Decimal   @db.Decimal(15,2)
  observaciones   String?   @db.Text
  estado          String    @default("pendiente") // "pendiente", "emitida", "anulada"
  totalPercepciones  Decimal   @default(0) @db.Decimal(15,2)
  totalRetenciones   Decimal   @default(0) @db.Decimal(15,2)
  /// RG 5616/2024: moneda de origen ("PES" = ARS, "DOL" = USD, "060" = EUR)
  monedaOrigen       String    @default("PES")
  /// RG 5616/2024: tipo de cambio vendedor BNA al momento de emisión
  tipoCambio         Float     @default(1)
  /// RG 5824/2026: CUIT/CUIL del consumidor final si total > umbral $10M
  cuitReceptor       String?
  /// "CAE" | "CAEA" — modalidad de autorización
  modalidadAuth      String    @default("CAE")
  /// CAEA code (if modalidadAuth = "CAEA")
  caea               String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  createdBy          Int?
  updatedBy          Int?

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])
  clienteId       Int
  cliente         Cliente   @relation(fields: [clienteId], references: [id])

  lineas          LineaFactura[]
  asientos        AsientoContable[]
  notasCredito    NotaCredito[]
  remitos         Remito[]
  cuentasCobrar   CuentaCobrar[]
  condicionPagoId Int?
  condicionPago   CondicionPago?   @relation(fields: [condicionPagoId], references: [id])
  vendedorId      Int?
  vendedor        Vendedor?        @relation(fields: [vendedorId], references: [id])
  serieId         Int?
  serie           Serie?           @relation(fields: [serieId], references: [id])
  /// Tipo de comprobante parametrizado (catálogo AFIP). Complementa tipoCbte Int.
  tipoComprobanteId Int?
  tipoComprobante   TipoComprobanteMaestro? @relation(fields: [tipoComprobanteId], references: [id])
  /// AFIP Concepto: 1=Productos, 2=Servicios, 3=Productos y Servicios
  concepto           Int       @default(1)
  /// Fecha inicio servicio (obligatorio si concepto=2 o 3)
  fechaServicioDesde DateTime?
  /// Fecha fin servicio (obligatorio si concepto=2 o 3)
  fechaServicioHasta DateTime?
  /// Fecha vencimiento de pago (obligatorio si concepto=2 o 3)
  fechaVtoPago       DateTime?
  /// WSFE ImpTotConc: neto no gravado (conceptos no gravados)
  netoNoGravado      Decimal   @default(0) @db.Decimal(15,2)
  /// WSFE ImpOpEx: operaciones exentas
  netoExento         Decimal   @default(0) @db.Decimal(15,2)
  /// Impuestos internos (tabaco, alcohol, electrónicos)
  impInternosTotal   Decimal   @default(0) @db.Decimal(15,2)
  /// Snapshot de condición IVA del receptor al momento de emisión
  condicionIvaReceptor String?
  comandas        Comanda[]
  /// Tributos detallados (percepciones IIBB, IVA, imp. internos) — mapea a WSFE Tributos[]
  tributos        TributoFactura[]
  notasDebito     NotaDebito[]

  /// FIX A-001: índices críticos para listados y reportes de facturación
  @@index([empresaId, estado, createdAt])
  @@index([empresaId, clienteId])
  @@index([empresaId, tipoCbte, puntoVenta])
  @@map("facturas")
}

model LineaFactura {
  id              Int       @id @default(autoincrement())
  descripcion     String
  cantidad        Float
  precioUnitario  Decimal   @db.Decimal(15,2)
  porcentajeIva   Float     // 21, 10.5, 27, 0
  /// Código AFIP IVA: 3=0%, 4=10.5%, 5=21%, 6=27%, 8=5%, 9=2.5%
  codigoAfipIva    String?
  subtotal        Decimal   @db.Decimal(15,2)
  iva             Decimal   @db.Decimal(15,2)
  total           Decimal   @db.Decimal(15,2)
  descuento       Float     @default(0)

  facturaId       Int
  factura         Factura   @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  productoId      Int?
  producto        Producto? @relation(fields: [productoId], references: [id])
  loteId          Int?
  lote            Lote?     @relation(fields: [loteId], references: [id])
  /// FIX A-002: índice en FK para evitar seq scan en include
  @@index([facturaId])
  @@index([productoId])
  @@map("lineas_factura")
}

model Compra {
  id              Int       @id @default(autoincrement())
  tipo            String    // "A", "B", "C"
  numero          String
  puntoVenta      String
  fecha           DateTime
  subtotal        Decimal   @db.Decimal(15,2)
  iva             Decimal   @db.Decimal(15,2)
  total           Decimal   @db.Decimal(15,2)
  observaciones      String?   @db.Text
  totalPercepciones  Decimal   @default(0) @db.Decimal(15,2)
  totalRetenciones   Decimal   @default(0) @db.Decimal(15,2)
  /// RG 5616/2024: moneda de origen
  monedaOrigen       String    @default("PES")
  /// RG 5616/2024: tipo de cambio vendedor BNA
  tipoCambio         Float     @default(1)
  /// CAE del proveedor (validado vía WSCDC)
  caeProveedor       String?
  /// Fecha vto. CAE del proveedor
  caeProveedorVto    DateTime?
  /// "valido" | "invalido" | "no_verificado"
  estadoVerificacionCAE String? @default("no_verificado")
  /// OrdenCompra de referencia para 3-way matching
  ordenCompraId      Int?
  ordenCompra        OrdenCompra? @relation(fields: [ordenCompraId], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  createdBy          Int?
  updatedBy          Int?
  empresaId          Int
  empresa            Empresa   @relation(fields: [empresaId], references: [id])

  proveedorId     Int
  proveedor       Proveedor      @relation(fields: [proveedorId], references: [id])
  condicionPagoId Int?
  condicionPago   CondicionPago? @relation(fields: [condicionPagoId], references: [id])

  lineas          LineaCompra[]
  asientos        AsientoContable[]
  retenciones     RetencionSICORE[]
  cuentasPagar    CuentaPagar[]
  /// Tributos detallados de la compra (percepciones sufridas IIBB, IVA, etc.)
  tributos        TributoCompra[]
  /// AFIP Concepto: 1=Productos, 2=Servicios, 3=Productos y Servicios
  concepto        Int       @default(1)
  /// Neto no gravado (conceptos no gravados)
  netoNoGravado   Decimal   @default(0) @db.Decimal(15,2)
  /// Operaciones exentas
  netoExento      Decimal   @default(0) @db.Decimal(15,2)

  /// FIX A-001: índices de filtrado frecuente en compras
  @@index([empresaId, createdAt])
  @@index([empresaId, proveedorId])
  @@map("compras")
}

model LineaCompra {
  id              Int       @id @default(autoincrement())
  descripcion     String
  cantidad        Float
  precioUnitario  Decimal   @db.Decimal(15,2)
  porcentajeIva   Float
  /// Código AFIP IVA: 3=0%, 4=10.5%, 5=21%, 6=27%, 8=5%, 9=2.5%
  codigoAfipIva    String?
  subtotal        Decimal   @db.Decimal(15,2)
  iva             Decimal   @db.Decimal(15,2)
  total           Decimal   @db.Decimal(15,2)
  descuento       Float     @default(0)

  compraId        Int
  compra          Compra    @relation(fields: [compraId], references: [id], onDelete: Cascade)
  productoId      Int?
  producto        Producto? @relation(fields: [productoId], references: [id])
  loteId          Int?
  lote            Lote?     @relation(fields: [loteId], references: [id])
  /// FIX A-002: índice en FK para evitar seq scan en include
  @@index([compraId])
  @@index([productoId])
  @@map("lineas_compra")
}

model AsientoContable {
  id          Int       @id @default(autoincrement())
  fecha       DateTime  @default(now())
  numero      Int
  descripcion String
  /// DEPRECATED: usar tipoAsientoId. Mantenido por backward compatibility.
  tipo        String    // "venta", "compra", "manual"
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  createdBy   Int?
  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])
  
  facturaId   Int?
  factura     Factura?  @relation(fields: [facturaId], references: [id])
  compraId    Int?
  compra      Compra?   @relation(fields: [compraId], references: [id])
  
  /// Tipo de asiento parametrizado (reemplaza campo 'tipo' string)
  tipoAsientoId Int?
  tipoAsiento   TipoAsiento? @relation(fields: [tipoAsientoId], references: [id])
  /// Plantilla origen si fue generado desde template
  plantillaOrigenId Int?
  
  movimientos MovimientoContable[]
  
  @@map("asientos_contables")
}

model MovimientoContable {
  id          Int       @id @default(autoincrement())
  cuenta      String    // "1.1 Caja", "4.1 Ventas", etc.
  debe        Decimal   @default(0) @db.Decimal(15,2)
  haber       Decimal   @default(0) @db.Decimal(15,2)
  
  asientoId     Int
  asiento       AsientoContable @relation(fields: [asientoId], references: [id], onDelete: Cascade)
  centroCostoId Int?
  centroCosto   CentroCosto?    @relation(fields: [centroCostoId], references: [id])

  @@map("movimientos_contables")
}

model Usuario {
  id        Int       @id @default(autoincrement())
  nombre    String
  email     String    @unique
  password  String    // Hashed with bcrypt
  rol       String    @default("vendedor") // "administrador", "contador", "vendedor"
  activo    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  
  empresaId Int
  empresa   Empresa   @relation(fields: [empresaId], references: [id])
  vendedor  Vendedor?
  logs      LogActividad[]
  tareas    TareaPendiente[]

  @@map("usuarios")
}

model ConfiguracionImpresora {
  id          Int       @id @default(autoincrement())
  nombre      String
  tipo        String    // "fiscal", "ticket", "a4"
  marca       String    // "hasar", "epson"
  modelo      String
  conexion    String    // "usb", "red"
  ip          String?
  puerto      Int?
  activa      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  /// FIX C-002: Multi-tenant isolation — cada empresa tiene sus propias impresoras
  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, nombre])
  @@index([empresaId])
  @@map("configuracion_impresoras")
}

model Categoria {
  id          Int        @id @default(autoincrement())
  nombre      String
  descripcion String?
  /// Jerarquía: alimentación > lácteos > quesos
  parentId    Int?
  parent      Categoria?  @relation("CategoriaJerarquia", fields: [parentId], references: [id])
  hijos       Categoria[] @relation("CategoriaJerarquia")
  /// Orden de visualización
  orden       Int        @default(0)
  activo      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  empresaId   Int
  empresa     Empresa    @relation(fields: [empresaId], references: [id])

  productos   Producto[]

  @@map("categorias")
}

/// Maestro de marcas para productos
model Marca {
  id          Int       @id @default(autoincrement())
  codigo      String
  nombre      String
  descripcion String?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])

  productos   Producto[]

  @@unique([empresaId, codigo])
  @@map("marcas")
}

model Producto {
  id              Int       @id @default(autoincrement())
  /// FIX C-004: unicidad por empresa, no global (@@unique abajo)
  codigo          String
  nombre          String
  descripcion     String?
  precioVenta     Decimal   @db.Decimal(15,2)
  precioCompra    Decimal   @default(0) @db.Decimal(15,2)
  porcentajeIva   Float     @default(21)  // 0, 10.5, 21, 27
  stock           Float     @default(0)
  stockMinimo     Float     @default(0)
  unidad          String    @default("unidad") // "unidad", "kg", "litro", etc.
  /// Código EAN-13 / UPC para lectura de scanner POS
  codigoBarras    String?
  /// Peso bruto en kg (0 = no aplica)
  peso            Float     @default(0)
  /// Unidad de peso: "kg", "g", "tn"
  pesoUnidad      String    @default("kg")
  /// Volumen en m³ (0 = no aplica) — para logística
  volumen         Float     @default(0)
  /// Dimensiones: largo en cm
  largo           Float     @default(0)
  /// Dimensiones: ancho en cm
  ancho           Float     @default(0)
  /// Dimensiones: alto en cm
  alto            Float     @default(0)
  /// "bien" | "servicio" | "bien_de_uso" — determina AFIP concepto (1/2/3)
  tipoProducto    String    @default("bien")
  /// Stock máximo permitido (0 = sin límite) — alerta sobre-stock
  stockMaximo     Float     @default(0)
  /// Ubicación en depósito: pasillo/estante/bin (ej: "A-03-12")
  ubicacionDeposito String?
  /// URL imagen principal del producto
  imagenUrl       String?
  /// "nacional" | "importado"
  origen          String    @default("nacional")
  /// NCM (Nomenclador Común Mercosur) — requerido exportación
  codigoNCM       String?
  /// Margen de ganancia deseado (%)
  margenGanancia  Float     @default(0)
  /// Marca platos/recetas para hospitalidad
  esPlato         Boolean   @default(false)
  /// Marca insumos para recetas/produccion
  esInsumo        Boolean   @default(false)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  createdBy       Int?
  updatedBy       Int?
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  categoriaId     Int?
  categoria       Categoria? @relation(fields: [categoriaId], references: [id])
  marcaId         Int?
  marca           Marca?     @relation(fields: [marcaId], references: [id])
  /// Depósito por defecto para recepción de mercadería
  depositoDefaultId Int?
  depositoDefault   Deposito? @relation("ProductoDepositoDefault", fields: [depositoDefaultId], references: [id])

  movimientosStock  MovimientoStock[]
  lineasFactura     LineaFactura[]
  lineasCompra      LineaCompra[]
  lineasPicking     LineaPicking[]
  componentesBOM    ComponenteBOM[]
  bomProducidos     ListaMateriales[]
  ordenesProduccion OrdenProduccion[]
  stocksDeposito      StockDeposito[]
  lineasTransferencia LineaTransferencia[]
  itemsListaPrecio    ItemListaPrecio[]
  lotes               Lote[]
  lineasPresupuesto   LineaPresupuesto[]
  lineasOrdenCompra   LineaOrdenCompra[]
  lineasComanda       LineaComanda[]
  lineasPedidoVenta   LineaPedidoVenta[]
  lineasRemito        LineaRemito[]
  lineasNotaCredito   LineaNotaCredito[]
  lineasNotaDebito    LineaNotaDebito[]
  unidadMedidaId      Int?
  unidadMedida        UnidadMedida?    @relation(fields: [unidadMedidaId], references: [id])
  /// Clasificación fiscal: determina IVA, exención, código NCM
  clasificacionFiscalId Int?
  clasificacionFiscal   ClasificacionFiscal? @relation(fields: [clasificacionFiscalId], references: [id])

  /// FIX C-004: código único por empresa
  @@unique([empresaId, codigo])
  /// FIX A-001: índices de filtrado frecuente
  @@index([empresaId, activo])
  @@index([empresaId, categoriaId])
  @@index([codigoBarras])
  @@map("productos")
}

model MovimientoStock {
  id          Int       @id @default(autoincrement())
  tipo        String    // "entrada", "salida", "ajuste", "transferencia_salida", "transferencia_entrada"
  cantidad    Float
  motivo      String?   // "venta", "compra", "ajuste manual", etc.
  createdAt   DateTime  @default(now())

  productoId  Int
  producto    Producto  @relation(fields: [productoId], references: [id])
  depositoId  Int?
  deposito    Deposito? @relation(fields: [depositoId], references: [id])
  /// FIX A-012: multi-tenant — necesario para reportes de movimientos por empresa
  empresaId   Int?

  /// FIX A-001/A-012: índices para reportes de stock
  @@index([empresaId, productoId, createdAt])
  @@index([productoId, createdAt])
  @@map("movimientos_stock")
}

model Caja {
  id            Int       @id @default(autoincrement())
  fecha         DateTime  @default(now())
  estado        String    @default("abierta") // "abierta", "cerrada"
  saldoInicial  Decimal   @default(0) @db.Decimal(15,2)
  saldoFinal    Decimal?  @db.Decimal(15,2)
  observaciones String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Arqueo (reconciliation)
  arqueoEfectivo      Decimal?  @db.Decimal(15,2)  // Cash declared by cashier
  arqueoTarjeta       Decimal?  @db.Decimal(15,2)  // Card vouchers total
  arqueoTransferencia Decimal?  @db.Decimal(15,2)  // Transfer receipts total
  arqueoCheque        Decimal?  @db.Decimal(15,2)  // Cheques total
  arqueoQR            Decimal?  @db.Decimal(15,2)  // QR receipts total
  diferencia          Decimal?  @db.Decimal(15,2)  // Declared total - system total
  diferenciaJustif    String?   @db.Text // Explanation for variance

  // Tracking
  abiertoPor    Int?
  cerradoPor    Int?
  turno         String?   // "mañana", "tarde", "noche"

  empresaId     Int
  empresa       Empresa        @relation(fields: [empresaId], references: [id])
  movimientos   MovimientoCaja[]

  /// Sucursal donde está la caja
  sucursalId    Int?
  sucursal      Sucursal?      @relation("CajaSucursal", fields: [sucursalId], references: [id])
  /// Tipo de caja (principal, chica, fondo fijo)
  cajaTipoId    Int?
  cajaTipo      CajaTipo?      @relation("CajaCajaTipo", fields: [cajaTipoId], references: [id])

  @@map("cajas")
}

model MovimientoCaja {
  id          Int       @id @default(autoincrement())
  tipo        String    // "ingreso", "egreso"
  concepto    String
  monto       Decimal   @db.Decimal(15,2)
  medioPago   String    @default("efectivo") // "efectivo", "tarjeta_debito", "tarjeta_credito", "transferencia", "cheque"
  referencia  String?   // número de factura, etc.
  createdAt   DateTime  @default(now())

  cajaId      Int
  caja        Caja      @relation(fields: [cajaId], references: [id])

  @@map("movimientos_caja")
}

// ─── JORNADA FISCAL ─────────────────────────────────────────────────────────
// Una jornada fiscal = un día de operación comercial.
// Puede haber múltiples Cajas (turnos) dentro de una misma jornada.
// El Cierre Z cierra la jornada de forma irreversible.

model JornadaFiscal {
  id               Int       @id @default(autoincrement())
  fecha            DateTime  // Fecha del día fiscal (solo fecha, sin hora)
  numeroZ          Int       // Contador Z secuencial por empresa (1, 2, 3...)
  estado           String    @default("abierta") // "abierta" | "cerrada_z"

  // Totales consolidados (poblados en Cierre Z)
  totalVentas        Decimal   @default(0) @db.Decimal(15,2)
  totalNeto          Decimal   @default(0) @db.Decimal(15,2)  // Base imponible total
  totalIva21         Decimal   @default(0) @db.Decimal(15,2)
  totalIva105        Decimal   @default(0) @db.Decimal(15,2)
  totalIva27         Decimal   @default(0) @db.Decimal(15,2)
  totalIvaExento     Decimal   @default(0) @db.Decimal(15,2)
  totalIvaNoGravado  Decimal   @default(0) @db.Decimal(15,2)
  totalEfectivo      Decimal   @default(0) @db.Decimal(15,2)
  totalTarjeta       Decimal   @default(0) @db.Decimal(15,2)
  totalTransferencia Decimal   @default(0) @db.Decimal(15,2)
  totalQR            Decimal   @default(0) @db.Decimal(15,2)
  totalCheque        Decimal   @default(0) @db.Decimal(15,2)
  totalCtaCte        Decimal   @default(0) @db.Decimal(15,2)
  cantidadFacturas Int       @default(0)
  cantidadTickets  Int       @default(0)
  primerNumFactura Int?      // Número de la primera factura del día
  ultimoNumFactura Int?      // Número de la última factura del día

  fechaCierre      DateTime?
  cerradoPor       Int?
  observaciones    String?   @db.Text

  empresaId        Int
  empresa          Empresa        @relation("JornadaFiscalEmpresa", fields: [empresaId], references: [id])
  cierresX         CierreX[]

  @@unique([empresaId, fecha])
  @@index([empresaId, fecha])
  @@map("jornadas_fiscales")
}

// ─── CIERRE X ───────────────────────────────────────────────────────────────
// Informe parcial de la jornada, no resetea contadores.
// Se puede generar múltiples veces en el día.

model CierreX {
  id               Int       @id @default(autoincrement())
  timestamp        DateTime  @default(now())
  numeroCierreX    Int       @default(1)  // Secuencial dentro de la jornada

  // Snapshot de totales al momento del cierre X
  totalVentas        Decimal   @default(0) @db.Decimal(15,2)
  totalNeto          Decimal   @default(0) @db.Decimal(15,2)
  totalIva21         Decimal   @default(0) @db.Decimal(15,2)
  totalIva105        Decimal   @default(0) @db.Decimal(15,2)
  totalIva27         Decimal   @default(0) @db.Decimal(15,2)
  totalIvaExento     Decimal   @default(0) @db.Decimal(15,2)
  totalEfectivo      Decimal   @default(0) @db.Decimal(15,2)
  totalTarjeta       Decimal   @default(0) @db.Decimal(15,2)
  totalTransferencia Decimal   @default(0) @db.Decimal(15,2)
  totalQR            Decimal   @default(0) @db.Decimal(15,2)
  totalCheque        Decimal   @default(0) @db.Decimal(15,2)
  cantidadFacturas Int       @default(0)

  // Datos analíticos (JSON)
  topProductos     Json?     // [{ nombre, cantidad, total }]
  ventasPorHora    Json?     // [{ hora: 9, total: 5000 }]
  ventasPorTipo    Json?     // [{ tipo: "B", cantidad: 12, total: 48000 }]

  jornadaId        Int?
  jornada          JornadaFiscal? @relation(fields: [jornadaId], references: [id])
  cajaId           Int
  empresaId        Int
  generadoPor      Int?

  @@index([empresaId, timestamp])
  @@map("cierres_x")
}


model NotaCredito {
  id              Int       @id @default(autoincrement())
  tipo            String    // "A", "B", "C"
  tipoCbte        Int       // AFIP: 3=NC-A, 8=NC-B, 13=NC-C
  numero          Int
  puntoVenta      Int
  cae             String?
  fechaCAE        DateTime?
  vencimientoCAE  DateTime?
  motivo          String
  subtotal        Decimal   @db.Decimal(15,2)
  iva             Decimal   @db.Decimal(15,2)
  total           Decimal   @db.Decimal(15,2)
  estado          String    @default("pendiente")
  /// Percepciones revertidas (de la factura original)
  totalPercepciones  Decimal @default(0) @db.Decimal(15,2)
  /// Retenciones revertidas
  totalRetenciones   Decimal @default(0) @db.Decimal(15,2)
  /// RG 5616: moneda de origen
  monedaOrigen       String  @default("PES")
  /// RG 5616: tipo de cambio
  tipoCambio         Float   @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  createdBy       Int?
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  facturaId       Int
  factura         Factura   @relation(fields: [facturaId], references: [id])
  clienteId       Int
  cliente         Cliente   @relation(fields: [clienteId], references: [id])

  lineas          LineaNotaCredito[]

  @@map("notas_credito")
}

/// Líneas de detalle de nota de crédito — trackea qué productos se devolvieron/acreditaron
model LineaNotaCredito {
  id              Int       @id @default(autoincrement())
  descripcion     String
  cantidad        Float
  precioUnitario  Decimal   @db.Decimal(15,2)
  porcentajeIva   Float
  codigoAfipIva   String?
  subtotal        Decimal   @db.Decimal(15,2)
  iva             Decimal   @db.Decimal(15,2)
  total           Decimal   @db.Decimal(15,2)
  descuento       Float     @default(0)

  notaCreditoId   Int
  notaCredito     NotaCredito @relation(fields: [notaCreditoId], references: [id], onDelete: Cascade)
  productoId      Int?
  producto        Producto?   @relation(fields: [productoId], references: [id])

  @@map("lineas_nota_credito")
}

/// Nota de Débito A/B/C — AFIP tipoCbte 2=ND-A, 7=ND-B, 12=ND-C
model NotaDebito {
  id              Int       @id @default(autoincrement())
  tipo            String    // "A", "B", "C"
  tipoCbte        Int       // AFIP: 2=ND-A, 7=ND-B, 12=ND-C
  numero          Int
  puntoVenta      Int
  cae             String?
  fechaCAE        DateTime?
  vencimientoCAE  DateTime?
  /// Motivo: intereses, ajuste precio, recargo, etc.
  motivo          String
  subtotal        Decimal   @db.Decimal(15,2)
  iva             Decimal   @db.Decimal(15,2)
  total           Decimal   @db.Decimal(15,2)
  totalPercepciones Decimal @default(0) @db.Decimal(15,2)
  totalRetenciones  Decimal @default(0) @db.Decimal(15,2)
  monedaOrigen    String    @default("PES")
  tipoCambio      Float     @default(1)
  estado          String    @default("pendiente")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  createdBy       Int?
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  /// Puede estar asociada a factura original o a proveedor
  facturaId       Int?
  factura         Factura?  @relation(fields: [facturaId], references: [id])
  clienteId       Int?
  cliente         Cliente?  @relation(fields: [clienteId], references: [id])
  proveedorId     Int?
  proveedor       Proveedor? @relation(fields: [proveedorId], references: [id])

  lineas          LineaNotaDebito[]

  @@map("notas_debito")
}

model LineaNotaDebito {
  id              Int       @id @default(autoincrement())
  descripcion     String
  cantidad        Float
  precioUnitario  Decimal   @db.Decimal(15,2)
  porcentajeIva   Float
  codigoAfipIva   String?
  subtotal        Decimal   @db.Decimal(15,2)
  iva             Decimal   @db.Decimal(15,2)
  total           Decimal   @db.Decimal(15,2)

  notaDebitoId    Int
  notaDebito      NotaDebito @relation(fields: [notaDebitoId], references: [id], onDelete: Cascade)
  productoId      Int?
  producto        Producto?  @relation(fields: [productoId], references: [id])

  @@map("lineas_nota_debito")
}

model Remito {
  id          Int       @id @default(autoincrement())
  numero      Int
  /// "venta" | "transferencia" | "entrada" | "devolucion"
  tipo        String    @default("venta")
  fecha       DateTime  @default(now())
  estado      String    @default("pendiente") // "pendiente", "entregado", "anulado"
  observaciones String? @db.Text
  /// Firma del receptor (base64 data URL)
  firmaReceptor String? @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdBy   Int?
  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])

  clienteId   Int
  cliente     Cliente   @relation(fields: [clienteId], references: [id])
  facturaId   Int?
  factura     Factura?  @relation(fields: [facturaId], references: [id])
  pedidoVentaId Int?
  pedidoVenta   PedidoVenta? @relation(fields: [pedidoVentaId], references: [id])

  incotermId  Int?
  incoterm    Incoterm?    @relation(fields: [incotermId], references: [id])

  lineas      LineaRemito[]
  envios      Envio[]
  pickings    ListaPicking[]
  cot         COT?

  @@map("remitos")
