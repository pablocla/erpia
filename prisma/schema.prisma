}

model Vehiculo {
  id              Int      @id @default(autoincrement())
  patente         String   @unique
  tipo            String   @default("utilitario")
  marca           String?
  modelo          String?
  capacidadKg     Float?
  capacidadBultos Int?
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  empresaId       Int
  empresa         Empresa  @relation(fields: [empresaId], references: [id])

  hojasRuta       HojaRuta[]

  @@map("vehiculos")
}

model Chofer {
  id         Int      @id @default(autoincrement())
  nombre     String
  documento  String?
  licencia   String?
  telefono   String?
  email      String?
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  empresaId  Int
  empresa    Empresa  @relation(fields: [empresaId], references: [id])

  hojasRuta  HojaRuta[]

  @@map("choferes")
}

model HojaRuta {
  id            Int       @id @default(autoincrement())
  numero        String    @unique
  fecha         DateTime  @db.Date
  /// "planificada" | "en_ruta" | "finalizada" | "cancelada"
  estado        String    @default("planificada")
  kmEstimado    Float?
  observaciones String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  empresaId     Int
  empresa       Empresa   @relation(fields: [empresaId], references: [id])

  vehiculoId    Int?
  vehiculo      Vehiculo? @relation(fields: [vehiculoId], references: [id])
  choferId      Int?
  chofer        Chofer?   @relation(fields: [choferId], references: [id])

  paradas       ParadaRuta[]

  @@map("hojas_ruta")
}

model ParadaRuta {
  id               Int       @id @default(autoincrement())
  orden            Int
  /// "pendiente" | "en_curso" | "entregado" | "no_entregado"
  estado           String    @default("pendiente")
  direccion        String
  localidad        String?
  ventanaDesde     DateTime?
  ventanaHasta     DateTime?
  horaArribo       DateTime?
  horaSalida       DateTime?
  lat              Float?
  lng              Float?
  contactoNombre   String?
  contactoTelefono String?
  motivoNoEntrega  String?
  observaciones    String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  hojaRutaId       Int
  hojaRuta         HojaRuta  @relation(fields: [hojaRutaId], references: [id], onDelete: Cascade)
  envioId          Int?      @unique
  envio            Envio?    @relation(fields: [envioId], references: [id])
  clienteId        Int?
  cliente          Cliente?  @relation(fields: [clienteId], references: [id])

  evidencia        EvidenciaEntrega?

  @@map("paradas_ruta")
}

model EvidenciaEntrega {
  id                Int       @id @default(autoincrement())
  receptorNombre    String?
  receptorDocumento String?
  firmaBase64       String?   @db.Text
  fotoUrl           String?
  geoLat            Float?
  geoLng            Float?
  fecha             DateTime  @default(now())

  paradaId          Int       @unique
  parada            ParadaRuta @relation(fields: [paradaId], references: [id], onDelete: Cascade)

  @@map("evidencias_entrega")
}

// ─── INDUSTRIA — Producción y BOM ────────────────────────────────────────────

model ListaMateriales {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  nombre      String
  descripcion String?
  /// "produccion" | "receta"
  tipo        String    @default("produccion")
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])

  productoId  Int?
  producto    Producto? @relation(fields: [productoId], references: [id])

  componentes ComponenteBOM[]
  ordenes     OrdenProduccion[]

  @@map("listas_materiales")
}

model ComponenteBOM {
  id          Int             @id @default(autoincrement())
  cantidad    Float
  unidad      String          @default("unidad")
  descripcion String?

  bomId       Int
  bom         ListaMateriales @relation(fields: [bomId], references: [id], onDelete: Cascade)
  productoId  Int?
  producto    Producto?       @relation(fields: [productoId], references: [id])

  @@map("componentes_bom")
}

model OrdenProduccion {
  id            Int             @id @default(autoincrement())
  numero        String          @unique
  cantidad      Float
  cantidadProd  Float           @default(0)
  /// "borrador" | "en_proceso" | "pausada" | "terminada" | "anulada"
  estado        String          @default("borrador")
  fechaInicio   DateTime?
  fechaFinPlan  DateTime?
  fechaFinReal  DateTime?
  observaciones String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  empresaId     Int
  empresa       Empresa         @relation(fields: [empresaId], references: [id])

  bomId         Int?
  bom           ListaMateriales? @relation(fields: [bomId], references: [id])
  productoId    Int?
  producto      Producto?       @relation(fields: [productoId], references: [id])

  @@map("ordenes_produccion")
}

// ─── PICKING ─────────────────────────────────────────────────────────────────

model ListaPicking {
  id          Int          @id @default(autoincrement())
  numero      String       @unique
  /// "pendiente" | "en_proceso" | "completada" | "anulada"
  estado      String       @default("pendiente")
  /// "baja" | "normal" | "alta" | "urgente"
  prioridad   String       @default("normal")
  zonaAlmacen String?
  operario    String?
  notas       String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  empresaId   Int
  empresa     Empresa      @relation(fields: [empresaId], references: [id])

  remitoId    Int?
  remito      Remito?      @relation(fields: [remitoId], references: [id])
  pedidoVentaId Int?
  pedidoVenta   PedidoVenta? @relation(fields: [pedidoVentaId], references: [id])

  lineas      LineaPicking[]

  @@map("listas_picking")
}

model LineaPicking {
  id              Int          @id @default(autoincrement())
  descripcion     String
  cantidadPedida  Float
  cantidadPicada  Float        @default(0)
  ubicacion       String?
  /// "pendiente" | "parcial" | "completo"
  estado          String       @default("pendiente")

  listaId         Int
  lista           ListaPicking @relation(fields: [listaId], references: [id], onDelete: Cascade)
  productoId      Int?
  producto        Producto?    @relation(fields: [productoId], references: [id])

  @@map("lineas_picking")
}

// ─── IoT — Dispositivos, Lecturas y Alertas ───────────────────────────────────

model DispositivoIoT {
  id             Int          @id @default(autoincrement())
  codigo         String       @unique
  nombre         String
  /// "temperatura" | "humedad" | "presion" | "contador" | "scanner" | "gps" | "energia" | "vibracion" | "flujo" | "peso" | "nivel"
  tipo           String
  ubicacion      String?
  activo         Boolean      @default(true)
  ipAddress      String?
  mac            String?
  firmware       String?
  ultimaConexion DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  empresaId      Int
  empresa        Empresa      @relation(fields: [empresaId], references: [id])

  // ─── CONFIGURACIÓN INDUSTRIAL ────────────────────────────────────────────
  /// Protocolo de comunicación: "mqtt" | "modbus_tcp" | "modbus_rtu" | "opcua" | "http" | "coap" | "lorawan" | "zigbee" | "ble"
  protocolo        String?
  /// Puerto o topic MQTT / Modbus register / OPC-UA node
  endpointConfig   String?
  /// Intervalo de muestreo en segundos (e.g. 5, 30, 60, 300)
  intervaloMuestreo Int?
  /// Unidad de medida principal del dispositivo
  unidadMedida     String?
  /// Rango mínimo de medición del sensor
  rangoMin         Float?
  /// Rango máximo de medición del sensor
  rangoMax         Float?
  /// Umbral inferior para generar alerta warning
  umbralAlertaMin  Float?
  /// Umbral superior para generar alerta warning
  umbralAlertaMax  Float?
  /// Umbral inferior para generar alerta crítica
  umbralCriticoMin Float?
  /// Umbral superior para generar alerta crítica
  umbralCriticoMax Float?
  /// Precisión / resolución del sensor (e.g. ±0.5)
  precision        Float?
  /// Fecha de última calibración
  ultimaCalibracion DateTime?
  /// Fecha de próxima calibración programada
  proximaCalibracion DateTime?
  /// Norma industrial aplicable: "IEC 61131" | "ISA-95" | "ISO 22000" | "HACCP" | "GMP" | "ISO 14644" | "ATEX" | "SIL" | "IEEE 802.15.4"
  normaIndustrial  String?
  /// Clase de protección IP: "IP20" | "IP54" | "IP65" | "IP67" | "IP68"
  claseProteccion  String?
  /// Zona de instalación: "zona_limpia" | "zona_atex" | "intemperie" | "camara_frio" | "linea_produccion" | "almacen" | "sala_maquinas"
  zonaInstalacion  String?
  /// Marca del dispositivo/sensor
  marca            String?
  /// Modelo del dispositivo/sensor
  modelo           String?
  /// Número de serie del equipo
  numeroSerie      String?
  /// Alimentación: "24vdc" | "220vac" | "bateria" | "poe" | "solar" | "4-20ma_loop"
  alimentacion     String?
  /// Tiempo máximo sin lectura antes de generar alerta de desconexión (segundos)
  timeoutDesconexion Int?
  /// Factor de corrección o offset de calibración
  offsetCalibracion Float?
  /// Notas técnicas del dispositivo
  notasTecnicas    String?     @db.Text

  lecturas       LecturaIoT[]
  alertas        AlertaIoT[]

  @@map("dispositivos_iot")
}

model LecturaIoT {
  id            Int            @id @default(autoincrement())
  valor         Float
  /// "°C", "%", "kPa", "unidades", etc.
  unidad        String
  /// "ok" | "alerta" | "error"
  calidad       String         @default("ok")
  timestamp     DateTime       @default(now())

  dispositivoId Int
  dispositivo   DispositivoIoT @relation(fields: [dispositivoId], references: [id])

  @@map("lecturas_iot")
}

model AlertaIoT {
  id            Int            @id @default(autoincrement())
  /// "umbral" | "desconexion" | "error"
  tipo          String
  mensaje       String
  valorLeido    Float?
  umbralMin     Float?
  umbralMax     Float?
  /// "info" | "warning" | "critical"
  nivel         String         @default("info")
  resuelta      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  resolvedAt    DateTime?

  dispositivoId Int
  dispositivo   DispositivoIoT @relation(fields: [dispositivoId], references: [id])

  @@map("alertas_iot")
}

// ─── DEPÓSITOS / MULTI-ALMACÉN ─────────────────────────────────────────────────

model Deposito {
  id           Int      @id @default(autoincrement())
  codigo       String   @unique
  nombre       String
  descripcion  String?
  direccion    String?
  localidad    String?
  provincia    String?
  /// "principal" | "secundario" | "transito" | "consignacion" | "devoluciones" | "cuarentena" | "merma"
  tipo         String   @default("principal")
  /// Responsable del depósito
  responsableId Int?
  /// Sucursal a la que pertenece
  sucursalId   Int?
  sucursal     Sucursal? @relation(fields: [sucursalId], references: [id])
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  empresaId    Int
  empresa      Empresa  @relation(fields: [empresaId], references: [id])

  stocks            StockDeposito[]
  movimientos       MovimientoStock[]
  transferenciasOrigen   TransferenciaDeposito[] @relation("TransferenciaOrigen")
  transferenciasDestino  TransferenciaDeposito[] @relation("TransferenciaDestino")
  lotes             Lote[]
  productosDefault  Producto[] @relation("ProductoDepositoDefault")

  @@map("depositos")
}

/// Stock por producto por depósito
model StockDeposito {
  id         Int      @id @default(autoincrement())
  cantidad   Float    @default(0)
  reservado  Float    @default(0) // Reserved by confirmed pedidos (not yet delivered)
  updatedAt  DateTime @updatedAt

  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])
  depositoId Int
  deposito   Deposito @relation(fields: [depositoId], references: [id])

  @@unique([productoId, depositoId])
  @@map("stock_deposito")
}

/// Movimiento de mercancía entre depósitos
model TransferenciaDeposito {
  id           Int      @id @default(autoincrement())
  numero       String   @unique
  /// "pendiente" | "en_transito" | "aprobada" | "rechazada"
  estado       String   @default("pendiente")
  fecha        DateTime @default(now())
  observaciones String? @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    Int?

  empresaId    Int
  empresa      Empresa  @relation(fields: [empresaId], references: [id])

  origenId     Int
  origen       Deposito @relation("TransferenciaOrigen", fields: [origenId], references: [id])
  destinoId    Int
  destino      Deposito @relation("TransferenciaDestino", fields: [destinoId], references: [id])

  lineas       LineaTransferencia[]

  @@index([empresaId])
  @@map("transferencias_deposito")
}

model LineaTransferencia {
  id             Int                   @id @default(autoincrement())
  cantidad       Float
  descripcion    String?

  transferenciaId Int
  transferencia   TransferenciaDeposito @relation(fields: [transferenciaId], references: [id], onDelete: Cascade)
  productoId     Int?
  producto       Producto?             @relation(fields: [productoId], references: [id])

  @@map("lineas_transferencia")
}

// ─── COT — Código de Operación de Transporte (ARBA) ──────────────────────
// Requerido por ARBA para el transporte de mercancía dentro/hacia Buenos Aires

model COT {
  id               Int      @id @default(autoincrement())
  /// Número de COT devuelto por ARBA (AB + 13 dígitos)
  numeroCOT        String?  @unique
  /// Código de integridad del COT
  codigoIntegridad String?
  estado           String   @default("pendiente") // "pendiente" | "aprobado" | "rechazado" | "anulado"
  /// CUIT emisor (remitente)
  cuitEmisor       String
  /// CUIT receptor
  cuitReceptor     String?
  /// Dirección de entrega
  domicilioEntrega String
  /// Localidad de entrega
  localidadEntrega String
  fechaEmision     DateTime @default(now())
  fechaVencimiento DateTime?
  /// Valor nominal de la mercancía en pesos
  valorMercaderia  Float?
  /// Peso en kg
  pesoTotal        Float?
  /// Cantidad de unidades
  cantidadUnidades Int?
  /// Respuesta XML de ARBA
  respuestaARBA    String?  @db.Text
  /// Error si el COT fue rechazado
  errorMensaje     String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  remitoId         Int?     @unique
  remito           Remito?  @relation(fields: [remitoId], references: [id])

  @@map("cots")
}

// ─── INGENIERÍA FUNCIONAL — Event Bus parametrizable ───────────────────────

/// Configuración de handlers del event bus. Cada fila = un handler registrado.
/// El operador puede activar/desactivar y configurar parámetros sin redeployar.
model ConfiguracionFuncional {
  id          Int      @id @default(autoincrement())
  /// Nombre interno del handler: "stock_por_venta", "asiento_venta", "email_factura"
  handler     String   @unique
  /// Nombre legible para la UI
  nombre      String
  /// Descripción del efecto
  descripcion String
  /// Evento que lo dispara
  evento      String
  /// Módulo al que afecta
  modulo      String
  /// Está activo
  activo      Boolean  @default(true)
  /// JSON: parámetros configurables por el usuario ({depositoId, ...})
  parametros  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs        HandlerLog[]

  @@map("configuracion_funcional")
}

/// Registro de ejecuciones del event bus (audit trail funcional)
model HandlerLog {
  id          Int      @id @default(autoincrement())
  evento      String
  handler     String
  exito       Boolean
  duracionMs  Int?
  payload     String?  @db.Text
  errorMsg    String?  @db.Text
  createdAt   DateTime @default(now())

  configId    Int?
  config      ConfiguracionFuncional? @relation(fields: [configId], references: [id])

  @@map("handler_logs")
}

// ─── SISTEMA DE TICKETS ────────────────────────────────────────────────────────────

model Ticket {
  id          Int      @id @default(autoincrement())
  numero      String   @unique
  titulo      String
  descripcion String   @db.Text
  /// "bug" | "mejora" | "consulta" | "urgente"
  tipo        String   @default("bug")
  /// "abierto" | "en_progreso" | "resuelto" | "cerrado"
  estado      String   @default("abierto")
  /// "baja" | "media" | "alta" | "critica"
  prioridad   String   @default("media")
  /// Módulo afectado (ej: "ventas", "stock", "afip")
  modulo      String?
  /// URL de la página donde se detectó
  urlOrigen   String?
  /// Email del reportante
  reportadoPor String?
  /// Asignado a (email o nombre)
  asignadoA   String?
  /// Stack trace o info técnica adicional
  stackTrace  String?  @db.Text
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  empresaId   Int
  empresa     Empresa  @relation(fields: [empresaId], references: [id])

  comentarios ComentarioTicket[]

  @@map("tickets")
}

model ComentarioTicket {
  id        Int      @id @default(autoincrement())
  texto     String   @db.Text
  autor     String
  createdAt DateTime @default(now())

  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("comentarios_ticket")
}

// ─── MAESTRO DE PUNTOS DE VENTA ────────────────────────────────────────────────
// Cada empresa puede tener varios puntos de venta (sucursales / canales)
// habilitados ante AFIP. El número (1-9999) es el que va en el comprobante.

model PuntoVentaConfig {
  id          Int      @id @default(autoincrement())
  /// Número habilitado ante AFIP (1–9999)
  numero      Int
  nombre      String
  descripcion String?
  /// "electronico" | "manual" | "web" | "factura_credito"
  tipo        String   @default("electronico")
  activo      Boolean  @default(true)
  /// Indica si es el PV por defecto al emitir comprobantes
  esDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  empresaId   Int
  empresa     Empresa  @relation(fields: [empresaId], references: [id])

  series      Serie[]

  @@unique([empresaId, numero])
  @@map("puntos_venta_config")
}

// ─── MAESTRO DE SERIES ───────────────────────────────────────────────────────────
// Una Serie vincula un Punto de Venta con un Tipo de Comprobante AFIP.
// Controla la numeración correlativa e identifica la letra del comprobante.
// El tipo de comprobante AFIP se almacena como tipoCbteAfip según la tabla
// oficial de WSFE (ver lib/afip/tipos-comprobante.ts).

model Serie {
  id                Int              @id @default(autoincrement())
  /// Identificador legible: "FA-001", "FB-001", "NCA-001"
  codigo            String           @unique
  descripcion       String?
  /// Código numérico del tipo de comprobante AFIP (1=Fac A, 6=Fac B, 11=Fac C, 3=NC A, 8=NC B, 13=NC C, etc.)
  tipoCbteAfip      Int
  /// Letra del comprobante: "A", "B", "C", "E", "M"
  letraComprobante  String
  /// Nombre descriptivo: "Factura A", "Nota de Crédito B"
  nombreComprobante String
  /// Último número emitido (se incrementa automáticamente al emitir)
  ultimoNumero      Int              @default(0)
  activo            Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  puntoVentaId      Int
  puntoVenta        PuntoVentaConfig @relation(fields: [puntoVentaId], references: [id])

  facturas          Factura[]

  /// Un PV no puede tener dos series del mismo tipo de comprobante
  @@unique([puntoVentaId, tipoCbteAfip])
  @@map("series")
}

// ─── MAESTRO DE MONEDAS ──────────────────────────────────────────────────────────
// Catálogo ISO 4217. ARS es siempre la moneda base del sistema.
// Las cotizaciones históricas se guardan en Cotizacion.

model Moneda {
  id          Int           @id @default(autoincrement())
  /// Código ISO 4217 (ARS, USD, EUR, BRL, UYU)
  codigo      String        @unique
  descripcion String
  simbolo     String
  /// Si true, los importes se usan tal cual. Si false, se deben convertir.
  esBase      Boolean       @default(false)
  activo      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  cotizaciones     Cotizacion[]
  cuentasBancarias CuentaBancaria[]
  listasPrecios    ListaPrecio[]

  @@map("monedas")
}

// ─── HISTÓRICO DE COTIZACIONES ───────────────────────────────────────────────────
// Tipo de cambio por fecha y tipo (oficial, MEP, CCL, blue).
// Se consulta para convertir importes en moneda extranjera a ARS base.

model Cotizacion {
  id        Int      @id @default(autoincrement())
  fecha     DateTime @db.Date
  /// "oficial" | "mep" | "ccl" | "blue" | "tarjeta"
  tipo      String   @default("oficial")
  /// Cuántos ARS vale 1 unidad de la moneda extranjera
  valorArs  Decimal  @db.Decimal(18, 6)
  fuente    String?
  createdAt DateTime @default(now())

  monedaId  Int
  moneda    Moneda   @relation(fields: [monedaId], references: [id])

  @@unique([monedaId, fecha, tipo])
  @@map("cotizaciones")
}

// ─── MAESTRO DE BANCOS ───────────────────────────────────────────────────────────
// Catálogo de entidades financieras según BCRA.
// Código BCRA es el identificador oficial (e.g. 7 = Banco Nación).

model Banco {
  id          Int      @id @default(autoincrement())
  /// Código BCRA oficial
  codigoBcra  String?  @unique
  nombre      String
  /// Código SWIFT para transferencias internacionales
  swift       String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cuentas     CuentaBancaria[]

  @@map("bancos")
}

// ─── MAESTRO DE CUENTAS BANCARIAS ───────────────────────────────────────────────
// Cuentas bancarias propias de la empresa, de clientes o proveedores.
// CBU: 22 dígitos. Alias: hasta 20 caracteres alfanuméricos.

model CuentaBancaria {
  id              Int       @id @default(autoincrement())
  cbu             String?   @unique
  alias           String?
  numeroCuenta    String?
  /// "CC" = Cuenta Corriente | "CA" = Caja de Ahorros | "virtual" = CVU
  tipo            String    @default("CC")
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  bancoId         Int
  banco           Banco     @relation(fields: [bancoId], references: [id])
  monedaId        Int
  moneda          Moneda    @relation(fields: [monedaId], references: [id])

  /// Solo uno de estos debería ser no-nulo (empresa, cliente o proveedor)
  empresaId       Int?
  empresa         Empresa?  @relation(fields: [empresaId], references: [id])
  clienteId       Int?
  cliente         Cliente?  @relation(fields: [clienteId], references: [id])
  proveedorId     Int?
  proveedor       Proveedor? @relation(fields: [proveedorId], references: [id])

  chequesEmitidos Cheque[]  @relation("CuentaEmisor")
  chequesDepositados Cheque[] @relation("CuentaDeposito")
  movimientos     MovimientoBancario[]

  @@map("cuentas_bancarias")
}

// ─── MAESTRO DE CHEQUES ──────────────────────────────────────────────────────────
// Cheques de terceros (recibidos de clientes) y propios (emitidos a proveedores).
// El "ciclo de vida": cartera → depositado/endosado/rechazado, o emitido → debitado/rechazado.

model Cheque {
  id              Int       @id @default(autoincrement())
  numero          String
  /// "propio" = cheque de la empresa | "tercero" = recibido de un cliente
  tipoCheque      String    @default("tercero")
  monto           Decimal   @db.Decimal(18, 2)
  fechaEmision    DateTime  @db.Date
  fechaVencimiento DateTime @db.Date
  /// CUIT del banco librador (para cheques de terceros)
  cuitBancoLibrador String?
  /// "cartera" | "depositado" | "endosado" | "rechazado" | "debitado" | "anulado"
  estado          String    @default("cartera")
  observaciones   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  /// Cuenta bancaria propia donde se deposita (para cheques de terceros)
  cuentaDepositoId Int?
  cuentaDeposito   CuentaBancaria? @relation("CuentaDeposito", fields: [cuentaDepositoId], references: [id])
  /// Cuenta bancaria propia contra la que se emite (para cheques propios)
  cuentaEmisorId  Int?
  cuentaEmisor    CuentaBancaria? @relation("CuentaEmisor", fields: [cuentaEmisorId], references: [id])

  clienteId       Int?
  cliente         Cliente?  @relation(fields: [clienteId], references: [id])
  proveedorId     Int?
  proveedor       Proveedor? @relation(fields: [proveedorId], references: [id])

  /// FIX A-001: índices para cartera de cheques
  @@index([estado, fechaVencimiento])
  @@map("cheques")
}

// ─── MOVIMIENTO BANCARIO ───────────────────────────────────────────────────────
// Registro de débitos y créditos bancarios para conciliación.

model MovimientoBancario {
  id              Int       @id @default(autoincrement())
  fecha           DateTime  @db.Date
  /// "credito" | "debito"
  tipo            String
  importe         Decimal   @db.Decimal(18, 2)
  descripcion     String
  referencia      String?
  /// "pendiente" | "conciliado"
  estado          String    @default("pendiente")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  cuentaBancariaId Int
  cuentaBancaria   CuentaBancaria @relation(fields: [cuentaBancariaId], references: [id])
  /// Tipo de movimiento parametrizado (depósito, extracción, comisión, etc.)
  tipoMovimientoBancarioId Int?
  tipoMovimientoBancario   TipoMovimientoBancario? @relation(fields: [tipoMovimientoBancarioId], references: [id])

  @@map("movimientos_bancarios")
}

// ─── LOG DE ACTIVIDAD (AUDITORÍA) ────────────────────────────────────────────
// Registro de acciones de usuario para trazabilidad corporativa.

model LogActividad {
  id          Int       @id @default(autoincrement())
  /// Acción realizada: "crear", "editar", "eliminar", "login", "pago", "emision"
  accion      String
  /// Módulo afectado: "ventas", "compras", "caja", "stock", "usuarios", etc.
  modulo      String
  /// Entidad afectada (ej: "Factura", "Producto", "Cliente")
  entidad     String?
  /// ID del registro afectado
  entidadId   Int?
  /// Detalle breve de la operación
  detalle     String?   @db.Text
  /// IP del request
  ip          String?
  createdAt   DateTime  @default(now())

  usuarioId   Int?
  usuario     Usuario?  @relation(fields: [usuarioId], references: [id])

  @@index([modulo])
  @@index([usuarioId])
  @@index([createdAt])
  @@map("logs_actividad")
}

// ─── MAESTRO DE CONDICIONES DE PAGO ─────────────────────────────────────────────
// Define la política de vencimiento: "Contado", "Net 15", "30/60/90", etc.
// diasVencimiento puede ser un array JSON: [30, 60, 90] para cuotas.

model CondicionPago {
  id              Int        @id @default(autoincrement())
  nombre          String     @unique
  descripcion     String?
  /// Número de cuotas (1 = contado o pago único)
  cuotas          Int        @default(1)
  /// Para cuota única: días desde la factura. Para múltiples: primer vencimiento.
  diasVencimiento Int        @default(0)
  /// JSON array de días adicionales para cuotas 2, 3, ... ej: [30, 60]
  diasAdicionales Json?
  activo          Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  clientes        Cliente[]
  proveedores     Proveedor[]
  facturas        Factura[]
  compras         Compra[]
  presupuestos    Presupuesto[]
  ordenesCompra   OrdenCompra[]
  pedidosVenta    PedidoVenta[]

  @@map("condiciones_pago")
}

// ─── MAESTRO DE LISTAS DE PRECIOS ────────────────────────────────────────────────
// Permite manejar precios diferenciados por canal, segmento o cliente.
// Un item puede aparecer en varias listas con distintos precios.

model ListaPrecio {
  id              Int             @id @default(autoincrement())
  nombre          String
  descripcion     String?
  /// Factor multiplicador sobre el costo (1.3 = 30% sobre costo). Null = precios manuales.
  factorMarkup    Decimal?        @db.Decimal(8, 4)
  /// Si true, los precios se calculan en base al factorMarkup sobre el costo del producto.
  esAutomatica    Boolean         @default(false)
  /// Fecha desde la que rige esta lista
  vigenciaDesde   DateTime?       @db.Date
  vigenciaHasta   DateTime?       @db.Date
  activo          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  empresaId       Int
  empresa         Empresa         @relation(fields: [empresaId], references: [id])
  monedaId        Int?
  moneda          Moneda?         @relation(fields: [monedaId], references: [id])

  items           ItemListaPrecio[]
  clientes        Cliente[]
  presupuestos    Presupuesto[]

  @@unique([empresaId, nombre])
  @@map("listas_precio")
}

// ─── ITEMS DE LISTA DE PRECIOS ───────────────────────────────────────────────────

model ItemListaPrecio {
  id            Int         @id @default(autoincrement())
  precio        Decimal     @db.Decimal(18, 2)
  /// Descuento adicional aplicado a este item específico (0–100)
  descuento     Decimal     @default(0) @db.Decimal(5, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  listaPrecioId Int
  listaPrecio   ListaPrecio @relation(fields: [listaPrecioId], references: [id], onDelete: Cascade)
  productoId    Int
  producto      Producto    @relation(fields: [productoId], references: [id])

  escalones     EscalonPrecio[]

  @@unique([listaPrecioId, productoId])
  @@map("items_lista_precio")
}

// ─── MAESTRO DE VENDEDORES ───────────────────────────────────────────────────────
// Representantes de ventas. Pueden asociarse a clientes y facturas.
// La comisión es un porcentaje calculado sobre el importe neto de la venta.

model Vendedor {
  id              Int       @id @default(autoincrement())
  nombre          String
  apellido        String?
  email           String?   @unique
  telefono        String?
  /// Porcentaje de comisión (0–100)
  comisionPct     Decimal   @default(0) @db.Decimal(5, 2)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  usuarioId       Int?      @unique
  usuario         Usuario?  @relation(fields: [usuarioId], references: [id])

  clientes        Cliente[]
  facturas        Factura[]
  presupuestos    Presupuesto[]
  pedidosVenta    PedidoVenta[]

  @@map("vendedores")
}

// ─── MAESTRO DE CENTROS DE COSTO ─────────────────────────────────────────────────
// Permite asignar costos e ingresos a unidades de negocio, proyectos o áreas.
// El código es jerárquico: "100" padre, "100.10" hijo.

model CentroCosto {
  id          Int           @id @default(autoincrement())
  codigo      String
  nombre      String
  descripcion String?
  activo      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  parentId    Int?
  parent      CentroCosto?  @relation("CentroCostoJerarquia", fields: [parentId], references: [id])
  hijos       CentroCosto[] @relation("CentroCostoJerarquia")

  movimientos MovimientoContable[]

  /// FIX C-003: Multi-tenant isolation — cada empresa tiene sus propios centros de costo
  empresaId   Int
  empresa     Empresa       @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, codigo])
  @@index([empresaId, activo])
  @@map("centros_costo")
}

// ─── MAESTRO DE PROVINCIAS ───────────────────────────────────────────────────────
// Jurisdicciones fiscales argentinas para IIBB, retenciones y percepciones.
// codigoAfip: 01=CABA, 02=Buenos Aires, etc. (según padrón AFIP/ARCA).

model Provincia {
  id              Int       @id @default(autoincrement())
  /// Código AFIP/ARCA de jurisdicción (01–94)
  codigoAfip      String    @unique
  nombre          String
  /// Organismo de recaudación (ARBA, AGIP, ATER, etc.)
  organismoIIBB   String?
  /// Código SICORE del organismo provincial
  codigoSicore    String?
  /// Alícuota base de IIBB (0–100)
  alicuotaIIBB    Decimal   @default(0) @db.Decimal(5, 2)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clientes        Cliente[]
  proveedores     Proveedor[]
  localidades     Localidad[]
  feriados        Feriado[]

  @@map("provincias")
}

// ─── MAESTRO DE LOTES ────────────────────────────────────────────────────────────
// Trazabilidad de lotes de producción / importación.
// Permite registrar vencimiento, origen y rastrear un lote a través del flujo de compra→venta.

model Lote {
  id              Int       @id @default(autoincrement())
  numeroLote      String
  fechaElaboracion DateTime? @db.Date
  fechaVencimiento DateTime? @db.Date
  /// País o planta de origen
  origen          String?
  /// "activo" | "cuarentena" | "vencido" | "agotado"
  estado          String    @default("activo")
  observaciones   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  productoId      Int
  producto        Producto  @relation(fields: [productoId], references: [id])
  depositoId      Int?
  deposito        Deposito? @relation(fields: [depositoId], references: [id])

  lineasFactura   LineaFactura[]
  lineasCompra    LineaCompra[]

  @@unique([productoId, numeroLote])
  @@map("lotes")
}

// ─── MAESTRO DE UNIDADES DE MEDIDA ───────────────────────────────────────────────
// Catálogo de UoM con factor de conversión a la unidad base del producto.
// Código AFIP/UNO: "u"=unidad, "kg"=kilogramo, "lts"=litros, "m"=metro, etc.

model UnidadMedida {
  id              Int       @id @default(autoincrement())
  /// Código corto (u, kg, lts, m, m2, m3, hs, cja, doc)
  codigo          String    @unique
  descripcion     String
  /// Código AFIP para WSFE (96=unidad, 07=kg, 04=lts, etc.)
  codigoAfip      String?
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  productos       Producto[]

  @@map("unidades_medida")
}

// ─── MAESTRO DE INCOTERMS ────────────────────────────────────────────────────────
// Términos internacionales de comercio (ICC 2020) para operaciones de exportación/importación.

model Incoterm {
  id          Int       @id @default(autoincrement())
  /// Código oficial (EXW, FCA, CPT, CIP, DAP, DPU, DDP, FAS, FOB, CFR, CIF)
  codigo      String    @unique
  nombre      String
  descripcion String?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  remitos     Remito[]

  @@map("incoterms")
}

// ─── MAESTRO DE PRESUPUESTOS DE VENTA ────────────────────────────────────────────
// Oferta comercial pre-factura. Se puede convertir en Pedido o Factura directamente.

model Presupuesto {
  id              Int                  @id @default(autoincrement())
  numero          String               @unique
  fechaEmision    DateTime             @db.Date
  fechaVencimiento DateTime?           @db.Date
  subtotal        Decimal              @db.Decimal(18, 2)
  /// Descuento global sobre el subtotal (0–100%)
  descuentoPct    Decimal              @default(0) @db.Decimal(5, 2)
  impuestos       Decimal              @default(0) @db.Decimal(18, 2)
  total           Decimal              @db.Decimal(18, 2)
  /// "borrador" | "enviado" | "aceptado" | "rechazado" | "vencido" | "facturado"
  estado          String               @default("borrador")
  observaciones   String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  empresaId       Int
  empresa         Empresa              @relation(fields: [empresaId], references: [id])

  clienteId       Int
  cliente         Cliente              @relation(fields: [clienteId], references: [id])
  vendedorId      Int?
  vendedor        Vendedor?            @relation(fields: [vendedorId], references: [id])
  listaPrecioId   Int?
  listaPrecio     ListaPrecio?         @relation(fields: [listaPrecioId], references: [id])
  condicionPagoId Int?
  condicionPago   CondicionPago?       @relation(fields: [condicionPagoId], references: [id])

  lineas          LineaPresupuesto[]

  @@map("presupuestos")
}

model LineaPresupuesto {
  id              Int          @id @default(autoincrement())
  descripcion     String?
  cantidad        Decimal      @db.Decimal(14, 4)
  precioUnitario  Decimal      @db.Decimal(18, 2)
  descuentoPct    Decimal      @default(0) @db.Decimal(5, 2)
  subtotal        Decimal      @db.Decimal(18, 2)
  orden           Int          @default(0)

  presupuestoId   Int
  presupuesto     Presupuesto  @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  productoId      Int?
  producto        Producto?    @relation(fields: [productoId], references: [id])

  @@map("lineas_presupuesto")
}

// ─── MAESTRO DE ÓRDENES DE COMPRA ────────────────────────────────────────────────
// OC emitida al proveedor antes de recibir la mercadería.
// Se puede cruzar con los ingresos de mercadería para control de recepción.

model OrdenCompra {
  id              Int                  @id @default(autoincrement())
  numero          String               @unique
  fechaEmision    DateTime             @db.Date
  fechaEntregaEst DateTime?            @db.Date
  subtotal        Decimal              @db.Decimal(18, 2)
  impuestos       Decimal              @default(0) @db.Decimal(18, 2)
  total           Decimal              @db.Decimal(18, 2)
  /// "borrador" | "aprobada" | "enviada" | "parcial" | "recibida" | "anulada"
  estado          String               @default("borrador")
  observaciones   String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  empresaId       Int
  empresa         Empresa              @relation(fields: [empresaId], references: [id])

  proveedorId     Int
  proveedor       Proveedor            @relation(fields: [proveedorId], references: [id])
  condicionPagoId Int?
  condicionPago   CondicionPago?       @relation(fields: [condicionPagoId], references: [id])

  lineas          LineaOrdenCompra[]
  compras         Compra[]
  recepciones     RecepcionCompra[]

  @@map("ordenes_compra")
}

model LineaOrdenCompra {
  id              Int          @id @default(autoincrement())
  descripcion     String?
  cantidad        Decimal      @db.Decimal(14, 4)
  cantidadRecibida Decimal     @default(0) @db.Decimal(14, 4)
  precioUnitario  Decimal      @db.Decimal(18, 2)
  subtotal        Decimal      @db.Decimal(18, 2)
  orden           Int          @default(0)

  ordenCompraId   Int
  ordenCompra     OrdenCompra  @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  productoId      Int?
  producto        Producto?    @relation(fields: [productoId], references: [id])

  @@map("lineas_orden_compra")
}

// ─── PEDIDO DE VENTA ──────────────────────────────────────────────────────────────
// Confirmación comercial de venta. Genera reserva de stock y dispara picking + remito.

model PedidoVenta {
  id              Int                 @id @default(autoincrement())
  numero          String              @unique
  fechaEmision    DateTime            @db.Date
  fechaEntregaEst DateTime?           @db.Date
  subtotal        Decimal             @db.Decimal(18, 2)
  impuestos       Decimal             @default(0) @db.Decimal(18, 2)
  total           Decimal             @db.Decimal(18, 2)
  /// "borrador" | "confirmado" | "en_picking" | "remitido" | "facturado" | "anulado"
  estado          String              @default("borrador")
  observaciones   String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  empresaId       Int
  empresa         Empresa             @relation(fields: [empresaId], references: [id])

  clienteId       Int
  cliente         Cliente             @relation(fields: [clienteId], references: [id])
  vendedorId      Int?
  vendedor        Vendedor?           @relation(fields: [vendedorId], references: [id])
  condicionPagoId Int?
  condicionPago   CondicionPago?      @relation(fields: [condicionPagoId], references: [id])
  canalVentaId    Int?
  canalVenta      CanalVenta?         @relation(fields: [canalVentaId], references: [id])
  presupuestoId   Int?

  lineas          LineaPedidoVenta[]
  listasPicking   ListaPicking[]
  remitos         Remito[]

  /// FIX A-001: índices para gestión de pedidos
  @@index([empresaId, estado, createdAt])
  @@index([empresaId, clienteId])
  @@map("pedidos_venta")
}

model LineaPedidoVenta {
  id              Int            @id @default(autoincrement())
  descripcion     String?
  cantidad        Decimal        @db.Decimal(14, 4)
  cantidadEntregada Decimal      @default(0) @db.Decimal(14, 4)
  precioUnitario  Decimal        @db.Decimal(18, 2)
  subtotal        Decimal        @db.Decimal(18, 2)
  orden           Int            @default(0)

  pedidoVentaId   Int
  pedidoVenta     PedidoVenta    @relation(fields: [pedidoVentaId], references: [id], onDelete: Cascade)
  productoId      Int?
  producto        Producto?      @relation(fields: [productoId], references: [id])

  @@map("lineas_pedido_venta")
}

// ─── RECEPCIÓN DE COMPRA ──────────────────────────────────────────────────────────
// Registro de ingreso de mercadería contra una OC. Base para 3-way matching.

model RecepcionCompra {
  id              Int                    @id @default(autoincrement())
  numero          String                 @unique
  fecha           DateTime               @db.Date
  /// "pendiente" | "verificada" | "rechazada"
  estado          String                 @default("pendiente")
  observaciones   String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  ordenCompraId   Int
  ordenCompra     OrdenCompra            @relation(fields: [ordenCompraId], references: [id])
  depositoId      Int?

  lineas          LineaRecepcionCompra[]

  @@map("recepciones_compra")
}

model LineaRecepcionCompra {
  id              Int               @id @default(autoincrement())
  cantidadRecibida Decimal          @db.Decimal(14, 4)
  cantidadRechazada Decimal         @default(0) @db.Decimal(14, 4)
  observacion     String?

  recepcionId     Int
  recepcion       RecepcionCompra   @relation(fields: [recepcionId], references: [id], onDelete: Cascade)
  lineaOcId       Int
  productoId      Int?

  @@map("lineas_recepcion_compra")
}

// ─── MAESTRO DE ACTIVOS FIJOS ─────────────────────────────────────────────────────
// Bienes de uso con control de vida útil y cálculo de amortización.
// Método: lineal. Amortización mensual = valorCompra / (vidaUtilMeses).

model ActivoFijo {
  id                  Int       @id @default(autoincrement())
  descripcion         String
  /// "vehiculo" | "mueble_utensilio" | "maquinaria" | "inmueble" | "hardware" | "intangible"
  categoria           String    @default("mueble_utensilio")
  fechaCompra         DateTime  @db.Date
  valorCompra         Decimal   @db.Decimal(18, 2)
  valorResidual       Decimal   @default(0) @db.Decimal(18, 2)
  vidaUtilMeses       Int       @default(60)
  /// Valor actual en libros (valorCompra – amortización acumulada)
  valorLibros         Decimal   @db.Decimal(18, 2)
  /// "activo" | "totalmente_amortizado" | "dado_de_baja"
  estado              String    @default("activo")
  /// Número de serie, patente, escritura, etc.
  identificador       String?
  observaciones       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  empresaId               Int
  empresa                 Empresa  @relation(fields: [empresaId], references: [id])
  /// Código de la cuenta contable del activo (ej: "1.2.1 Bienes de Uso")
  cuentaActivoCodigo      String?
  /// Código de la cuenta de amortización acumulada (ej: "1.2.2 Amort. Acumulada")
  cuentaAmortizacionCodigo String?

  @@map("activos_fijos")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ═══ MAESTROS DE REFERENCIA PARAMÉTRICOS (Catálogos reutilizables) ═══════════
// ═══════════════════════════════════════════════════════════════════════════════

// ─── MAESTRO DE PAÍSES ───────────────────────────────────────────────────────────
// Catálogo ISO 3166-1 alpha-2. Permite clientes/proveedores extranjeros.

model Pais {
  id          Int         @id @default(autoincrement())
  /// Código ISO 3166-1 alpha-2 (AR, UY, BR, CL, PY, US, ES)
  codigo      String      @unique
  /// Código ISO 3166-1 alpha-3 (ARG, URY, BRA)
  codigo3     String?
  nombre      String
  /// Código numérico ISO 3166-1 (032=Argentina)
  codigoNum   String?
  /// Código de área telefónico internacional (+54, +598, +55)
  codigoTelefono String?
  activo      Boolean     @default(true)
  createdAt   DateTime    @default(now())

  localidades Localidad[]
  clientes    Cliente[]
  proveedores Proveedor[]

  @@map("paises")
}

// ─── MAESTRO DE LOCALIDADES ──────────────────────────────────────────────────────
// Ciudades, pueblos y partidos. Vinculadas a Provincia y País.
// El código postal puede ser CPA (Argentina) o formato local de cada país.

model Localidad {
  id              Int        @id @default(autoincrement())
  nombre          String
  /// Código Postal Argentino (ej: "C1425ABC") o código postal local
  codigoPostal    String?
  /// Código de área telefónico local (11, 351, 341)
  codigoArea      String?
  activo          Boolean    @default(true)
  createdAt       DateTime   @default(now())

  provinciaId     Int?
  provincia       Provincia? @relation(fields: [provinciaId], references: [id])
  paisId          Int?
  pais            Pais?      @relation(fields: [paisId], references: [id])

  clientes        Cliente[]
  proveedores     Proveedor[]

  @@index([provinciaId])
  @@map("localidades")
}

// ─── MAESTRO DE TIPOS DE DOCUMENTO ───────────────────────────────────────────────
// DNI, CUIT, CUIL, Pasaporte, CDI, LE, LC, etc.
// Permite validar formato según tipo (11 dígitos para CUIT, 8 para DNI).

model TipoDocumento {
  id              Int       @id @default(autoincrement())
  /// Código corto: "DNI", "CUIT", "CUIL", "PAS", "CDI", "LE", "LC"
  codigo          String    @unique
  nombre          String
  /// Regex de validación (ej: "^\d{2}-\d{8}-\d$" para CUIT)
  patron          String?
  /// Longitud esperada (8 para DNI, 11 para CUIT)
  longitud        Int?
  /// Si true, se usa para facturación AFIP
  esAfip          Boolean   @default(false)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@map("tipos_documento")
}

// ─── MAESTRO DE CONDICIONES IVA ──────────────────────────────────────────────────
// Reemplaza los strings hardcoded ("Responsable Inscripto", "Monotributista").
// Contiene código AFIP para facturación electrónica.

model CondicionIva {
  id              Int       @id @default(autoincrement())
  /// Código AFIP: 1=RI, 4=Exento, 5=CF, 6=Monotributo
  codigoAfip      String    @unique
  nombre          String
  /// Abreviatura: "RI", "MT", "EX", "CF"
  abreviatura     String?
  /// Letra de comprobante que recibe: "A", "B", "C"
  letraRecibe     String?
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@map("condiciones_iva")
}

// ─── MAESTRO DE ACTIVIDADES ECONÓMICAS ───────────────────────────────────────────
// Códigos AFIP F.883 / CLAE. Requerido para alta de contribuyentes.

model ActividadEconomica {
  id              Int       @id @default(autoincrement())
  /// Código AFIP/CLAE (6 dígitos: 477190, 620100)
  codigo          String    @unique
  descripcion     String
  /// "principal" | "secundaria"
  tipo            String    @default("principal")
  /// Alícuota IIBB sugerida según actividad
  alicuotaIIBB    Decimal?  @db.Decimal(5, 2)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  proveedores     Proveedor[]

  @@map("actividades_economicas")
}

// ─── MAESTRO DE ZONAS GEOGRÁFICAS ────────────────────────────────────────────────
// Zonas para logística (cálculo de flete) y pricing diferenciado.

model ZonaGeografica {
  id              Int       @id @default(autoincrement())
  codigo          String    @unique
  nombre          String
  descripcion     String?
  /// Factor de ajuste de flete (1.0 = base, 1.5 = 50% más)
  factorFlete     Decimal   @default(1.0) @db.Decimal(5, 2)
  /// Factor de ajuste de precio (1.0 = sin descuento/recargo)
  factorPrecio    Decimal   @default(1.0) @db.Decimal(5, 2)
  /// Días adicionales de entrega respecto a zona base
  diasEntrega     Int       @default(0)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  clientes        Cliente[]

  @@map("zonas_geograficas")
}

// ─── MAESTRO DE NACIONALIDADES ───────────────────────────────────────────────────
// Para datos de empleados (RRHH) y clientes persona física.

model Nacionalidad {
  id          Int       @id @default(autoincrement())
  /// "argentina", "uruguaya", "brasileña", "chilena"
  nombre      String    @unique
  /// Código ISO del país asociado
  codigoPais  String?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@map("nacionalidades")
}

// ─── MAESTRO DE IDIOMAS ──────────────────────────────────────────────────────────
// Para comunicaciones, documentos y preferencias de usuario.

model Idioma {
  id          Int       @id @default(autoincrement())
  /// Código BCP 47: "es-AR", "pt-BR", "en-US"
  codigo      String    @unique
  nombre      String
  /// Código ISO 639-1: "es", "pt", "en"
  iso639      String?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  clientes    Cliente[]

  @@map("idiomas")
}

// ─── MAESTRO DE FORMAS DE PAGO ───────────────────────────────────────────────────
// Medios de pago: efectivo, transferencia, tarjeta, cheque, MercadoPago.
// Diferente a CondicionPago (que es el plazo: contado, 30 días).

model FormaPago {
  id              Int       @id @default(autoincrement())
  codigo          String    @unique
  nombre          String
  /// "efectivo" | "transferencia" | "tarjeta_debito" | "tarjeta_credito" | "cheque" | "mercadopago" | "cuenta_corriente"
  tipo            String
  /// Comisión o descuento (ej: 3% para tarjeta)
  comisionPct     Decimal   @default(0) @db.Decimal(5, 2)
  /// Días para acreditación (0=inmediato, 2=48hs)
  diasAcreditacion Int      @default(0)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  clientes        Cliente[]
  planesCuotas    PlanCuotas[]

  @@map("formas_pago")
}

// ─── MAESTRO DE MOTIVOS ──────────────────────────────────────────────────────────
// Motivos parametrizables para NC, ajustes de stock, bajas, devoluciones.

model Motivo {
  id              Int       @id @default(autoincrement())
  codigo          String    @unique
  descripcion     String
  /// "nota_credito" | "ajuste_stock" | "devolucion" | "baja" | "anulacion"
  tipoOperacion   String
  /// Si true, requiere autorización de supervisor
  requiereAprobacion Boolean @default(false)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@map("motivos")
}

// ─── MAESTRO DE FERIADOS ─────────────────────────────────────────────────────────
// Calendario de feriados para cálculo de vencimientos y días hábiles.

model Feriado {
  id          Int        @id @default(autoincrement())
  fecha       DateTime   @db.Date
  descripcion String
  /// "nacional" | "provincial" | "municipal"
  tipo        String     @default("nacional")
  /// Código de provincia si es provincial (puede ser null si es nacional)
  provinciaId Int?
  provincia   Provincia? @relation(fields: [provinciaId], references: [id])
  createdAt   DateTime   @default(now())

  @@unique([fecha, provinciaId])
  @@map("feriados")
}

// ─── MAESTRO DE TIPOS DE CLIENTE ────────────────────────────────────────────────
// Categorización comercial: "Mayorista", "Minorista", "Distribuidor", "Consumidor Final"

model TipoCliente {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  nombre      String
  descripcion String?
  /// Factor de descuento automático (0–100%)
  descuentoPct Decimal  @default(0) @db.Decimal(5, 2)
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  clientes    Cliente[]

  @@map("tipos_cliente")
}

// ─── MAESTRO DE ESTADOS DE CLIENTE ──────────────────────────────────────────────
// Estado operativo: "Activo", "Inactivo", "Suspendido", "Bloqueado"

model EstadoCliente {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  nombre      String
  descripcion String?
  /// Si true, permite operaciones de venta
  permiteVenta Boolean  @default(true)
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  clientes    Cliente[]

  @@map("estados_cliente")
}

// ─── MAESTRO DE RUBROS ──────────────────────────────────────────────────────────
// Clasificación económica: "Alimentos", "Tecnología", "Construcción", "Servicios"

model Rubro {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  nombre      String
  descripcion String?
  /// Ícono de la UI (ej: "utensils", "stethoscope", "factory", "shopping-cart")
  icono       String?
  /// Color HEX o OKLCH para la UI
  color       String?
  /// Orden de presentación en UI
  orden       Int       @default(0)
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  clientes    Cliente[]
  proveedores Proveedor[]
  empresas    Empresa[]  @relation("EmpresaRubro")
  configuraciones ConfiguracionRubro[]
  workflows       WorkflowRubro[]
  featuresRubro   FeatureRubro[]

  @@map("rubros")
}

// ─── MAESTRO DE CANALES DE VENTA ────────────────────────────────────────────────
// Canal de comercialización: "Online", "Presencial", "Mayorista", "Distribuidor"

model CanalVenta {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  nombre      String
  descripcion String?
  /// Factor de markup adicional (0–100%)
  markupPct   Decimal   @default(0) @db.Decimal(5, 2)
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  clientes    Cliente[]
  pedidosVenta PedidoVenta[]
  periodosFiscales PeriodoFiscal[]

  @@map("canales_venta")
}

// ─── MAESTRO DE SEGMENTOS DE CLIENTE ────────────────────────────────────────────
// Segmentación de valor: "VIP", "Premium", "Regular", "Nuevo", "Inactivo"

model SegmentoCliente {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  nombre      String
  descripcion String?
  /// Prioridad de atención (1=alta, 5=baja)
  prioridad   Int       @default(3)
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  clientes    Cliente[]

  @@map("segmentos_cliente")
}

// ─── MAESTRO DE TIPOS DE EMPRESA ────────────────────────────────────────────────
// Para clientes jurídicos: "SA", "SRL", "Cooperativa", "Fundación"

model TipoEmpresa {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  nombre      String
  descripcion String?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  clientes    Cliente[]

  @@map("tipos_empresa")
}

// ─── MAESTRO DE ESTADOS CIVILES ─────────────────────────────────────────────────
// Para clientes persona física: "Soltero", "Casado", "Divorciado", "Viudo"

model EstadoCivil {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  nombre      String
  descripcion String?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  clientes    Cliente[]

  @@map("estados_civiles")
}

// ─── MAESTRO DE PROFESIONES ─────────────────────────────────────────────────────
// Ocupaciones para clientes persona física: "Ingeniero", "Médico", "Comerciante"

model Profesion {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  nombre      String
  descripcion String?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  clientes    Cliente[]

  @@map("profesiones")
}

// ─── MAESTRO DE TIPOS DE DIRECCIÓN ──────────────────────────────────────────────
// Clasificación de direcciones: "Legal", "Entrega", "Facturación", "Sucursal"

model TipoDireccion {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  nombre      String
  descripcion String?
  /// Si true, es la dirección principal por defecto
  esPrincipal Boolean   @default(false)
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@map("tipos_direccion")
}

// ─── MAESTRO DE TIPOS DE CONTACTO ───────────────────────────────────────────────
// Tipos de medio de contacto: "Teléfono", "Email", "WhatsApp", "Telegram"

model TipoContacto {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  nombre      String
  descripcion String?
  /// Patrón de validación (regex)
  patron      String?
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@map("tipos_contacto")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ═══ CUENTAS A COBRAR / CUENTAS A PAGAR ═════════════════════════════════════
// ═══════════════════════════════════════════════════════════════════════════════

// ─── CUENTA A COBRAR ─────────────────────────────────────────────────────────
// Se genera al emitir factura a crédito. Se cancela con Recibos.

model CuentaCobrar {
  id              Int       @id @default(autoincrement())
  /// Número de cuota (1 para pago único)
  numeroCuota     Int       @default(1)
  montoOriginal   Decimal   @db.Decimal(18, 2)
  montoPagado     Decimal   @default(0) @db.Decimal(18, 2)
  saldo           Decimal   @db.Decimal(18, 2)
  fechaEmision    DateTime  @db.Date
  fechaVencimiento DateTime @db.Date
  /// "pendiente" | "parcial" | "pagada" | "vencida" | "incobrable"
  estado          String    @default("pendiente")
  observaciones   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  facturaId       Int
  factura         Factura   @relation(fields: [facturaId], references: [id])
  clienteId       Int
  cliente         Cliente   @relation(fields: [clienteId], references: [id])

  itemsRecibo     ItemRecibo[]

  /// FIX A-001: índices para aging y gestión de CC
  @@index([estado, fechaVencimiento])
  @@index([clienteId])
  @@map("cuentas_cobrar")
}

// ─── RECIBO DE COBRANZA ──────────────────────────────────────────────────────
// Documento que registra el pago del cliente. Cancela una o más CC.

model Recibo {
  id              Int       @id @default(autoincrement())
  numero          String    @unique
  fecha           DateTime  @db.Date
  montoTotal      Decimal   @db.Decimal(18, 2)
  /// "efectivo" | "transferencia" | "cheque" | "tarjeta"
  medioPago       String    @default("efectivo")
  /// Retenciones sufridas por el cobrador (IVA, Ganancias, IIBB)
  retencionIVA    Decimal   @default(0) @db.Decimal(18, 2)
  retencionGanancias Decimal @default(0) @db.Decimal(18, 2)
  retencionIIBB   Decimal   @default(0) @db.Decimal(18, 2)
  totalRetenciones Decimal  @default(0) @db.Decimal(18, 2)
  /// Neto efectivamente cobrado = montoTotal - totalRetenciones
  netoRecibido    Decimal   @default(0) @db.Decimal(18, 2)
  observaciones   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clienteId       Int
  cliente         Cliente   @relation(fields: [clienteId], references: [id])
  /// Cobrador que realizó la gestión
  cobradorId      Int?
  cobrador        Cobrador? @relation(fields: [cobradorId], references: [id])

  items           ItemRecibo[]
  /// Detalle de retenciones sufridas (con régimen, certificado, base)
  retencionesDetalle RetencionRecibo[]

  @@map("recibos")
}

model ItemRecibo {
  id              Int           @id @default(autoincrement())
  montoPagado     Decimal       @db.Decimal(18, 2)

  reciboId        Int
  recibo          Recibo        @relation(fields: [reciboId], references: [id], onDelete: Cascade)
  cuentaCobrarId  Int
  cuentaCobrar    CuentaCobrar  @relation(fields: [cuentaCobrarId], references: [id])

  @@map("items_recibo")
}

// ─── CUENTA A PAGAR ──────────────────────────────────────────────────────────
// Se genera al registrar compra a crédito. Se cancela con OrdenesPago.

model CuentaPagar {
  id              Int       @id @default(autoincrement())
  numeroCuota     Int       @default(1)
  montoOriginal   Decimal   @db.Decimal(18, 2)
  montoPagado     Decimal   @default(0) @db.Decimal(18, 2)
  saldo           Decimal   @db.Decimal(18, 2)
  fechaEmision    DateTime  @db.Date
  fechaVencimiento DateTime @db.Date
  /// "pendiente" | "parcial" | "pagada" | "vencida"
  estado          String    @default("pendiente")
  observaciones   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  compraId        Int
  compra          Compra    @relation(fields: [compraId], references: [id])
  proveedorId     Int
  proveedor       Proveedor @relation(fields: [proveedorId], references: [id])

  itemsOrdenPago  ItemOrdenPago[]

  @@map("cuentas_pagar")
}

// ─── ORDEN DE PAGO ───────────────────────────────────────────────────────────
// Documento que autoriza el pago al proveedor. Cancela una o más CP.

model OrdenPago {
  id              Int       @id @default(autoincrement())
  numero          String    @unique
  fecha           DateTime  @db.Date
  montoTotal      Decimal   @db.Decimal(18, 2)
  medioPago       String    @default("transferencia")
  /// Retenciones aplicadas al proveedor (deducidas del pago)
  retencionIVA    Decimal   @default(0) @db.Decimal(18, 2)
  retencionGanancias Decimal @default(0) @db.Decimal(18, 2)
  retencionIIBB   Decimal   @default(0) @db.Decimal(18, 2)
  totalRetenciones Decimal  @default(0) @db.Decimal(18, 2)
  /// Neto efectivamente pagado = montoTotal - totalRetenciones
  netoPagado      Decimal   @default(0) @db.Decimal(18, 2)
  observaciones   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  proveedorId     Int
  proveedor       Proveedor @relation(fields: [proveedorId], references: [id])

  items           ItemOrdenPago[]
  retenciones     RetencionSICORE[]

  @@map("ordenes_pago")
}

model ItemOrdenPago {
  id              Int          @id @default(autoincrement())
  montoPagado     Decimal      @db.Decimal(18, 2)

  ordenPagoId     Int
  ordenPago       OrdenPago    @relation(fields: [ordenPagoId], references: [id], onDelete: Cascade)
  cuentaPagarId   Int
  cuentaPagar     CuentaPagar  @relation(fields: [cuentaPagarId], references: [id])

  @@map("items_orden_pago")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ═══ MATRIZ FISCAL MULTI-EJE ════════════════════════════════════════════════
// ═══════════════════════════════════════════════════════════════════════════════

// ─── CONFIGURACIÓN FISCAL POR EMPRESA ─────────────────────────────────────────
// Flags de régimen fiscal de la empresa: si es agente de percepción/retención, etc.

model ConfigFiscalEmpresa {
  id                        Int      @id @default(autoincrement())
  empresaId                 Int      @unique
  empresa                   Empresa  @relation(fields: [empresaId], references: [id])
  esAgentePercepcionIVA     Boolean  @default(false)
  esAgenteRetencionIVA      Boolean  @default(false)
  esAgentePercepcionIIBB    Boolean  @default(false)
  esAgenteRetencionIIBB     Boolean  @default(false)
  esAgenteRetencionGanancias Boolean @default(false)
  /// JSON: provincias donde es RI para IIBB (Convenio Multilateral)
  jurisdiccionesIIBB        Json?
  /// Número de inscripción en convenio multilateral
  numConvenioMultilateral   String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  inscripcionesIIBB         InscripcionIIBB[]

  @@map("config_fiscal_empresa")
}

// ─── INSCRIPCIÓN IIBB POR JURISDICCIÓN ────────────────────────────────────────
// Una empresa puede estar inscripta en IIBB en múltiples provincias con
// diferentes alícuotas y números de inscripción.

model InscripcionIIBB {
  id              Int              @id @default(autoincrement())
  /// "PBA", "CABA", "SF", "CBA", etc.
  jurisdiccion    String
  /// Número de inscripción provincial
  numeroInscripcion String?
  /// Alícuota específica para esta empresa en esta provincia
  alicuota        Decimal          @db.Decimal(5, 2)
  /// "local" | "convenio_multilateral"
  regimen         String           @default("local")
  /// Coeficiente de convenio multilateral (0.01 – 1.00)
  coeficienteUnificado Decimal?    @db.Decimal(8, 6)
  activo          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  configFiscalId  Int
  configFiscal    ConfigFiscalEmpresa @relation(fields: [configFiscalId], references: [id])

  @@unique([configFiscalId, jurisdiccion])
  @@map("inscripciones_iibb")
}

// ─── PADRÓN DE RÉGIMEN POR CLIENTE ──────────────────────────────────────────
// ARBA / ARCIBA / DGR publican padrones de sujetos con alícuota específica.
// Si el cliente aparece en el padrón, se usa esa alícuota en lugar de la general.

model PadronRegimenCliente {
  id              Int       @id @default(autoincrement())
  /// "percepcion_iibb" | "retencion_iibb" | "percepcion_iva"
  tipoRegimen     String
  /// Organismo: "ARBA", "AGIP", etc.
  organismo       String
  jurisdiccion    String
  /// Alícuota asignada al cliente según padrón (puede ser 0 = excluido)
  alicuota        Decimal   @db.Decimal(5, 2)
  /// Período de vigencia
  vigenciaDesde   DateTime  @db.Date
  vigenciaHasta   DateTime? @db.Date
  /// CUIT del sujeto (para lookup rápido sin JOIN)
  cuitSujeto      String
  createdAt       DateTime  @default(now())

  clienteId       Int
  cliente         Cliente   @relation(fields: [clienteId], references: [id])

  @@index([cuitSujeto, organismo])
  @@map("padron_regimen_cliente")
}

// ─── CLASIFICACIÓN FISCAL DE PRODUCTO ────────────────────────────────────────
// Permite asignar IVA diferenciado, exenciones o códigos NCM a cada producto.

model ClasificacionFiscal {
  id              Int       @id @default(autoincrement())
  /// Código interno: "GRAV_21", "RED_10_5", "EXENTO", "NO_GRAVADO"
  codigo          String    @unique
  nombre          String
  /// Alícuota IVA por defecto (21, 10.5, 27, 0)
  alicuotaIva     Decimal   @db.Decimal(5, 2)
  /// Código NCM (Nomenclador Común del Mercosur) para exportación
  codigoNCM       String?
  /// Si true, producto exento de IVA
  exentoIva       Boolean   @default(false)
  /// Si true, no gravado (diferente a exento en el tratamiento AFIP)
  noGravado       Boolean   @default(false)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  productos       Producto[]

  @@map("clasificaciones_fiscales")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ═══ MOTOR DE INTELIGENCIA ARTIFICIAL ═══════════════════════════════════════
// ═══════════════════════════════════════════════════════════════════════════════

// ─── ALERTAS GENERADAS POR IA ─────────────────────────────────────────────────
// Generadas por cron diario o bajo demanda. Persistidas para historial y métricas.

model AlertaIA {
  id          Int       @id @default(autoincrement())
  /// "stock_critico" | "demanda_cayendo" | "cliente_inactivo" | "cobranza_urgente" | "anomalia" | "oportunidad" | "turno" | "caja" | "general"
  tipo        String
  /// "alta" | "media" | "baja"
  prioridad   String
  titulo      String
  descripcion String    @db.Text
  /// Acción recomendada por la IA
  accion      String?   @db.Text
  /// Datos estructurados (montos, productos, etc.)
  datos       Json?
  leida       Boolean   @default(false)
  resuelta    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId, createdAt])
  @@index([empresaId, leida])
  @@map("alertas_ia")
}

// ─── REPORTES GENERADOS POR IA ────────────────────────────────────────────────
// Reportes diarios/semanales/mensuales generados por cron o bajo demanda.

model ReporteIA {
  id              Int       @id @default(autoincrement())
  /// "dia" | "semana" | "mes"
  periodo         String
  resumen         String    @db.Text
  metricasClave   Json
  insights        Json
  recomendaciones Json
  alertasCriticas Json
  createdAt       DateTime  @default(now())

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId, periodo, createdAt])
  @@map("reportes_ia")
}

// ─── COLA DE MENSAJES WHATSAPP ────────────────────────────────────────────────
// Mensajes generados por IA para enviar vía Twilio/WhatsApp. 
// Requieren aprobación del usuario antes de envío.

model MensajePendienteWhatsApp {
  id           Int       @id @default(autoincrement())
  destinatario String
  telefono     String
  mensaje      String    @db.Text
  /// "cobranza" | "recordatorio_turno" | "cliente_inactivo" | "stock" | "pedido" | "general"
  tipo         String
  prioridad    Int       @default(5)
  /// "pendiente" | "aprobado" | "enviado" | "error" | "descartado"
  estado       String    @default("pendiente")
  enviadoAt    DateTime?
  error        String?
  createdAt    DateTime  @default(now())

  empresaId    Int
  empresa      Empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId, estado])
  @@index([estado, prioridad])
  @@map("mensajes_pendientes_whatsapp")
}

// ─── HISTORIAL DE CHAT IA ─────────────────────────────────────────────────────
// Persiste conversaciones del chat IA para continuidad y auditoría.

model ChatIAHistorial {
  id        Int       @id @default(autoincrement())
  /// "user" | "assistant" | "system"
  role      String
  content   String    @db.Text
  createdAt DateTime  @default(now())

  empresaId Int
  empresa   Empresa   @relation(fields: [empresaId], references: [id])
  usuarioId Int

  @@index([empresaId, usuarioId, createdAt])
  @@map("chat_ia_historial")
}

// ─── LOGS DE EJECUCIÓN DE AGENTES IA ──────────────────────────────────────────
// Auditoría de cada ejecución de agente autónomo.

model AgenteLog {
  id                  Int       @id @default(autoincrement())
  /// ID del agente: "alertas-stock" | "cobranzas" | "ventas-leads" | etc.
  agenteId            String
  /// "schedule" | "event" | "manual" | "api"
  triggeredBy         String
  /// "success" | "error" | "skipped"
  status              String
  /// Resumen legible de lo que hizo el agente
  resumen             String    @db.Text
  /// Cantidad de acciones ejecutadas
  accionesEjecutadas  Int       @default(0)
  /// Tiempo de ejecución en ms
  durationMs          Int       @default(0)
  /// Error message if failed
  error               String?   @db.Text
  /// Detalle de acciones (JSON array)
  detalles            Json?
  createdAt           DateTime  @default(now())

  empresaId           Int
  empresa             Empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId, agenteId, createdAt])
  @@index([agenteId, status])
  @@index([empresaId, createdAt])
  @@map("agente_logs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// MÓDULO AGENDA / TURNOS
// ═══════════════════════════════════════════════════════════════════════════════

model Profesional {
  id          Int       @id @default(autoincrement())
  nombre      String
  especialidad String?
  email       String?
  telefono    String?
  color       String?   @default("#3b82f6")
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])
  turnos      Turno[]

  @@map("profesionales")
}

model Turno {
  id          Int       @id @default(autoincrement())
  fecha       DateTime  @db.Date
  horaInicio  String    /// "09:00"
  horaFin     String    /// "09:30"
  /// "pendiente" | "confirmado" | "en_curso" | "completado" | "cancelado" | "no_asistio"
  estado      String    @default("pendiente")
  motivo      String?
  notas       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profesionalId Int
  profesional   Profesional @relation(fields: [profesionalId], references: [id])
  clienteId     Int?
  cliente       Cliente?    @relation(fields: [clienteId], references: [id])

  @@index([fecha])
  @@index([profesionalId])
  @@map("turnos")
}

// ═══════════════════════════════════════════════════════════════════════════════
// MÓDULO HISTORIA CLÍNICA (VETERINARIA / SALUD)
// ═══════════════════════════════════════════════════════════════════════════════

model Paciente {
  id          Int       @id @default(autoincrement())
  nombre      String
  especie     String?   /// "canino", "felino", "equino", etc.
  raza        String?
  sexo        String?   /// "M" | "H"
  fechaNac    DateTime? @db.Date
  peso        Float?
  chip        String?   @unique
  notas       String?   @db.Text
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  clienteId   Int
  cliente     Cliente   @relation(fields: [clienteId], references: [id])
  consultas   Consulta[]

  @@map("pacientes")
}

model Consulta {
  id              Int       @id @default(autoincrement())
  fecha           DateTime  @default(now())
  motivo          String
  diagnostico     String?   @db.Text
  tratamiento     String?   @db.Text
  observaciones   String?   @db.Text
  peso            Float?
  temperatura     Float?
  proximaVisita   DateTime? @db.Date
  createdAt       DateTime  @default(now())

  pacienteId      Int
  paciente        Paciente  @relation(fields: [pacienteId], references: [id])

  @@index([pacienteId])
  @@index([fecha])
  @@map("consultas")
}

// ═══════════════════════════════════════════════════════════════════════════════
// MÓDULO MEMBRESÍAS / SUSCRIPCIONES
// ═══════════════════════════════════════════════════════════════════════════════

model PlanMembresia {
  id          Int       @id @default(autoincrement())
  nombre      String
  descripcion String?
  precio      Decimal   @db.Decimal(18, 2)
  /// "mensual" | "trimestral" | "semestral" | "anual"
  periodicidad String   @default("mensual")
  duracionDias Int      @default(30)
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])
  membresias  Membresia[]

  @@map("planes_membresia")
}

model Membresia {
  id          Int       @id @default(autoincrement())
  fechaInicio DateTime  @db.Date
  fechaFin    DateTime  @db.Date
  /// "activa" | "vencida" | "cancelada" | "suspendida"
  estado      String    @default("activa")
  notas       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  planId      Int
  plan        PlanMembresia @relation(fields: [planId], references: [id])
  clienteId   Int
  cliente     Cliente       @relation(fields: [clienteId], references: [id])

  @@index([clienteId])
  @@index([estado])
  @@map("membresias")
}

// ═══════════════════════════════════════════════════════════════════════════════
// MÓDULO HOSPITALIDAD (RESTAURANTE / SALÓN)
// ═══════════════════════════════════════════════════════════════════════════════

model Salon {
  id          Int       @id @default(autoincrement())
  nombre      String
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])
  mesas       Mesa[]

  @@map("salones")
}

model Mesa {
  id          Int       @id @default(autoincrement())
  numero      Int
  capacidad   Int       @default(4)
  /// "libre" | "ocupada" | "reservada" | "cuenta_pedida"
  estado      String    @default("libre")
  posX        Int?
  posY        Int?

  salonId     Int
  salon       Salon     @relation(fields: [salonId], references: [id])
  comandas    Comanda[]

  @@unique([salonId, numero])
  @@map("mesas")
}

model Comanda {
  id          Int       @id @default(autoincrement())
  /// "abierta" | "enviada_cocina" | "en_preparacion" | "lista" | "entregada" | "cerrada" | "cancelada"
  estado      String    @default("abierta")
  comensales  Int       @default(1)
  mozo        String?
  notas       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  mesaId      Int
  mesa        Mesa      @relation(fields: [mesaId], references: [id])
  lineas      LineaComanda[]
  facturaId   Int?
  factura     Factura?  @relation(fields: [facturaId], references: [id])

  @@index([estado])
  @@map("comandas")
}

model LineaComanda {
  id          Int       @id @default(autoincrement())
  cantidad    Int       @default(1)
  nombre      String
  precio      Decimal   @db.Decimal(18, 2)
  notas       String?
  /// "pendiente" | "en_preparacion" | "lista" | "entregada"
  estado      String    @default("pendiente")

  comandaId   Int
  comanda     Comanda   @relation(fields: [comandaId], references: [id])
  productoId  Int?
  producto    Producto? @relation(fields: [productoId], references: [id])

  @@map("lineas_comanda")
}

model ConfiguracionModulo {
  id         Int      @id @default(autoincrement())
  modulo     String
  habilitado Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  empresaId  Int      @map("empresa_id")
  empresa    Empresa  @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, modulo])
  @@map("configuracion_modulos")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ═══ PARAMETRIZACIÓN — PLAN DE CUENTAS DINÁMICO ═════════════════════════════
// ═══════════════════════════════════════════════════════════════════════════════

// ─── PLAN DE CUENTAS EN DB (reemplaza plan-cuentas.ts hardcodeado) ─────────
// Cada empresa tiene su propio plan de cuentas adaptado al rubro.
// El seed genera un plan base según Empresa.rubro y la empresa lo personaliza.

model CuentaContable {
  id         Int       @id @default(autoincrement())
  /// Código jerárquico: "1.1", "1.1.1", "2.4.1", etc.
  codigo     String
  nombre     String
  /// "activo" | "pasivo" | "patrimonio" | "ingreso" | "egreso"
  tipo       String
  /// Subcategoría: "Disponibilidades", "Bienes de Cambio", "Deudas Fiscales", etc.
  categoria  String
  /// Naturaleza del saldo: "deudora" | "acreedora" — define si sube por debe o haber
  naturaleza String    @default("deudora")
  /// Nivel jerárquico (1=rubro, 2=subrubro, 3=cuenta, 4=subcuenta)
  nivel      Int       @default(3)
  /// Si true, permite imputar movimientos; si false, es cuenta de resumen
  imputable  Boolean   @default(true)
  /// Cuenta padre para jerarquía (null = cuenta raíz)
  parentId   Int?
  parent     CuentaContable?  @relation("CuentaJerarquia", fields: [parentId], references: [id])
  hijos      CuentaContable[] @relation("CuentaJerarquia")
  /// Código AFIP para mapeo fiscal (ej: libro IVA digital, SIRE)
  codigoAfip String?
  /// Si true, esta cuenta se ajusta por inflación (RT 6 / NIC 29)
  ajustaInflacion Boolean @default(false)
  /// Override moneda funcional (null = ARS). Para cuentas en moneda extranjera.
  monedaFuncional String?
  /// Rubro contable para agrupación en estados financieros (Balance / EERR)
  rubroContableId Int?
  rubroContable   RubroContable? @relation(fields: [rubroContableId], references: [id])
  activo     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  empresaId  Int
  empresa    Empresa   @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, codigo])
  @@index([empresaId, tipo])
  @@map("cuentas_contables")
}

// ─── MAPEO DE ASIENTOS AUTOMÁTICOS ────────────────────────────────────────────
// Define qué cuenta contable usar para cada campo de cada tipo de transacción.
// Ej: transaccion="venta", campo="ingreso" → cuenta "4.1.1 Ventas gastronómicas"
// Ej: transaccion="compra", campo="mercaderia" → cuenta "1.4 Mercaderías"
// Esto desacopla la lógica de asientos del plan de cuentas hardcodeado.

model ConfigAsientoCuenta {
  id              Int       @id @default(autoincrement())
  /// Tipo de transacción: "venta" | "compra" | "cobro" | "pago" | "nc" | "nd" | "cmv" | "liquidacion_iva"
  tipoTransaccion String
  /// Campo semántico: "ingreso" | "iva_df" | "iva_cf" | "mercaderia" | "caja" | "banco" |
  ///   "proveedores" | "deudores" | "percepciones" | "ret_iva_sufrida" | "ret_ganancias_sufrida" |
  ///   "ret_iibb_sufrida" | "ret_iva_depositar" | "ret_ganancias_depositar" | "ret_iibb_depositar" |
  ///   "cmv" | "iva_a_pagar" | "iva_a_favor"
  campo           String
  /// Código de cuenta contable (referencia al plan de cuentas de esta empresa)
  cuentaCodigo    String
  /// Nombre legible (cache para UI, no normativo)
  cuentaNombre    String?
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, tipoTransaccion, campo])
  @@map("config_asiento_cuentas")
}

// ─── NUMERADORES CONFIGURABLES ────────────────────────────────────────────────
// Cada tipo de documento tiene un prefijo, formato y correlativo independiente.
// La empresa puede personalizar el formato: "REC-{NNNNNN}", "FC-{PPPP}-{NNNNNNNN}", etc.

model Numerador {
  id              Int       @id @default(autoincrement())
  /// Tipo de documento: "recibo" | "orden_pago" | "pedido_venta" | "orden_compra" |
  ///   "remito" | "lista_picking" | "recepcion" | "nota_debito" | "presupuesto"
  tipoDocumento   String
  /// Prefijo: "REC", "OP", "PV", "OC", "REM", "PK", "RCMP", "ND", "PRES"
  prefijo         String
  /// Último número emitido (correlativo)
  ultimoNumero    Int       @default(0)
  /// Cantidad de dígitos para el número (8 → 00000001)
  digitos         Int       @default(6)
  /// Sucursal/punto de venta (opcional, para esquemas PPPP-NNNNNNNN)
  sucursal        String?
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, tipoDocumento, sucursal])
  @@map("numeradores")
}

// ─── PARÁMETROS FISCALES CENTRALIZADOS ────────────────────────────────────────
// Constantes del sistema que hoy están hardcodeadas en servicios.
// Almacena umbrales, tolerancias, mínimos no imponibles y cualquier valor
// que pueda cambiar por normativa o por decisión empresarial.

model ParametroFiscal {
  id              Int       @id @default(autoincrement())
  /// Clave única del parámetro: "umbral_rg5824", "tolerancia_3way_match",
  ///   "minimo_sicore_305", "minimo_sicore_767", "iibb_pba_comercio", etc.
  clave           String
  /// Valor numérico del parámetro
  valor           Decimal   @db.Decimal(18, 4)
  /// Descripción legible para UI
  descripcion     String?
  /// "fiscal" | "operativo" | "contable"
  categoria       String    @default("fiscal")
  /// País al que aplica (null = global)
  pais            String?
  /// Normativa de referencia: "RG 5824/2026", "RG 2854", etc.
  normativa       String?
  /// Vigencia
  vigenciaDesde   DateTime? @db.Date
  vigenciaHasta   DateTime? @db.Date
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, clave, pais])
  @@index([empresaId, categoria])
  @@map("parametros_fiscales")
}

// ─── PERÍODO FISCAL CONTABLE ─────────────────────────────────────────────────
// Controla apertura/cierre de meses contables. Una vez cerrado, el período
// bloquea la creación/modificación de asientos, facturas y compras con fecha
// dentro de ese rango. Solo un contador o administrador puede reabrir.

model PeriodoFiscal {
  id          Int       @id @default(autoincrement())
  mes         Int       // 1–12
  anio        Int
  /// "abierto" | "cerrado" | "bloqueado"
  /// abierto:    se pueden registrar transacciones
  /// cerrado:    mes cerrado por cierre contable, reaperturable por admin
  /// bloqueado:  presentado ante AFIP, no reaperturable sin auditoría
  estado      String    @default("abierto")
  /// Fecha/hora en que se cerró
  fechaCierre   DateTime?
  /// Usuario que ejecutó el cierre
  cerradoPor    Int?
  /// Observaciones del cierre (ej: "Cierre mensual agosto 2026")
  observaciones String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, mes, anio])
  canalVentaId    Int?
  canalVenta      CanalVenta?         @relation(fields: [canalVentaId], references: [id])
  @@index([empresaId, estado])
  @@map("periodos_fiscales")
}

// ─── ESCALONES DE PRECIO (PRECIO POR VOLUMEN) ────────────────────────────────
// Permite definir tramos de precio por cantidad para un ítem de lista de precios.
// Ejemplo: 1–5 unidades → $100; 6–12 unidades → $85; 13+ unidades → $70
// REQUIERE MIGRACIÓN: prisma migrate dev --name add-escalones-precio

model EscalonPrecio {
  id                Int             @id @default(autoincrement())
  /// Cantidad mínima para que aplique este escalón (inclusive)
  cantidadDesde     Int
  /// Cantidad máxima para este escalón. Null = sin límite superior (tramo final)
  cantidadHasta     Int?
  /// Precio unitario para este tramo de cantidad
  precio            Decimal         @db.Decimal(18, 2)
  /// Descuento porcentual alternativo (0 = no aplica descuento, usar precio directo)
  descuentoPct      Decimal         @default(0) @db.Decimal(5, 2)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  itemListaPrecioId Int
  itemListaPrecio   ItemListaPrecio @relation(fields: [itemListaPrecioId], references: [id], onDelete: Cascade)

  @@index([itemListaPrecioId])
  @@map("escalones_precio")
}

// ─── TIPOS DE ENVASE (RETORNABLES) ───────────────────────────────────────────
// Maestro de tipos de envases retornables para distribuidoras de bebidas.
// Ejemplos: "Cajón 24 latas", "Botellón 20L", "Sifón 1L"
// REQUIERE MIGRACIÓN: prisma migrate dev --name add-envases-retornables

model TipoEnvase {
  id            Int       @id @default(autoincrement())
  nombre        String
  descripcion   String?
  /// Capacidad nominal (litros, unidades, etc.)
  capacidad     Float?
  /// Unidad de medida: "litros" | "unidades" | "kg"
  unidadMedida  String    @default("unidades")
  /// Valor de depósito por envase (monto cobrado al cliente como garantía)
  valorDeposito Decimal   @default(0) @db.Decimal(18, 2)
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  empresaId     Int
  empresa       Empresa   @relation(fields: [empresaId], references: [id])

  movimientos   MovimientoEnvase[]

  @@index([empresaId])
  @@map("tipos_envase")
}

// ─── MOVIMIENTOS DE ENVASES ───────────────────────────────────────────────────
// Registra cada entrega y retorno de envases retornables.
// Saldo por cliente = SUM(entregados) - SUM(retornados)

model MovimientoEnvase {
  id              Int        @id @default(autoincrement())
  /// "entrega" = salida del depósito hacia cliente
  /// "retorno" = devolución del cliente al depósito
  /// "ajuste"  = corrección de inventario (puede ser + o -)
  tipo            String     // "entrega" | "retorno" | "ajuste"
  cantidad        Int        // positivo siempre; el tipo define la dirección
  fechaMovimiento DateTime   @default(now())
  observaciones   String?

  tipoEnvaseId    Int
  tipoEnvase      TipoEnvase @relation(fields: [tipoEnvaseId], references: [id])

  /// Cliente al que se entregaron / devolvió los envases
  clienteId       Int?
  cliente         Cliente?   @relation(fields: [clienteId], references: [id])

  /// Factura o remito de origen (opcional — para trazabilidad)
  facturaId       Int?

  empresaId       Int
  empresa         Empresa    @relation(fields: [empresaId], references: [id])

  createdAt       DateTime   @default(now())

  @@index([empresaId, tipo])
  @@index([clienteId])
  @@index([tipoEnvaseId])
  @@map("movimientos_envase")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ═══ FASE 1: MAESTROS CONTABLES PROFESIONALES ═══════════════════════════════
// ═══════════════════════════════════════════════════════════════════════════════

// ─── RUBRO CONTABLE (agrupación para estados financieros) ────────────────────
// Permite agrupar cuentas para presentación de Balance General (RT 8/9)
// y Estado de Resultados. Ejemplos: Disponibilidades, Créditos por Ventas,
// Bienes de Cambio, Bienes de Uso, Deudas Comerciales, Deudas Fiscales, etc.

model RubroContable {
  id          Int       @id @default(autoincrement())
  /// Código jerárquico: "1.1", "2.3", etc.
  codigo      String
  nombre      String
  /// "balance_general" | "estado_resultados" | "flujo_efectivo"
  tipoEstadoFinanciero String @default("balance_general")
  /// Orden de presentación en el estado financiero
  orden       Int       @default(0)
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])

  cuentas     CuentaContable[]

  @@unique([empresaId, codigo])
  @@map("rubros_contables")
}

// ─── TIPO DE ASIENTO ─────────────────────────────────────────────────────────
// Catálogo de tipos de asiento contable. Reemplaza el campo String 'tipo'
// en AsientoContable con un maestro parametrizable.

model TipoAsiento {
  id                  Int       @id @default(autoincrement())
  /// Código: "APERTURA", "DIARIO", "CIERRE", "AJUSTE", "RECLASIFICACION", etc.
  codigo              String
  nombre              String
  /// Si true, requiere aprobación de supervisor/contador
  requiereAprobacion  Boolean   @default(false)
  /// Si true, afecta cuentas de resultado (EERR)
  afectaResultado     Boolean   @default(true)
  /// Si true, es generado automáticamente por el sistema (no manual)
  esAutomatico        Boolean   @default(false)
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  empresaId           Int
  empresa             Empresa   @relation(fields: [empresaId], references: [id])

  asientos            AsientoContable[]
  plantillas          PlantillaAsiento[]

  @@unique([empresaId, codigo])
  @@map("tipos_asiento")
}

// ─── PLANTILLA DE ASIENTO ────────────────────────────────────────────────────
// Templates para asientos recurrentes: sueldos, amortizaciones, provisiones,
// ajuste por inflación. Permite generar asientos con un click.

model PlantillaAsiento {
  id              Int       @id @default(autoincrement())
  /// Código interno: "SUELDOS_MENSUAL", "AMORT_BU", "PROV_VACACIONES", etc.
  codigo          String
  nombre          String
  descripcion     String?
  /// "mensual" | "bimestral" | "trimestral" | "semestral" | "anual" | null (manual)
  periodicidad    String?
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])
  tipoAsientoId   Int?
  tipoAsiento     TipoAsiento? @relation(fields: [tipoAsientoId], references: [id])

  lineas          LineaPlantillaAsiento[]

  @@unique([empresaId, codigo])
  @@map("plantillas_asiento")
}

model LineaPlantillaAsiento {
  id              Int              @id @default(autoincrement())
  /// Código de cuenta contable (referencia al plan de la empresa)
  cuentaCodigo    String
  /// Nombre cache de la cuenta
  cuentaNombre    String?
  /// Fórmula o monto fijo para el debe. null = 0. Puede ser "PARAM_MONTO" para variable.
  debeFormula     String?
  /// Fórmula o monto fijo para el haber. null = 0.
  haberFormula    String?
  /// Orden de presentación
  orden           Int              @default(0)

  plantillaId     Int
  plantilla       PlantillaAsiento @relation(fields: [plantillaId], references: [id], onDelete: Cascade)

  @@map("lineas_plantilla_asiento")
}

// ─── TIPO DE COMPROBANTE (Catálogo AFIP) ─────────────────────────────────────
// Catálogo completo de tipos de comprobante según tabla AFIP WSFE.
// Permite parametrizar en vez de hardcodear códigos numéricos.

model TipoComprobanteMaestro {
  id              Int       @id @default(autoincrement())
  /// Código AFIP: 1, 2, 3, 6, 7, 8, 11, 12, 13, 19, 20, 21, 51, 201, 206, etc.
  codigoAfip      Int
  /// Letra: "A", "B", "C", "E", "M", "T"
  letra           String
  /// Nombre completo: "Factura A", "Nota de Crédito B", "Factura de Crédito Electrónica MiPyME A"
  nombre          String
  /// Abreviatura: "FA", "FB", "FC", "NCA", "NCB", "NCC", "NDA", "NDB"
  abreviatura     String
  /// Flags de tipo
  esFactura       Boolean   @default(false)
  esNotaCredito   Boolean   @default(false)
  esNotaDebito    Boolean   @default(false)
  esRecibo        Boolean   @default(false)
  esRemito        Boolean   @default(false)
  /// Si aplica para MiPyME (FCE)
  esFCE           Boolean   @default(false)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])
  facturas        Factura[]

  @@unique([empresaId, codigoAfip])
  @@map("tipos_comprobante_maestro")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ═══ FASE 2: MAESTROS FINANCIEROS COMPLETOS ═════════════════════════════════
// ═══════════════════════════════════════════════════════════════════════════════

// ─── TIPO DE RETENCIÓN ───────────────────────────────────────────────────────
// Catálogo de impuestos retenibles con norma legal de referencia.

model TipoRetencion {
  id          Int       @id @default(autoincrement())
  /// "IVA", "GANANCIAS", "IIBB", "SUSS"
  codigo      String
  nombre      String
  /// Norma legal: "RG 2854", "RG 830", "RG 3164", etc.
  normaLegal  String?
  /// "iva" | "ganancias" | "iibb" | "suss"
  impuesto    String
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])

  regimenes   RegimenRetencion[]

  @@unique([empresaId, codigo])
  @@map("tipos_retencion")
}

// ─── RÉGIMEN DE RETENCIÓN ────────────────────────────────────────────────────
// Detalle por régimen SICORE con alícuotas, mínimos y bases de cálculo.
// Reemplaza strings hardcoded en RetencionSICORE.

model RegimenRetencion {
  id                   Int       @id @default(autoincrement())
  /// Código SICORE: "217", "219", "305", "767", "779", etc.
  codigoSicore         String
  /// Concepto: "Operaciones venta de cosas muebles", "Locaciones de obra", etc.
  concepto             String
  descripcion          String?
  /// Alícuota para sujetos inscriptos (%)
  alicuotaInscripto    Decimal   @db.Decimal(5, 2)
  /// Alícuota para sujetos no inscriptos (%)
  alicuotaNoInscripto  Decimal   @default(0) @db.Decimal(5, 2)
  /// Monto mínimo no sujeto a retención
  minimoNoSujeto       Decimal   @default(0) @db.Decimal(18, 2)
  /// "neto" | "bruto" — base sobre la cual se calcula la retención
  baseCalculo          String    @default("neto")
  vigenciaDesde        DateTime  @db.Date
  vigenciaHasta        DateTime? @db.Date
  activo               Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tipoRetencionId      Int
  tipoRetencion        TipoRetencion @relation(fields: [tipoRetencionId], references: [id])
  empresaId            Int
  empresa              Empresa       @relation(fields: [empresaId], references: [id])

  retenciones          RetencionSICORE[]

  @@unique([empresaId, codigoSicore])
  @@map("regimenes_retencion")
}

// ─── TIPO DE MOVIMIENTO BANCARIO ─────────────────────────────────────────────
// Catálogo de tipos de movimiento con signo y flags operativos.

model TipoMovimientoBancario {
  id                  Int       @id @default(autoincrement())
  /// "DEPOSITO", "EXTRACCION", "TRANSF_EMITIDA", "TRANSF_RECIBIDA", etc.
  codigo              String
  nombre              String
  /// +1 para créditos (ingresos), -1 para débitos (egresos)
  signo               Int       @default(1)
  /// Si afecta el saldo de la cuenta bancaria
  afectaSaldo         Boolean   @default(true)
  /// Si requiere conciliación con extracto
  requiereConciliacion Boolean  @default(true)
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  empresaId           Int
  empresa             Empresa   @relation(fields: [empresaId], references: [id])

  movimientos         MovimientoBancario[]

  @@unique([empresaId, codigo])
  @@map("tipos_movimiento_bancario")
}

// ─── CONCEPTO DE COBRO/PAGO ──────────────────────────────────────────────────
// Parametriza los conceptos que componen un recibo o una orden de pago.

model ConceptoCobroPago {
  id                      Int       @id @default(autoincrement())
  /// "SALDO_FACTURA", "ANTICIPO", "SENA", "RET_IVA", "RET_GAN", etc.
  codigo                  String
  nombre                  String
  /// "cobro" | "pago" | "ambos"
  tipo                    String    @default("ambos")
  /// Si afecta el saldo de cuenta corriente del cliente/proveedor
  afectaCuentaCorriente   Boolean   @default(true)
  /// Si es un anticipo (pago antes de factura)
  esAnticipo              Boolean   @default(false)
  /// Si requiere factura asociada para su imputación
  requiereFactura         Boolean   @default(true)
  /// Código de cuenta contable asociada (para asiento automático)
  cuentaContableCodigo    String?
  activo                  Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  empresaId               Int
  empresa                 Empresa   @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, codigo])
  @@map("conceptos_cobro_pago")
}

// ─── PLAN DE CUOTAS ──────────────────────────────────────────────────────────
// Planes de financiación por forma de pago (ej: 3 cuotas sin interés con Visa).

model PlanCuotas {
  id                      Int       @id @default(autoincrement())
  nombre                  String
  /// Cantidad de cuotas (1, 3, 6, 12, 18, 24)
  cantidadCuotas          Int
  /// Tasa de interés mensual (0 = sin interés)
  tasaInteres             Decimal   @default(0) @db.Decimal(8, 4)
  /// Coeficiente multiplicador sobre el precio contado (1.0 = sin recargo)
  coeficienteMultiplicador Decimal  @default(1) @db.Decimal(8, 4)
  vigenciaDesde           DateTime? @db.Date
  vigenciaHasta           DateTime? @db.Date
  activo                  Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  formaPagoId             Int
  formaPago               FormaPago @relation(fields: [formaPagoId], references: [id])
  empresaId               Int
  empresa                 Empresa   @relation(fields: [empresaId], references: [id])

  @@map("planes_cuotas")
}

// ─── ENTIDAD FINANCIERA ──────────────────────────────────────────────────────
// Extiende el concepto de Banco para incluir fintech, billeteras y cobradores.
// Coexiste con el modelo Banco existente (paralelo, no reemplazo).

model EntidadFinanciera {
  id          Int       @id @default(autoincrement())
  /// Código identificador: "MP" (MercadoPago), "UALA", "NX" (Naranja X), etc.
  codigo      String
  nombre      String
  /// "banco" | "fintech" | "billetera_virtual" | "cobrador_externo" | "procesador_tarjeta"
  tipo        String    @default("banco")
  /// Prefijo CBU/CVU para identificación automática
  cbuPrefijo  String?
  /// CUIT de la entidad (para retenciones)
  cuit        String?
  /// Comisión por defecto (%)
  comisionPct Decimal   @default(0) @db.Decimal(5, 2)
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, codigo])
  @@map("entidades_financieras")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ═══ FASE 3: MAESTROS OPERACIONALES ═════════════════════════════════════════
// ═══════════════════════════════════════════════════════════════════════════════

// ─── SUCURSAL ────────────────────────────────────────────────────────────────
// Entidad branch real. Diferente de PuntoVentaConfig (que es AFIP/fiscal).

model Sucursal {
  id              Int       @id @default(autoincrement())
  /// Código corto: "CASA_CENTRAL", "SUC_NORTE", "SUC_SUR"
  codigo          String
  nombre          String
  direccion       String?
  telefono        String?
  email           String?
  /// Si es la sucursal principal / casa central
  esMatriz        Boolean   @default(false)
  /// Responsable de la sucursal (Usuario)
  responsableId   Int?
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  localidadId     Int?
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  depositos       Deposito[]
  cajasTipo       CajaTipo[]
  cajas           Caja[]    @relation("CajaSucursal")

  @@unique([empresaId, codigo])
  @@map("sucursales")
}

// ─── COBRADOR ────────────────────────────────────────────────────────────────
// Agente de cobranza separado de Vendedor. Gestiona recibos y cobranzas.

model Cobrador {
  id              Int       @id @default(autoincrement())
  /// Código: "COB01", "COB02"
  codigo          String
  nombre          String
  email           String?
  telefono        String?
  /// Porcentaje de comisión sobre montos cobrados
  comisionPct     Decimal   @default(0) @db.Decimal(5, 2)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  /// Usuario del sistema asociado (opcional)
  usuarioId       Int?
  /// Zona geográfica asignada
  zonaGeograficaId Int?
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  recibos         Recibo[]

  @@unique([empresaId, codigo])
  @@map("cobradores")
}

// ─── TIPO DE OPERACIÓN COMERCIAL ─────────────────────────────────────────────
// Parametriza operaciones: venta mostrador, mayorista, devolución, consignación.

model TipoOperacionComercial {
  id                      Int       @id @default(autoincrement())
  /// "VENTA_MOSTRADOR", "VENTA_MAYORISTA", "DEVOLUCION", "BONIFICACION", etc.
  codigo                  String
  nombre                  String
  /// "venta" | "compra" | "devolucion" | "bonificacion" | "consignacion" | "muestra"
  tipo                    String    @default("venta")
  /// Si la operación afecta stock (movimiento entrada/salida)
  afectaStock             Boolean   @default(true)
  /// Si la operación genera/cancela cuenta corriente
  afectaCuentaCorriente   Boolean   @default(true)
  /// Si requiere aprobación de supervisor
  requiereAprobacion      Boolean   @default(false)
  /// Tipo de comprobante AFIP por defecto para esta operación
  tipoComprobanteDefaultId Int?
  activo                  Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  empresaId               Int
  empresa                 Empresa   @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, codigo])
  @@map("tipos_operacion_comercial")
}

// ─── TIPO DE CAJA ────────────────────────────────────────────────────────────
// Principal, secundaria, fondo fijo, caja chica. Define reglas de arqueo.

model CajaTipo {
  id              Int       @id @default(autoincrement())
  /// "PRINCIPAL", "SECUNDARIA", "FONDO_FIJO", "CHICA"
  codigo          String
  nombre          String
  /// "principal" | "secundaria" | "fondo_fijo" | "chica"
  tipo            String    @default("principal")
  /// Monto máximo permitido (0 = sin límite)
  montoMaximo     Decimal   @default(0) @db.Decimal(18, 2)
  /// Si requiere arqueo al cierre
  requiereArqueo  Boolean   @default(true)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sucursalId      Int?
  sucursal        Sucursal? @relation(fields: [sucursalId], references: [id])
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  cajas           Caja[]    @relation("CajaCajaTipo")

  @@unique([empresaId, codigo])
  @@map("cajas_tipo")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ═══ FASE 4: INFRAESTRUCTURA DE ESCALABILIDAD ═══════════════════════════════
// ═══════════════════════════════════════════════════════════════════════════════

// ─── CAMPO PERSONALIZADO (EAV Pattern) ───────────────────────────────────────
// Permite agregar campos dinámicos a CUALQUIER entidad sin migración de schema.
// El usuario final puede crear campos tipo texto, número, fecha, select, etc.

model CampoPersonalizado {
  id              Int       @id @default(autoincrement())
  /// Entidad destino: "cliente", "producto", "proveedor", "factura", "compra", etc.
  entidad         String
  /// Nombre interno del campo (camelCase, sin espacios)
  nombreCampo     String
  /// Etiqueta visible en formularios
  etiqueta        String
  /// "texto" | "numero" | "fecha" | "booleano" | "select" | "multiselect" | "textarea" | "email" | "url"
  tipoDato        String    @default("texto")
  /// JSON: opciones para select/multiselect. Ej: ["Zona Norte", "Zona Sur", "Zona Oeste"]
  opciones        Json?
  /// Si el campo es obligatorio
  obligatorio     Boolean   @default(false)
  /// Orden de presentación en el formulario
  orden           Int       @default(0)
  /// Si se muestra en listados/tablas
  visibleEnLista  Boolean   @default(false)
  /// Si se muestra en el formulario de edición
  visibleEnFormulario Boolean @default(true)
  /// Valor por defecto (string serializado)
  valorDefault    String?
  /// Placeholder del campo
  placeholder     String?
  /// Texto de ayuda
  ayuda           String?
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  valores         ValorCampoPersonalizado[]

  @@unique([empresaId, entidad, nombreCampo])
  @@index([empresaId, entidad])
  @@map("campos_personalizados")
}

// ─── VALOR DE CAMPO PERSONALIZADO ────────────────────────────────────────────
// Almacena el valor tipado del campo para cada entidad específica.
// Usa columnas separadas por tipo (EAV pattern con tipado) para mejor performance.

model ValorCampoPersonalizado {
  id              Int       @id @default(autoincrement())
  /// ID de la entidad (UUID o Int serializado como String)
  entidadId       String
  /// Valores tipados (usar el que corresponda al tipoDato del campo)
  valorTexto      String?
  valorNumero     Decimal?  @db.Decimal(18, 4)
  valorFecha      DateTime?
  valorBooleano   Boolean?
  /// Para select múltiple u objetos complejos
  valorJson       Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  campoId         Int
  campo           CampoPersonalizado @relation(fields: [campoId], references: [id], onDelete: Cascade)

  @@unique([campoId, entidadId])
  @@index([entidadId])
  @@map("valores_campo_personalizado")
}

// ─── TABLA AUXILIAR (Catálogos genéricos) ────────────────────────────────────
// Permite al usuario crear catálogos sin tocar código: "Origen del Lead",
// "Tipo de Envío", "Categoría de Gasto", etc.

model TablaAuxiliar {
  id              Int       @id @default(autoincrement())
  /// Código único: "ORIGEN_LEAD", "TIPO_ENVIO", "CAT_GASTO"
  codigo          String
  nombre          String
  descripcion     String?
  /// Si true, es un catálogo del sistema (protegido contra eliminación)
  esDelSistema    Boolean   @default(false)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  valores         ValorAuxiliar[]

  @@unique([empresaId, codigo])
  @@map("tablas_auxiliares")
}

model ValorAuxiliar {
  id              Int            @id @default(autoincrement())
  /// Código del valor: "WEB", "TELEFONO", "REFERIDO"
  codigo          String
  nombre          String
  descripcion     String?
  /// Orden de presentación
  orden           Int            @default(0)
  /// Datos adicionales (JSON libre para extensibilidad)
  metadata        Json?
  activo          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tablaAuxiliarId Int
  tablaAuxiliar   TablaAuxiliar  @relation(fields: [tablaAuxiliarId], references: [id], onDelete: Cascade)

  @@unique([tablaAuxiliarId, codigo])
  @@map("valores_auxiliar")
}

// ─── CONFIGURACIÓN DE CAMPO POR EMPRESA ──────────────────────────────────────
// Permite por empresa definir qué campos nativos son visibles, obligatorios
// o de solo lectura en cada formulario. Personalización sin código.

model ConfiguracionCampo {
  id              Int       @id @default(autoincrement())
  /// Entidad: "cliente", "producto", "proveedor", "factura"
  entidad         String
  /// Nombre del campo nativo: "cuit", "direccion", "limiteCredito"
  campo           String
  /// Si el campo es visible en el formulario
  visible         Boolean   @default(true)
  /// Si el campo es obligatorio
  obligatorio     Boolean   @default(false)
  /// Si el campo es de solo lectura
  soloLectura     Boolean   @default(false)
  /// Valor por defecto
  valorDefault    String?
  /// Orden de presentación (override del orden natural)
  orden           Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, entidad, campo])
  @@map("configuraciones_campo")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ═══ SPRINT IMPUESTOS — TAX ENGINEERING ══════════════════════════════════════
// ═══════════════════════════════════════════════════════════════════════════════
// Modelos que cierran las brechas fiscales críticas para AFIP compliance:
// TributoFactura/TributoCompra (WSFE Tributos[]), PadronRegimenProveedor,
// RegimenPercepcion, RetencionRecibo, DeclaracionJurada.

// ─── TRIBUTO FACTURA ────────────────────────────────────────────────────────
// Cada factura de venta puede incluir múltiples tributos adicionales
// (percepciones IIBB, percepción IVA, impuestos internos, municipales).
// Mapea 1:1 al array Tributos[] del WSFE FECAESolicitar.

model TributoFactura {
  id              Int       @id @default(autoincrement())
  /// Código AFIP tributo: 1=Imp.Nacional, 2=Imp.Provincial, 3=Imp.Municipal, 4=Imp.Interno, 99=Otro
  codigoAfip      Int
  /// Descripción legible: "Percepción IIBB ARBA", "Percepción IVA RG 2408", etc.
  descripcion     String
  /// Base imponible sobre la cual se calcula el tributo
  baseImponible   Decimal   @db.Decimal(15,2)
  /// Alícuota aplicada (porcentaje, ej: 3.5)
  alicuota        Float
  /// Importe resultante del tributo
  importe         Decimal   @db.Decimal(15,2)
  /// Jurisdicción (para IIBB): "PBA", "CABA", "SF", etc.
  jurisdiccion    String?
  /// Referencia al organismo: "ARBA", "AGIP", "AFIP", etc.
  organismo       String?

  facturaId       Int
  factura         Factura   @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])
  /// Régimen de percepción que originó este tributo (opcional)
  regimenPercepcionId Int?
  regimenPercepcion   RegimenPercepcion? @relation("tributosFacturaPercepcion", fields: [regimenPercepcionId], references: [id])

  @@map("tributos_factura")
}

// ─── TRIBUTO COMPRA ─────────────────────────────────────────────────────────
// Tributos adicionales incluidos en facturas de proveedor (percepciones sufridas).
// Se usan para computar crédito fiscal de percepciones IIBB e IVA.

model TributoCompra {
  id              Int       @id @default(autoincrement())
  /// Código AFIP tributo: 1=Nacional, 2=Provincial, 3=Municipal, 4=Interno, 99=Otro
  codigoAfip      Int
  descripcion     String
  baseImponible   Decimal   @db.Decimal(15,2)
  alicuota        Float
  importe         Decimal   @db.Decimal(15,2)
  jurisdiccion    String?
  organismo       String?

  compraId        Int
  compra          Compra    @relation(fields: [compraId], references: [id], onDelete: Cascade)
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])
  /// Régimen de percepción sufrida
  regimenPercepcionId Int?
  regimenPercepcion   RegimenPercepcion? @relation("tributosCompraPercepcion", fields: [regimenPercepcionId], references: [id])

  @@map("tributos_compra")
}

// ─── RÉGIMEN DE PERCEPCIÓN ──────────────────────────────────────────────────
// Maestro de regímenes de percepción (IVA RG 2408, IIBB ARBA, IIBB AGIP, etc.)
// Define alícuotas base, mínimos no sujetos y vigencia.

model RegimenPercepcion {
  id                   Int       @id @default(autoincrement())
  /// Código único: "PERC_IVA_2408", "PERC_IIBB_ARBA", "PERC_IIBB_AGIP", etc.
  codigo               String
  nombre               String
  /// "percepcion_iva" | "percepcion_iibb" | "percepcion_municipal"
  tipo                 String
  /// Impuesto: "IVA" | "IIBB" | "MUNICIPAL"
  impuesto             String
  /// Organismo: "AFIP" | "ARBA" | "AGIP" | "DGR_SF" | "DGR_CBA"
  organismo            String
  /// Jurisdicción (para IIBB): "PBA", "CABA", "SF", "CBA", etc.
  jurisdiccion         String?
  /// Alícuota general para inscriptos (%)
  alicuotaInscripto    Decimal   @db.Decimal(5, 2)
  /// Alícuota para no inscriptos (%)
  alicuotaNoInscripto  Decimal   @default(0) @db.Decimal(5, 2)
  /// Monto mínimo no sujeto a percepción
  minimoNoSujeto       Decimal   @default(0) @db.Decimal(18, 2)
  /// Norma legal: "RG 2408", "DN B 1/2004", etc.
  normaLegal           String?
  /// "neto" | "total" — base sobre la cual se calcula la percepción
  baseCalculo          String    @default("neto")
  vigenciaDesde        DateTime  @db.Date
  vigenciaHasta        DateTime? @db.Date
  activo               Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  empresaId            Int
  empresa              Empresa   @relation(fields: [empresaId], references: [id])

  tributosFactura      TributoFactura[]  @relation("tributosFacturaPercepcion")
  tributosCompra       TributoCompra[]   @relation("tributosCompraPercepcion")

  @@unique([empresaId, codigo])
  @@map("regimenes_percepcion")
}

// ─── PADRÓN RÉGIMEN PROVEEDOR ───────────────────────────────────────────────
// Espejo de PadronRegimenCliente pero para proveedores.
// Cuando la empresa es agente de retención IIBB, necesita consultar la alícuota
// del proveedor según padrón provincial (ARBA, AGIP, DGR).

model PadronRegimenProveedor {
  id              Int       @id @default(autoincrement())
  /// "retencion_iibb" | "retencion_iva" | "retencion_ganancias"
  tipoRegimen     String
  /// Organismo: "ARBA", "AGIP", "DGR_SF", etc.
  organismo       String
  jurisdiccion    String
  /// Alícuota asignada al proveedor según padrón (0 = excluido)
  alicuota        Decimal   @db.Decimal(5, 2)
  vigenciaDesde   DateTime  @db.Date
  vigenciaHasta   DateTime? @db.Date
  /// CUIT del proveedor (para lookup rápido sin JOIN)
  cuitSujeto      String
  /// Marca tipo: "AG" = agente, "EX" = excluido, "NI" = no inscripto
  marcaSujeto     String?
  createdAt       DateTime  @default(now())

  proveedorId     Int
  proveedor       Proveedor @relation(fields: [proveedorId], references: [id])
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@index([cuitSujeto, organismo])
  @@map("padron_regimen_proveedor")
}

// ─── RETENCIÓN RECIBO (detalle) ─────────────────────────────────────────────
// Detalle de retenciones sufridas en cobros (cuando el cliente es agente de retención).
// Complementa los campos flat de Recibo (retencionIVA, retencionGanancias, retencionIIBB)
// con la información necesaria para SIRE RG 5577.

model RetencionRecibo {
  id              Int       @id @default(autoincrement())
  /// "IVA" | "GANANCIAS" | "IIBB" | "SUSS"
  tipo            String
  /// Código SICORE/régimen del retenedor
  codigoRegimen   String?
  /// Base imponible de la retención
  base            Decimal   @db.Decimal(18, 2)
  /// Alícuota aplicada
  alicuota        Decimal   @db.Decimal(5, 2)
  /// Monto retenido
  monto           Decimal   @db.Decimal(18, 2)
  /// Número de constancia/certificado emitido por el agente
  numeroCertificado String?
  /// Fecha de la retención
  fechaRetencion  DateTime  @default(now())
  /// Jurisdicción (para IIBB)
  jurisdiccion    String?
  /// CUIT del agente de retención (el cliente)
  cuitAgente      String?

  reciboId        Int
  recibo          Recibo    @relation(fields: [reciboId], references: [id], onDelete: Cascade)
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@map("retenciones_recibo")
}

// ─── DECLARACIÓN JURADA ─────────────────────────────────────────────────────
// Tracking de presentaciones de DDJJ fiscales: IVA mensual, IIBB por jurisdicción,
// SICORE, CM03/CM05. Estado de cada presentación y número de VEP.

model DeclaracionJurada {
  id              Int       @id @default(autoincrement())
  /// "IVA" | "IIBB" | "SICORE" | "CONVENIO_MULTILATERAL" | "SIRE"
  tipo            String
  /// Período: YYYYMM (ej: "202604")
  periodo         String
  /// Jurisdicción (para IIBB): "PBA", "CABA", etc. Null para nacionales.
  jurisdiccion    String?
  /// "borrador" | "generada" | "presentada" | "rectificativa" | "anulada"
  estado          String    @default("borrador")
  /// Número de VEP (Volante Electrónico de Pago)
  vepNumero       String?
  /// Monto total determinado
  montoTotal      Decimal   @default(0) @db.Decimal(18, 2)
  /// Monto de saldo a favor del período anterior
  saldoFavorAnterior Decimal @default(0) @db.Decimal(18, 2)
  /// Monto a pagar resultante
  montoAPagar     Decimal   @default(0) @db.Decimal(18, 2)
  /// Fecha de presentación
  fechaPresentacion DateTime?
  /// Fecha de vencimiento
  fechaVencimiento  DateTime?
  /// Número de rectificativa (0 = original, 1 = 1ra rectif, etc.)
  nroRectificativa  Int     @default(0)
  /// JSON con hash del contenido para auditoría
  hashContenido     String?
  observaciones     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  empresaId         Int
  empresa           Empresa  @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, tipo, periodo, jurisdiccion, nroRectificativa])
  @@map("declaraciones_juradas")
}


// ══════════════════════════════════════════════════════════════════════════════
// ═══ CONFIGURACIÓN DINÁMICA POR RUBRO — RAILROAD SWITCH ENGINE ══════════════
// ══════════════════════════════════════════════════════════════════════════════

// ─── CONFIGURACIÓN DE RUBRO (template por sector) ────────────────────────────
// Define qué features se activan por defecto para cada rubro.
// Cuando una empresa se da de alta, se copian estos registros a FeatureEmpresa.

model ConfiguracionRubro {
  id              Int       @id @default(autoincrement())
  /// Feature key normalizada: "pos", "stock", "kds", "facturacion_afip",
  ///   "agentes_ia", "bom_produccion", "historia_clinica", "membresias",
  ///   "picking_warehouse", "iot_sensores", "conciliacion_bancaria", etc.
  featureKey      String
  /// ¿Activada por defecto al crear empresa de este rubro?
  activado        Boolean   @default(true)
  /// ¿Modo simplificado? (ej: contabilidad simplificada para kiosco)
  modoSimplificado Boolean  @default(false)
  /// Orden de presentación en UI
  orden           Int       @default(0)
  /// Label legible para UI
  label           String?
  /// Descripción de qué hace esta feature
  descripcion     String?
  /// Icono para la UI
  icono           String?
  /// Grupo funcional: "core", "fiscal", "vertical", "integracion", "ia"
  grupo           String    @default("core")
  /// Parámetros por defecto del rubro como JSON
  /// Ej: {"umbralAlerta": 10, "diasCobranza": 30, "requiereBOM": true}
  parametros      Json?
  /// Condiciones de activación como JSON
  /// Ej: {"condicionIva": "Responsable Inscripto"} → solo si es RI
  condiciones     Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  rubroId         Int
  rubro           Rubro     @relation(fields: [rubroId], references: [id])

  @@unique([rubroId, featureKey])
  @@index([rubroId, grupo])
  @@map("configuracion_rubro")
}

// ─── FEATURE POR RUBRO (catálogo global de features) ─────────────────────────
// Catálogo maestro de todas las features disponibles del ERP.
// Cada rubro selecciona cuáles activar por defecto.

model FeatureRubro {
  id                Int       @id @default(autoincrement())
  /// Key normalizada (misma que ConfiguracionRubro.featureKey)
  featureKey        String
  /// Grupo funcional: "core", "fiscal", "vertical", "integracion", "ia"
  grupo             String    @default("core")
  /// Orden de presentación
  orden             Int       @default(0)
  /// Label legible
  label             String
  descripcion       String?
  icono             String?
  /// ¿Se activa por defecto para este rubro?
  activadoPorDefecto Boolean  @default(false)
  /// ¿Permite modo simplificado?
  permiteModoSimplificado Boolean @default(false)
  /// JSON schema de los parámetros configurables de esta feature
  /// Ej: {"type":"object","properties":{"diasCobranza":{"type":"number","default":30}}}
  schemaParametros  Json?

  rubroId           Int
  rubro             Rubro     @relation(fields: [rubroId], references: [id])

  @@unique([rubroId, featureKey])
  @@map("features_rubro")
}

// ─── FEATURE POR EMPRESA (override de empresa sobre rubro) ───────────────────
// La empresa puede activar/desactivar/personalizar features de su rubro.
// Si no existe registro para una featureKey, se hereda de ConfiguracionRubro.

model FeatureEmpresa {
  id              Int       @id @default(autoincrement())
  featureKey      String
  /// Override de activación (null = heredar del rubro)
  activado        Boolean   @default(true)
  /// Override de modo simplificado
  modoSimplificado Boolean  @default(false)
  /// Parámetros personalizados de la empresa (merge con defaults del rubro)
  parametros      Json?
  /// Notas internas
  notas           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, featureKey])
  @@index([empresaId])
  @@map("features_empresa")
}


// ══════════════════════════════════════════════════════════════════════════════
// ═══ WORKFLOW ENGINE — MOTOR DE FLUJOS DINÁMICOS (RAILROAD SWITCH) ═══════════
// ══════════════════════════════════════════════════════════════════════════════

// ─── WORKFLOW POR RUBRO (template de flujos) ─────────────────────────────────
// Define los flujos completos por proceso de negocio y rubro.
// Ej: "venta_gastronomia" tiene pasos: comanda→kds→cuenta→factura→cobro
//     "venta_distribucion" tiene: pedido→picking→remito→factura→cc→cobro

model WorkflowRubro {
  id          Int       @id @default(autoincrement())
  /// Clave del proceso: "venta", "compra", "cobro", "produccion", "turno_medico"
  proceso     String
  /// Nombre legible: "Flujo de Venta Gastronomía"
  nombre      String
  descripcion String?
  /// Versión del workflow (para evolucionar sin romper instancias en vuelo)
  version     Int       @default(1)
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  rubroId     Int
  rubro       Rubro     @relation(fields: [rubroId], references: [id])

  pasos       WorkflowStep[]

  @@unique([rubroId, proceso, version])
  @@index([rubroId, proceso])
  @@map("workflow_rubro")
}

// ─── PASO DEL WORKFLOW ───────────────────────────────────────────────────────
// Cada step es un nodo en el grafo del flujo.

model WorkflowStep {
  id              Int       @id @default(autoincrement())
  /// Key interna: "crear_comanda", "emitir_factura", "generar_asiento", "enviar_whatsapp"
  stepKey         String
  /// Nombre legible: "Emitir Factura AFIP"
  nombre          String
  /// Tipo de acción:
  /// "service_call" → invoca un servicio TypeScript
  /// "event_emit"   → emite un evento al event bus
  /// "condition"    → bifurcación condicional (railroad switch)
  /// "approval"     → requiere aprobación de usuario
  /// "timer"        → espera N minutos/horas
  /// "webhook"      → llama endpoint externo
  tipo            String    @default("service_call")
  /// Referencia al servicio/handler a ejecutar
  /// Ej: "facturaService.emitirFactura", "asientoService.generarAsientoVenta"
  accion          String?
  /// Orden secuencial dentro del workflow
  orden           Int       @default(0)
  /// ¿Se puede desactivar por empresa?
  desactivable    Boolean   @default(true)
  /// ¿Es obligatorio (no se puede saltar)?
  obligatorio     Boolean   @default(true)
  /// Parámetros del paso como JSON
  /// Ej: {"tipoCbte": 1, "puntoVenta": 1} para facturación
  parametros      Json?
  /// Condición de ejecución como JSON (evaluada en runtime)
  /// Ej: {"campo": "total", "operador": ">", "valor": 50000}
  condicion       Json?
  /// Feature requerida (si la feature no está activa, se salta el paso)
  requiereFeature String?
  /// Timeout en segundos (0 = sin timeout)
  timeoutSeg      Int       @default(0)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workflowId      Int
  workflow        WorkflowRubro @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  transicionesSalida  WorkflowTransition[] @relation("TransicionOrigen")
  transicionesEntrada WorkflowTransition[] @relation("TransicionDestino")

  @@unique([workflowId, stepKey])
  @@index([workflowId, orden])
  @@map("workflow_steps")
}

// ─── TRANSICIÓN ENTRE PASOS ──────────────────────────────────────────────────
// Define las "vías del tren" — las posibles rutas entre pasos.
// Permite bifurcaciones (railroad switch) con condiciones.

model WorkflowTransition {
  id              Int       @id @default(autoincrement())
  /// Label de la transición: "siguiente", "aprobado", "rechazado", "error", "timeout"
  label           String    @default("siguiente")
  /// Condición JSON para tomar esta vía
  /// Ej: {"campo": "rubro", "operador": "==", "valor": "gastronomia"}
  /// Si null, es la transición por defecto (siempre se toma)
  condicion       Json?
  /// Prioridad de evaluación (menor = primero). Si 2 condiciones matchean, gana la de menor prioridad.
  prioridad       Int       @default(0)
  activo          Boolean   @default(true)

  origenId        Int
  origen          WorkflowStep @relation("TransicionOrigen", fields: [origenId], references: [id], onDelete: Cascade)
  destinoId       Int
  destino         WorkflowStep @relation("TransicionDestino", fields: [destinoId], references: [id], onDelete: Cascade)

  @@index([origenId, prioridad])
  @@map("workflow_transitions")
}

// ─── INSTANCIA DE WORKFLOW (ejecución en vuelo) ──────────────────────────────
// Cada vez que se ejecuta un flujo (ej: una venta), se crea una instancia
// que trackea el estado actual y el historial de pasos ejecutados.

model WorkflowInstancia {
  id              Int       @id @default(autoincrement())
  /// Proceso: "venta", "compra", etc.
  proceso         String
  /// Versión del workflow template usado
  version         Int       @default(1)
  /// "en_curso" | "completado" | "error" | "cancelado" | "pausado"
  estado          String    @default("en_curso")
  /// Step key en el que se encuentra actualmente
  stepActual      String?
  /// Referencia a la entidad que disparó el workflow
  /// Ej: facturaId, pedidoId, compraId
  entidadTipo     String?
  entidadId       Int?
  /// Contexto acumulado del workflow como JSON
  /// Se enriquece en cada paso: {total: 50000, clienteId: 1, cae: "xxx"}
  contexto        Json?
  /// Error si estado == "error"
  error           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  pasoLog         WorkflowPasoLog[]

  @@index([empresaId, proceso, estado])
  @@index([entidadTipo, entidadId])
  @@map("workflow_instancias")
}

// ─── LOG DE EJECUCIÓN DE PASO ────────────────────────────────────────────────
// Audit trail de cada paso ejecutado dentro de una instancia.

model WorkflowPasoLog {
  id              Int       @id @default(autoincrement())
  stepKey         String
  /// "ejecutado" | "saltado" | "error" | "timeout" | "rollback"
  resultado       String
  /// Duración en ms
  duracionMs      Int?
  /// Input que recibió el paso
  input           Json?
  /// Output que devolvió el paso
  output          Json?
  /// Error si resultado == "error"
  error           String?   @db.Text
  createdAt       DateTime  @default(now())

  instanciaId     Int
  instancia       WorkflowInstancia @relation(fields: [instanciaId], references: [id], onDelete: Cascade)

  @@index([instanciaId, createdAt])
  @@map("workflow_paso_log")
}


// ═══════════════════════════════════════════════════════════════════════════════
// GAP CLOSURE — Modelos faltantes para completitud operativa
// ═══════════════════════════════════════════════════════════════════════════════

// ─── TOMA DE INVENTARIO ─────────────────────────────────────────────────────
// Conteo físico de stock con conciliación contra sistema

model TomaInventario {
  id              Int       @id @default(autoincrement())
  numero          String
  fecha           DateTime  @default(now())
  estado          String    @default("borrador") // borrador | en_conteo | procesada | anulada
  observaciones   String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  depositoId      Int
  empresaId       Int

  lineas          LineaTomaInventario[]

  @@index([empresaId, estado])
  @@map("tomas_inventario")
}

model LineaTomaInventario {
  id                Int       @id @default(autoincrement())
  stockSistema      Float     // Cantidad que indica el sistema
  stockContado      Float?    // Cantidad contada físicamente
  diferencia        Float?    // contado - sistema (calculado al procesar)
  observaciones     String?

  productoId        Int
  tomaInventarioId  Int
  tomaInventario    TomaInventario @relation(fields: [tomaInventarioId], references: [id], onDelete: Cascade)

  @@map("lineas_toma_inventario")
}

// ─── ARQUEO DE CAJA ─────────────────────────────────────────────────────────
// Registro formal de reconciliación al cierre de caja

model ArqueoCaja {
  id                    Int       @id @default(autoincrement())
  fecha                 DateTime  @default(now())
  /// Montos declarados por el cajero
  efectivoDeclarado     Float     @default(0)
  tarjetaDeclarado      Float     @default(0)
  transferenciaDeclarado Float    @default(0)
  chequeDeclarado       Float     @default(0)
  qrDeclarado           Float     @default(0)
  /// Montos según sistema
  efectivoSistema       Float     @default(0)
  tarjetaSistema        Float     @default(0)
  transferenciaSistema  Float     @default(0)
  chequeSistema         Float     @default(0)
  qrSistema             Float     @default(0)
  /// Diferencia total
  diferencia            Float     @default(0)
  justificacion         String?   @db.Text
  estado                String    @default("pendiente") // pendiente | aprobado | con_diferencia
  aprobadoPor           Int?
  createdAt             DateTime  @default(now())

  cajaId                Int
  empresaId             Int

  @@index([empresaId, fecha])
  @@map("arqueos_caja")
}

// ─── CONCILIACIÓN BANCARIA ──────────────────────────────────────────────────
// Persistencia de resultados de conciliación auto-match

model ConciliacionBancaria {
  id              Int       @id @default(autoincrement())
  fecha           DateTime  @default(now())
  periodo         String    // "2025-06" (mes conciliado)
  estado          String    @default("borrador") // borrador | confirmada
  totalConciliado Float     @default(0)
  totalPendiente  Float     @default(0)
  itemsConciliados Int      @default(0)
  itemsPendientes  Int      @default(0)
  observaciones   String?   @db.Text
  createdAt       DateTime  @default(now())

  cuentaBancariaId Int
  empresaId        Int
  lineas           LineaConciliacion[]

  @@index([empresaId, cuentaBancariaId])
  @@map("conciliaciones_bancarias")
}

model LineaConciliacion {
  id                    Int       @id @default(autoincrement())
  /// Referencia al movimiento del extracto bancario
  extractoRef           String?
  extractoFecha         DateTime?
  extractoMonto         Float?
  extractoDescripcion   String?
  /// Referencia al movimiento del sistema
  movimientoBancarioId  Int?
  /// Confianza del match (0-1)
  confianza             Float?
  /// Estado: conciliado | pendiente_sistema | pendiente_extracto
  estado                String

  conciliacionId        Int
  conciliacion          ConciliacionBancaria @relation(fields: [conciliacionId], references: [id], onDelete: Cascade)

  @@map("lineas_conciliacion")
}

// ─── ENDOSO DE CHEQUE ───────────────────────────────────────────────────────
// Cadena de custodia de cheques de terceros

model EndosoCheque {
  id              Int       @id @default(autoincrement())
  fecha           DateTime  @default(now())
  /// A quién se endosa (proveedor / tercero)
  endosadoA       String
  cuitEndosatario String?
  motivo          String?
  createdAt       DateTime  @default(now())

  chequeId        Int
  empresaId       Int

  @@index([chequeId])
  @@map("endosos_cheque")
}

// ─── EJERCICIO CONTABLE ─────────────────────────────────────────────────────
// Cierre de ejercicio con asiento de refundición

model EjercicioContable {
  id              Int       @id @default(autoincrement())
  nombre          String    // "Ejercicio 2025"
  fechaInicio     DateTime  @db.Date
  fechaFin        DateTime  @db.Date
  estado          String    @default("abierto") // abierto | en_cierre | cerrado
  asientoCierreId Int?      // Asiento de refundición generado
  observaciones   String?   @db.Text
  cerradoPor      Int?
  fechaCierre     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int

  @@index([empresaId, estado])
  @@map("ejercicios_contables")
}

// ─── AJUSTE POR INFLACIÓN (RT 6) ───────────────────────────────────────────
// Obligatorio en Argentina para EECC en moneda homogénea

model AjusteInflacion {
  id              Int       @id @default(autoincrement())
  periodo         String    // "2025-06"
  indice          String    @default("IPC") // IPC | IPIM
  coeficiente     Float     // Coeficiente de ajuste del período
  totalAjuste     Float     // Resultado neto del ajuste
  estado          String    @default("borrador") // borrador | aplicado
  asientoId       Int?      // Asiento generado por el ajuste
  createdAt       DateTime  @default(now())

  empresaId       Int

  @@index([empresaId, periodo])
  @@map("ajustes_inflacion")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ██  MÓDULOS DIFERENCIADORES vs SAP/TANGO/COLPPY  ██
// ═══════════════════════════════════════════════════════════════════════════════

// ─── APROBACIONES MULTI-NIVEL ─────────────────────────────────────────────────
// Cadena de aprobaciones configurable (compras, pagos, gastos, NC)
// Diferenciador SAP Business One + Tango Premium

model CadenaAprobacion {
  id              Int       @id @default(autoincrement())
  nombre          String    // "Aprobación OC > 50k"
  entidad         String    // "orden_compra" | "orden_pago" | "nota_credito" | "gasto" | "ajuste_stock"
  montoMinimo     Float     @default(0)
  montoMaximo     Float?    // null = sin límite
  activa          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int
  niveles         NivelAprobacion[]

  @@index([empresaId, entidad])
  @@map("cadenas_aprobacion")
}

model NivelAprobacion {
  id              Int       @id @default(autoincrement())
  cadenaId        Int
  cadena          CadenaAprobacion @relation(fields: [cadenaId], references: [id], onDelete: Cascade)
  orden           Int       // 1, 2, 3...
  rol             String    // "supervisor" | "gerente" | "director" | "cfo"
  usuarioId       Int?      // Si es usuario fijo (null = cualquier usuario con ese rol)
  plazoHoras      Int       @default(48) // Plazo máximo para aprobar
  accionVencido   String    @default("escalar") // "escalar" | "rechazar" | "auto_aprobar"

  @@index([cadenaId, orden])
  @@map("niveles_aprobacion")
}

model SolicitudAprobacion {
  id              Int       @id @default(autoincrement())
  cadenaId        Int
  entidad         String    // "orden_compra"
  entidadId       Int       // ID del registro
  estado          String    @default("pendiente") // pendiente | aprobado | rechazado | vencido
  nivelActual     Int       @default(1)
  solicitanteId   Int       // Usuario que creó la solicitud
  monto           Float
  descripcion     String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completadoAt    DateTime?

  empresaId       Int
  pasos           PasoAprobacion[]

  @@index([empresaId, estado])
  @@index([empresaId, entidad, entidadId])
  @@map("solicitudes_aprobacion")
}

model PasoAprobacion {
  id              Int       @id @default(autoincrement())
  solicitudId     Int
  solicitud       SolicitudAprobacion @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  nivel           Int
  aprobadorId     Int?      // Usuario que aprobó/rechazó
  accion          String    // "aprobado" | "rechazado" | "escalado" | "auto_aprobado"
  comentario      String?   @db.Text
  fechaAccion     DateTime  @default(now())

  @@index([solicitudId])
  @@map("pasos_aprobacion")
}

// ─── CONTROL PRESUPUESTARIO ──────────────────────────────────────────────────
// Presupuesto por centro de costo / cuenta contable con alerta de desvío
// Diferenciador SAP FI-CO + Tango Presupuestos

model PresupuestoGasto {
  id              Int       @id @default(autoincrement())
  nombre          String    // "Presupuesto Operativo 2026"
  ejercicio       Int       // 2026
  tipo            String    @default("anual") // anual | mensual | trimestral
  estado          String    @default("borrador") // borrador | aprobado | vigente | cerrado
  montoTotal      Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int
  lineas          LineaPresupuestoGasto[]

  @@index([empresaId, ejercicio])
  @@map("presupuestos_gasto")
}

model LineaPresupuestoGasto {
  id              Int       @id @default(autoincrement())
  presupuestoId   Int
  presupuesto     PresupuestoGasto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  cuentaContableId Int?     // Cuenta de gasto
  centroCostoId   Int?      // Centro de costo
  mes             Int       // 1-12
  montoPresupuestado Float
  montoEjecutado  Float     @default(0) // Se actualiza automáticamente
  montoComprometido Float   @default(0) // OC aprobadas no facturadas
  observaciones   String?

  @@index([presupuestoId, mes])
  @@index([cuentaContableId])
  @@map("lineas_presupuesto_gasto")
}

// ─── FLUJO DE FONDOS PROYECTADO ──────────────────────────────────────────────
// Proyección de cash flow basado en CxC, CxP, cheques diferidos, cuotas
// Diferenciador Tango Tablero Financiero + SAP Cash Management

model ProyeccionFlujoCaja {
  id              Int       @id @default(autoincrement())
  fecha           DateTime  @db.Date
  tipo            String    // "cobro_previsto" | "pago_previsto" | "cheque_diferido_cobrar" | "cheque_diferido_pagar" | "cuota_cobrar" | "cuota_pagar" | "gasto_fijo" | "ingreso_fijo"
  origenEntidad   String?   // "cuenta_cobrar" | "cuenta_pagar" | "cheque" | "gasto_recurrente"
  origenId        Int?
  concepto        String
  monto           Float
  moneda          String    @default("ARS")
  probabilidad    Float     @default(1.0) // 0-1, para estimaciones
  realizado       Boolean   @default(false)
  createdAt       DateTime  @default(now())

  empresaId       Int

  @@index([empresaId, fecha])
  @@index([empresaId, tipo])
  @@map("proyecciones_flujo_caja")
}

// ─── CRM / PIPELINE DE OPORTUNIDADES ────────────────────────────────────────
// Gestión de leads y oportunidades comerciales
// Diferenciador SAP CRM + Salesforce-like pipeline

model Lead {
  id              Int       @id @default(autoincrement())
  nombre          String
  empresa         String?
  email           String?
  telefono        String?
  origen          String    @default("manual") // manual | web | referido | mercadolibre | tiendanube | whatsapp | feria
  estado          String    @default("nuevo") // nuevo | contactado | calificado | descartado | convertido
  vendedorId      Int?
  notas           String?   @db.Text
  valorEstimado   Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  convertidoAt    DateTime?
  clienteId       Int?      // Se llena al convertir

  empresaId       Int
  oportunidades   Oportunidad[]
  actividades     ActividadCRM[]

  @@index([empresaId, estado])
  @@index([empresaId, vendedorId])
  @@map("leads")
}

model Oportunidad {
  id              Int       @id @default(autoincrement())
  nombre          String    // "Venta servidor X para Empresa Y"
  leadId          Int?
  lead            Lead?     @relation(fields: [leadId], references: [id])
  clienteId       Int?
  vendedorId      Int?
  etapa           String    @default("prospecto") // prospecto | propuesta | negociacion | cierre | ganada | perdida
  probabilidad    Float     @default(10) // % probabilidad de cierre
  montoEstimado   Float
  montoReal       Float?
  fechaCierreEstimada DateTime? @db.Date
  motivoPerdida   String?
  presupuestoId   Int?      // Link a Presupuesto cuando se genera
  pedidoVentaId   Int?      // Link a PedidoVenta cuando se convierte
  notas           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  cerradaAt       DateTime?

  empresaId       Int
  actividades     ActividadCRM[]

  @@index([empresaId, etapa])
  @@index([empresaId, vendedorId])
  @@map("oportunidades")
}

model ActividadCRM {
  id              Int       @id @default(autoincrement())
  tipo            String    // "llamada" | "email" | "reunion" | "whatsapp" | "visita" | "nota"
  descripcion     String    @db.Text
  fecha           DateTime  @default(now())
  completada      Boolean   @default(false)
  leadId          Int?
  lead            Lead?     @relation(fields: [leadId], references: [id])
  oportunidadId   Int?
  oportunidad     Oportunidad? @relation(fields: [oportunidadId], references: [id])
  usuarioId       Int

  empresaId       Int

  @@index([empresaId, fecha])
  @@map("actividades_crm")
}

// ─── MRP — PLANIFICACIÓN DE NECESIDADES ─────────────────────────────────────
// Material Requirements Planning basado en BOM + demanda
// Diferenciador SAP PP-MRP

model CorreridaMRP {
  id              Int       @id @default(autoincrement())
  fecha           DateTime  @default(now())
  horizonte       Int       @default(30) // días de planificación
  estado          String    @default("ejecutando") // ejecutando | completado | error
  totalSugerencias Int      @default(0)
  createdAt       DateTime  @default(now())

  empresaId       Int
  sugerencias     SugerenciaMRP[]

  @@index([empresaId])
  @@map("corridas_mrp")
}

model SugerenciaMRP {
  id              Int       @id @default(autoincrement())
  corridaId       Int
  corrida         CorreridaMRP @relation(fields: [corridaId], references: [id], onDelete: Cascade)
  productoId      Int
  tipo            String    // "comprar" | "producir" | "transferir"
  cantidad        Float
  fechaNecesidad  DateTime  @db.Date
  prioridad       String    @default("normal") // critica | alta | normal | baja
  estado          String    @default("pendiente") // pendiente | aceptada | rechazada | convertida
  ordenCompraId   Int?      // Se llena al convertir en OC
  ordenProduccionId Int?    // Se llena al convertir en OP
  razon           String?   @db.Text // "Stock bajo mínimo" | "Pedido #123 requiere"

  @@index([corridaId])
  @@map("sugerencias_mrp")
}

// ─── GESTIÓN DE CALIDAD ─────────────────────────────────────────────────────
// Inspecciones en recepción y producción
// Diferenciador SAP QM + Bejerman Calidad

model PlantillaInspeccion {
  id              Int       @id @default(autoincrement())
  nombre          String    // "Inspección materia prima alimenticia"
  entidad         String    // "recepcion_compra" | "orden_produccion" | "despacho"
  activa          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  empresaId       Int
  criterios       CriterioInspeccion[]

  @@index([empresaId, entidad])
  @@map("plantillas_inspeccion")
}

model CriterioInspeccion {
  id              Int       @id @default(autoincrement())
  plantillaId     Int
  plantilla       PlantillaInspeccion @relation(fields: [plantillaId], references: [id], onDelete: Cascade)
  nombre          String    // "Temperatura" | "Color" | "Certificado sanitario"
  tipo            String    // "si_no" | "rango_numerico" | "texto" | "foto"
  valorMinimo     Float?
  valorMaximo     Float?
  obligatorio     Boolean   @default(true)
  orden           Int       @default(0)

  @@map("criterios_inspeccion")
}

model InspeccionCalidad {
  id              Int       @id @default(autoincrement())
  plantillaId     Int
  entidad         String
  entidadId       Int
  estado          String    @default("en_curso") // en_curso | aprobada | rechazada | aprobada_con_desvio
  inspectorId     Int
  observaciones   String?   @db.Text
  createdAt       DateTime  @default(now())
  completadaAt    DateTime?

  empresaId       Int
  resultados      ResultadoInspeccion[]

  @@index([empresaId, entidad, entidadId])
  @@map("inspecciones_calidad")
}

model ResultadoInspeccion {
  id              Int       @id @default(autoincrement())
  inspeccionId    Int
  inspeccion      InspeccionCalidad @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)
  criterioId      Int
  valorTexto      String?
  valorNumerico   Float?
  valorBooleano   Boolean?
  conforme        Boolean   @default(true)
  observacion     String?

  @@map("resultados_inspeccion")
}

// ─── KPI DASHBOARD EJECUTIVO ─────────────────────────────────────────────────
// Tablero de control con métricas en tiempo real
// Diferenciador Tango Tablero + SAP Analytics Cloud

model KPIDefinicion {
  id              Int       @id @default(autoincrement())
  codigo          String    // "VENTA_DIA" | "MARGEN_BRUTO" | "DSO" | "DPO" | "ROTACION_STOCK"
  nombre          String    // "Ventas del día"
  categoria       String    // "ventas" | "finanzas" | "stock" | "compras" | "rrhh"
  unidad          String    @default("ARS") // "ARS" | "%" | "dias" | "unidades"
  formula         String?   @db.Text // SQL o descripción del cálculo
  metaValor       Float?    // Objetivo target
  alertaAmarilla  Float?    // Umbral warning
  alertaRoja      Float?    // Umbral critical
  activo          Boolean   @default(true)
  orden           Int       @default(0)
  createdAt       DateTime  @default(now())

  empresaId       Int
  snapshots       KPISnapshot[]

  @@unique([empresaId, codigo])
  @@map("kpi_definiciones")
}

model KPISnapshot {
  id              Int       @id @default(autoincrement())
  kpiId           Int
  kpi             KPIDefinicion @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  valor           Float
  fecha           DateTime  @db.Date
  createdAt       DateTime  @default(now())

  @@index([kpiId, fecha])
  @@map("kpi_snapshots")
}

// ─── GASTOS RECURRENTES ─────────────────────────────────────────────────────
// Alquileres, servicios, seguros — se proyectan al flujo de caja
// Diferenciador Xubio + Colppy

model GastoRecurrente {
  id              Int       @id @default(autoincrement())
  concepto        String    // "Alquiler oficina" | "Servicio internet"
  monto           Float
  moneda          String    @default("ARS")
  frecuencia      String    @default("mensual") // mensual | bimestral | trimestral | anual
  diaVencimiento  Int       @default(10) // Día del mes
  cuentaContableId Int?
  centroCostoId   Int?
  proveedorId     Int?
  activo          Boolean   @default(true)
  fechaInicio     DateTime  @db.Date
  fechaFin        DateTime? @db.Date
  createdAt       DateTime  @default(now())

  empresaId       Int

  @@index([empresaId, activo])
  @@map("gastos_recurrentes")
}

// ══════════════════════════════════════════════════════════════════════════════
// ─── DOCUMENTOS ADJUNTOS / GED ──────────────────────────────────────────────
// Sistema polimórfico de documentos adjuntos. Permite adjuntar archivos a
// cualquier entidad del sistema (facturas, compras, clientes, OC, etc.)
// ══════════════════════════════════════════════════════════════════════════════

model DocumentoAdjunto {
  id              Int       @id @default(autoincrement())
  /// Entidad a la que se adjunta: "factura" | "compra" | "cliente" | "proveedor" | "orden_compra" | "pedido_venta" | "remito" | "asiento" | "activo_fijo" | "inspeccion" | "legajo"
  entidadTipo     String
  /// ID de la entidad
  entidadId       Int
  /// Nombre original del archivo
  nombreArchivo   String
  /// MIME type: "application/pdf", "image/jpeg", etc.
  mimeType        String
  /// Tamaño en bytes
  tamanio         Int
  /// URL del archivo en storage (Supabase Storage / S3)
  url             String
  /// Storage key para operaciones de borrado
  storageKey      String
  /// Categoría: "constancia_afip" | "contrato" | "remito_firmado" | "cert_exclusion" | "presupuesto" | "otro"
  categoria       String    @default("otro")
  /// Descripción libre
  descripcion     String?
  /// ID del usuario que subió el archivo
  subidoPor       Int?
  createdAt       DateTime  @default(now())

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId, entidadTipo, entidadId])
  @@map("documentos_adjuntos")
}

// ══════════════════════════════════════════════════════════════════════════════
// ─── FACTURACIÓN RECURRENTE ─────────────────────────────────────────────────
// Genera facturas automáticas periódicamente para suscripciones, membresías,
// alquileres, servicios recurrentes. Mirror de GastoRecurrente pero para ventas.
// ══════════════════════════════════════════════════════════════════════════════

model FacturaRecurrente {
  id              Int       @id @default(autoincrement())
  /// Concepto: "Suscripción mensual", "Alquiler oficina", etc.
  concepto        String
  /// Monto neto (sin IVA)
  montoNeto       Decimal   @db.Decimal(15,2)
  /// Alícuota IVA: 21, 10.5, 27, 0
  alicuotaIva     Float     @default(21)
  /// "mensual" | "bimestral" | "trimestral" | "semestral" | "anual"
  frecuencia      String    @default("mensual")
  /// Día del mes para emitir (1-28)
  diaEmision      Int       @default(1)
  /// Próxima fecha de emisión
  proximaEmision  DateTime  @db.Date
  /// Fecha hasta la cual se emiten (null = indefinida)
  fechaFin        DateTime? @db.Date
  /// Tipo de comprobante AFIP: 1=Factura A, 6=Factura B, 11=Factura C
  tipoCbte        Int       @default(6)
  /// AFIP Concepto: 2=Servicios
  concepto_afip   Int       @default(2)
  /// Si está activa para emisión automática
  activo          Boolean   @default(true)
  /// Cantidad de facturas ya emitidas
  facturasEmitidas Int      @default(0)
  /// Última fecha en que se emitió
  ultimaEmision   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clienteId       Int
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId, activo, proximaEmision])
  @@map("facturas_recurrentes")
}

// ══════════════════════════════════════════════════════════════════════════════
// ─── MERCADOPAGO INTEGRACIÓN ────────────────────────────────────────────────
// Pagos vía QR, checkout pro, transferencia. Webhook de confirmación y
// conciliación automática con CxC.
// ══════════════════════════════════════════════════════════════════════════════

model MercadoPagoConfig {
  id              Int       @id @default(autoincrement())
  /// Access token (encrypted at rest)
  accessToken     String
  /// Public key para frontend
  publicKey       String
  /// User ID de MP para identificar cuenta
  mpUserId        String?
  /// Nombre de la cuenta (para UI)
  nombreCuenta    String?
  /// Webhook secret para verificar notificaciones
  webhookSecret   String?
  /// Si recibe pagos QR en punto de venta
  qrHabilitado    Boolean   @default(true)
  /// Si usa Checkout Pro para portal/tienda
  checkoutHabilitado Boolean @default(true)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int       @unique
  empresa         Empresa   @relation(fields: [empresaId], references: [id])
  transacciones   MercadoPagoTransaccion[]

  @@map("mercadopago_config")
}

model MercadoPagoTransaccion {
  id              Int       @id @default(autoincrement())
  /// ID de pago en MercadoPago
  mpPaymentId     String    @unique
  /// "approved" | "pending" | "rejected" | "refunded" | "cancelled"
  estado          String
  /// Monto cobrado
  monto           Decimal   @db.Decimal(15,2)
  /// Monto neto (descontada comisión MP)
  montoNeto       Decimal?  @db.Decimal(15,2)
  /// Comisión de MP
  comisionMp      Decimal?  @db.Decimal(15,2)
  /// "credit_card" | "debit_card" | "account_money" | "qr" | "transfer"
  medioPago       String
  /// Descripción del pago
  descripcion     String?
  /// Email del pagador
  emailPagador    String?
  /// CUIT/DNI del pagador
  docPagador      String?
  /// FK a factura si se concilió
  facturaId       Int?
  /// FK a CxC si se concilió
  cuentaCobrarId  Int?
  /// Si ya se concilió automáticamente
  conciliado      Boolean   @default(false)
  /// Fecha del pago en MP
  fechaPago       DateTime?
  /// Datos raw del webhook (JSON)
  rawData         String?   @db.Text
  createdAt       DateTime  @default(now())

  configId        Int
  config          MercadoPagoConfig @relation(fields: [configId], references: [id])
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId, estado])
  @@index([mpPaymentId])
  @@map("mercadopago_transacciones")
}

// ══════════════════════════════════════════════════════════════════════════════
// ─── ALERTAS CONFIGURABLES POR USUARIO ──────────────────────────────────────
// Motor de alertas parametrizables: condición → acción → destinatario.
// Complementa las AlertaIA hardcoded con reglas definidas por el usuario.
// ══════════════════════════════════════════════════════════════════════════════

model ReglaAlerta {
  id              Int       @id @default(autoincrement())
  /// Nombre descriptivo: "Stock bajo de insumos", "CxC vencida > 60 días"
  nombre          String
  /// "stock_bajo" | "cxc_vencida" | "cxp_vencida" | "diferencia_caja" | "venta_baja" | "presupuesto_excedido" | "custom"
  tipoRegla       String
  /// Configuración JSON de la condición: { campo, operador, valor, entidad }
  condicion       String    @db.Text
  /// "email" | "notificacion" | "whatsapp" | "webhook"
  accion          String    @default("notificacion")
  /// ID de usuario destinatario (null = admin)
  destinatarioId  Int?
  /// Email destino (si accion = "email")
  emailDestino    String?
  /// Cada cuántas horas re-evaluar (0 = sólo manual)
  frecuenciaHoras Int       @default(24)
  /// Último chequeo
  ultimoChequeo   DateTime?
  /// Si se activó la última vez
  ultimoResultado Boolean?
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId, activo])
  @@map("reglas_alertas")
}

// ══════════════════════════════════════════════════════════════════════════════
// ─── LEGAJO DE EMPLEADOS / RRHH BÁSICO ──────────────────────────────────────
// Datos del empleado: legales, laborales, ART, obra social, sindicato.
// No incluye liquidación de sueldos (demasiado complejo), pero sí ABM.
// ══════════════════════════════════════════════════════════════════════════════

model Empleado {
  id              Int       @id @default(autoincrement())
  /// Nombre completo
  nombre          String
  /// CUIL: XX-XXXXXXXX-X
  cuil            String
  /// DNI
  dni             String?
  /// Fecha de nacimiento
  fechaNacimiento DateTime? @db.Date
  /// Domicilio completo
  domicilio       String?
  /// Localidad
  localidad       String?
  /// Provincia
  provincia       String?
  /// Código postal
  codigoPostal    String?
  /// Teléfono
  telefono        String?
  /// Email personal
  email           String?
  /// Fecha de ingreso
  fechaIngreso    DateTime  @db.Date
  /// Fecha de egreso (null = activo)
  fechaEgreso     DateTime? @db.Date
  /// "activo" | "licencia" | "baja"
  estado          String    @default("activo")
  /// Puesto / cargo
  cargo           String?
  /// Departamento / área
  departamento    String?
  /// Categoría de convenio colectivo
  categoriaConvenio String?
  /// Convenio colectivo de trabajo (ej: "Comercio 130/75")
  convenioCCT     String?
  /// Modalidad: "relacion_dependencia" | "monotributo" | "pasantia" | "contrato"
  modalidad       String    @default("relacion_dependencia")
  /// Tipo de jornada: "completa" | "parcial" | "reducida"
  tipoJornada     String    @default("completa")
  /// Sueldo bruto básico mensual
  sueldoBruto     Decimal?  @db.Decimal(15,2)
  /// CBU para depósito de haberes
  cbu             String?
  /// ART contratada
  art             String?
  /// Nro de siniestro ART (si aplica)
  nroSiniestroArt String?
  /// Obra social
  obraSocial      String?
  /// Nro de afiliado obra social
  nroAfiliadoOS   String?
  /// Sindicato
  sindicato       String?
  /// Nro de afiliado sindicato
  nroAfiliadoSind String?
  /// Observaciones
  observaciones   String?   @db.Text
  /// FK al Usuario del sistema (si tiene acceso)
  usuarioId       Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId, estado])
  @@index([cuil])
  @@map("empleados")
}

// ══════════════════════════════════════════════════════════════════════════════
// ─── CITI VENTAS / COMPRAS (RG 3685) ────────────────────────────────────────
// Control de generación de archivos CITI para AFIP.
// ══════════════════════════════════════════════════════════════════════════════

model GeneracionCITI {
  id              Int       @id @default(autoincrement())
  /// "ventas" | "compras"
  tipo            String
  /// Período: "2026-01", "2026-02", etc.
  periodo         String
  /// Cantidad de registros incluidos
  cantidadRegistros Int
  /// Nombre del archivo generado
  nombreArchivo   String
  /// URL de descarga (storage)
  url             String?
  /// Hash SHA256 del contenido para verificación
  hashContenido   String?
  /// "generado" | "presentado" | "error"
  estado          String    @default("generado")
  createdAt       DateTime  @default(now())

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, tipo, periodo])
  @@map("generaciones_citi")
}

// ══════════════════════════════════════════════════════════════════════════════
// ─── COTIZACIÓN AUTOMÁTICA BNA/BCRA ─────────────────────────────────────────
// Registro de cotizaciones obtenidas automáticamente.
// ══════════════════════════════════════════════════════════════════════════════

model CotizacionAutomatica {
  id              Int       @id @default(autoincrement())
  /// "USD_OFICIAL" | "USD_MEP" | "USD_CCL" | "EUR" | "BRL"
  monedaPar       String
  /// Valor compra
  compra          Decimal   @db.Decimal(15,4)
  /// Valor venta
  venta           Decimal   @db.Decimal(15,4)
  /// Fuente: "BNA" | "BCRA" | "DOLARAPI" | "MANUAL"
  fuente          String
  /// Fecha de la cotización
  fecha           DateTime  @db.Date

  @@unique([monedaPar, fecha, fuente])
  @@index([fecha])
  @@map("cotizaciones_automaticas")
}

// ══════════════════════════════════════════════════════════════════════════════
// ─── MANTENIMIENTO PREVENTIVO ───────────────────────────────────────────────
// Órdenes de mantenimiento, calendario preventivo, tracking de activos.
// ══════════════════════════════════════════════════════════════════════════════

model PlanMantenimiento {
  id              Int       @id @default(autoincrement())
  /// Nombre: "Servicio anual compresor", "Cambio aceite flota"
  nombre          String
  /// Descripción de tareas
  descripcion     String?   @db.Text
  /// "diario" | "semanal" | "mensual" | "trimestral" | "semestral" | "anual" | "por_horas"
  frecuencia      String
  /// Próxima fecha programada
  proximaEjecucion DateTime @db.Date
  /// FK al activo fijo (si aplica)
  activoFijoId    Int?
  /// Nombre del equipo/máquina (si no es activo fijo registrado)
  equipo          String?
  /// Responsable asignado
  responsable     String?
  /// Costo estimado por ejecución
  costoEstimado   Decimal?  @db.Decimal(15,2)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])
  ordenesTrabajo  OrdenTrabajo[]

  @@index([empresaId, activo])
  @@map("planes_mantenimiento")
}

model OrdenTrabajo {
  id              Int       @id @default(autoincrement())
  /// Número correlativo
  numero          String
  /// "preventivo" | "correctivo" | "predictivo"
  tipo            String    @default("preventivo")
  /// Descripción del trabajo
  descripcion     String    @db.Text
  /// "pendiente" | "en_proceso" | "completada" | "cancelada"
  estado          String    @default("pendiente")
  /// Prioridad: "baja" | "media" | "alta" | "urgente"
  prioridad       String    @default("media")
  /// Fecha programada
  fechaProgramada DateTime  @db.Date
  /// Fecha de inicio real
  fechaInicio     DateTime?
  /// Fecha de finalización
  fechaFin        DateTime?
  /// Técnico asignado
  tecnicoAsignado String?
  /// Observaciones / resultado
  observaciones   String?   @db.Text
  /// Costo real de mano de obra
  costoManoObra   Decimal?  @db.Decimal(15,2)
  /// Costo real de repuestos
  costoRepuestos  Decimal?  @db.Decimal(15,2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  planId          Int?
  plan            PlanMantenimiento? @relation(fields: [planId], references: [id])
  empresaId       Int
  empresa         Empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId, estado])
  @@map("ordenes_trabajo")
}

/// FIX C-006: Log de cada request/response al webservice AFIP.
/// Permite auditar, reproducir errores y detectar CAEs duplicados.
model AfipWebserviceLog {
  id            Int       @id @default(autoincrement())
  /// Webservice: "WSAA" | "WSFE" | "WSCDC" | "PADRON_A5" | "CAEA"
  webservice    String
  /// Operación: "FECAESolicitar" | "FECompUltimoAutorizado" | "login" | etc.
  operacion     String
  /// XML o JSON del request enviado (puede ser largo)
  requestBody   String?   @db.Text
  /// XML o JSON de la response recibida
  responseBody  String?   @db.Text
  /// HTTP status o código interno (200, 500, TIMEOUT, etc.)
  statusCode    String?
  /// CAE obtenido si la operación fue exitosa
  cae           String?
  /// Número de factura asociada
  facturaId     Int?
  /// Tiempo de respuesta en milisegundos
  duracionMs    Int?
  /// Error legible si falló
  errorMsg      String?   @db.Text
  createdAt     DateTime  @default(now())

  empresaId     Int
  empresa       Empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId, webservice, createdAt])
  @@index([empresaId, cae])
  @@index([facturaId])
  @@map("afip_webservice_logs")
}

/// Tareas personales del usuario para organizar su jornada.
/// Cada tarea puede ser privada o visible al jefe/administrador.
model TareaPendiente {
  id               Int       @id @default(autoincrement())
  titulo           String
  descripcion      String?   @db.Text
  completada       Boolean   @default(false)
  /// "baja" | "media" | "alta" | "urgente"
  prioridad        String    @default("media")
  fechaVencimiento DateTime? @db.Date
  /// false = solo el usuario la ve; true = visible para administradores/jefes
  visibleJefe      Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  usuarioId        Int
  usuario          Usuario   @relation(fields: [usuarioId], references: [id])
  empresaId        Int
  empresa          Empresa   @relation(fields: [empresaId], references: [id])

  @@index([usuarioId, completada])
  @@map("tareas_pendientes")
}
