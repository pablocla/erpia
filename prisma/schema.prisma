}

model HojaRuta {
  id            Int       @id @default(autoincrement())
  numero        String    @unique
  fecha         DateTime  @db.Date
  /// "planificada" | "en_ruta" | "finalizada" | "cancelada"
  estado        String    @default("planificada")
  kmEstimado    Float?
  observaciones String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  empresaId     Int
  empresa       Empresa   @relation(fields: [empresaId], references: [id])

  vehiculoId    Int?
  vehiculo      Vehiculo? @relation(fields: [vehiculoId], references: [id])
  choferId      Int?
  chofer        Chofer?   @relation(fields: [choferId], references: [id])

  paradas       ParadaRuta[]

  @@map("hojas_ruta")
}

model ParadaRuta {
  id               Int       @id @default(autoincrement())
  orden            Int
  /// "pendiente" | "en_curso" | "entregado" | "no_entregado"
  estado           String    @default("pendiente")
  direccion        String
  localidad        String?
  ventanaDesde     DateTime?
  ventanaHasta     DateTime?
  horaArribo       DateTime?
  horaSalida       DateTime?
  lat              Float?
  lng              Float?
  contactoNombre   String?
  contactoTelefono String?
  motivoNoEntrega  String?
  observaciones    String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  hojaRutaId       Int
  hojaRuta         HojaRuta  @relation(fields: [hojaRutaId], references: [id], onDelete: Cascade)
  envioId          Int?      @unique
  envio            Envio?    @relation(fields: [envioId], references: [id])
  clienteId        Int?
  cliente          Cliente?  @relation(fields: [clienteId], references: [id])

  evidencia        EvidenciaEntrega?

  @@map("paradas_ruta")
}

model EvidenciaEntrega {
  id                Int       @id @default(autoincrement())
  receptorNombre    String?
  receptorDocumento String?
  firmaBase64       String?   @db.Text
  fotoUrl           String?
  geoLat            Float?
  geoLng            Float?
  fecha             DateTime  @default(now())

  paradaId          Int       @unique
  parada            ParadaRuta @relation(fields: [paradaId], references: [id], onDelete: Cascade)

  @@map("evidencias_entrega")
}

// ─── INDUSTRIA — Producción y BOM ────────────────────────────────────────────

model ListaMateriales {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  nombre      String
  descripcion String?
  /// "produccion" | "receta"
  tipo        String    @default("produccion")
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id])

  productoId  Int?
  producto    Producto? @relation(fields: [productoId], references: [id])

  componentes ComponenteBOM[]
  ordenes     OrdenProduccion[]

  @@map("listas_materiales")
}

model ComponenteBOM {
  id          Int             @id @default(autoincrement())
  cantidad    Float
  unidad      String          @default("unidad")
  descripcion String?

  bomId       Int
  bom         ListaMateriales @relation(fields: [bomId], references: [id], onDelete: Cascade)
  productoId  Int?
  producto    Producto?       @relation(fields: [productoId], references: [id])

  @@map("componentes_bom")
}

model OrdenProduccion {
